page { background: #f0f2f5; min-height: 100vh; }
.page { min-height: 100vh; padding-bottom: 120rpx; }
.container { padding: 20rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 20rpx; margin-bottom: 16rpx; }
.stitle { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; }
.actions { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12rpx; }
.act { display: flex; flex-direction: column; align-items: center; font-size: 22rpx; color: #333; }
.act-icon { width: 80rpx; height: 80rpx; background: #f0f2f5; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; font-size: 40rpx; margin-bottom: 8rpx; }
.stats-row { display: flex; gap: 10rpx; }
.stat-box { flex: 1; text-align: center; background: #f8f9fa; border-radius: 12rpx; padding: 16rpx 8rpx; }
.sval { font-size: 36rpx; font-weight: bold; color: #333; display: block; }
.sval.purple { color: #7c3aed; }
.sval.orange { color: #f59e0b; }
.sval.dark { color: #6b7280; }
.slb { font-size: 20rpx; color: #999; margin-top: 4rpx; display: block; }
.news { display: flex; align-items: center; padding: 12rpx 0; border-bottom: 1px solid #eee; }
.news:last-child { border-bottom: none; }
.news-tag { padding: 3rpx 10rpx; background: #e8f5e9; border-radius: 6rpx; font-size: 18rpx; margin-right: 8rpx; color: #2e7d32; flex-shrink: 0; }
.news-tag.pinned { background: #ff3b30; color: #fff; }
.news-tag.official { background: #e3f2fd; color: #1565c0; }
.news-badge-new { display: inline-block; padding: 2rpx 8rpx; background: #ff6900; color: #fff; border-radius: 4rpx; font-size: 16rpx; margin-right: 6rpx; vertical-align: middle; }
.news-body { flex: 1; }
.news-t { font-size: 26rpx; color: #333; display: block; }
.news-d { font-size: 18rpx; color: #999; margin-top: 4rpx; display: block; }
.foot { text-align: center; font-size: 20rpx; color: #999; padding: 16rpx 0; }
.navbar { position: fixed; bottom: 0; left: 0; right: 0; height: 100rpx; background: #fff; display: flex; box-shadow: 0 -1px 8px rgba(0,0,0,0.06); z-index: 999; }
.nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.nav-item.on::before { content: ''; position: absolute; top: 4rpx; width: 28rpx; height: 4rpx; background: #ff6900; border-radius: 2rpx; }
.nav-icon { font-size: 36rpx; margin-bottom: 2rpx; }
.nav-text { font-size: 20rpx; color: #999; }
.nav-item.on .nav-text { color: #333; font-weight: bold; }
.banner-card { border-radius: 20rpx; overflow: hidden; margin-bottom: 16rpx; }
.banner-bg { background: linear-gradient(135deg, #5b6abf, #7c4dff, #4a148c); border-radius: 20rpx; padding: 28rpx 24rpx 20rpx; min-height: 340rpx; position: relative; overflow: hidden; }
.banner-deco-1 { position: absolute; top: -40rpx; right: -20rpx; width: 180rpx; height: 180rpx; background: rgba(255,255,255,0.08); border-radius: 50%; }
.banner-deco-2 { position: absolute; bottom: 16rpx; left: -24rpx; width: 120rpx; height: 120rpx; background: rgba(255,255,255,0.06); border-radius: 50%; }
.banner-deco-3 { position: absolute; top: 50rpx; right: 32rpx; width: 70rpx; height: 70rpx; background: rgba(255,255,255,0.07); border-radius: 50%; }
.banner-content { position: relative; z-index: 2; }
.banner-sub { font-size: 22rpx; color: rgba(255,255,255,0.8); display: block; margin-bottom: 8rpx; }
.banner-title { font-size: 48rpx; font-weight: 900; color: #fff; display: block; line-height: 1.1; }
.banner-title-2 { font-size: 48rpx; font-weight: 900; color: #ffd54f; display: block; line-height: 1.1; margin-bottom: 12rpx; }
.banner-desc { font-size: 22rpx; color: rgba(255,255,255,0.85); display: block; margin-bottom: 16rpx; }
.banner-tags { display: flex; gap: 10rpx; flex-wrap: wrap; }
.banner-tag { display: flex; align-items: center; gap: 4rpx; background: rgba(255,255,255,0.2); border-radius: 16rpx; padding: 6rpx 12rpx; }
.tag-icon { font-size: 22rpx; }
.tag-text { font-size: 20rpx; color: #fff; }
.banner-bottom { position: absolute; bottom: 20rpx; left: 24rpx; right: 24rpx; z-index: 2; display: flex; justify-content: space-between; align-items: center; }
.banner-slogan { font-size: 22rpx; font-weight: 600; color: #fff; }
.banner-slogan-sub { font-size: 18rpx; color: rgba(255,255,255,0.7); }
