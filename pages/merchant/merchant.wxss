/* 商人页科技感样式 */
.merchant-tip { text-align: center; padding: 32rpx 0; }
.tip-icon { font-size: 72rpx; display: block; margin-bottom: 20rpx; }
.tip-title-row { display: flex; align-items: center; justify-content: center; gap: 12rpx; margin-bottom: 16rpx; }
.tip-title { font-size: 32rpx; font-weight: 700; color: #fff; }
.tip-desc-row { display: flex; align-items: center; justify-content: center; gap: 12rpx; margin-bottom: 12rpx; }
.tip-desc { font-size: 26rpx; color: rgba(255,255,255,0.8); }
.tip-hint { font-size: 22rpx; color: rgba(0,212,255,0.7); }
.edit-btn { font-size: 24rpx; padding: 4rpx 8rpx; background: rgba(0,212,255,0.15); border: 1rpx solid rgba(0,212,255,0.3); border-radius: 8rpx; }
.edit-btn:active { background: rgba(0,212,255,0.3); }
.card-title { font-size: 28rpx; font-weight: 700; color: #00d4ff; margin-bottom: 20rpx; padding-left: 16rpx; border-left: 4rpx solid #00d4ff; text-transform: uppercase; letter-spacing: 2rpx; }
.item-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12rpx; }
.item-card { background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 14rpx; padding: 20rpx; position: relative; }
.item-badge { position: absolute; top: 10rpx; right: 10rpx; padding: 3rpx 10rpx; border-radius: 6rpx; font-size: 16rpx; color: #fff; font-weight: 600; }
.badge-normal { background: rgba(255,255,255,0.3); }
.badge-rare { background: linear-gradient(135deg, #00d4ff, #0099cc); }
.badge-epic { background: linear-gradient(135deg, #9945ff, #7c3aed); }
.badge-legend { background: linear-gradient(135deg, #ffab40, #ff9100); }
.item-name { font-size: 28rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 8rpx; }
.item-price { font-size: 26rpx; color: #00d4ff; font-weight: 600; display: block; margin: 8rpx 0; text-shadow: 0 0 8px rgba(0,212,255,0.4); }
.item-effect { font-size: 22rpx; color: rgba(255,255,255,0.7); line-height: 1.5; }
.source { font-size: 22rpx; color: rgba(0,212,255,0.5); display: block; margin-top: 8rpx; }

/* 管理员栏 */
.admin-bar { padding: 20rpx 24rpx; margin-bottom: 16rpx; }
.admin-bar-row { display: flex; align-items: center; gap: 16rpx; }
.admin-bar-label { font-size: 26rpx; color: rgba(255,255,255,0.6); }
.admin-bar-text { font-size: 24rpx; color: #00d4ff; }
.toggle { width: 88rpx; height: 48rpx; background: rgba(255,255,255,0.15); border-radius: 24rpx; padding: 4rpx; transition: background 0.3s; margin-left: auto; }
.toggle.on { background: linear-gradient(135deg, #00d4ff, #9945ff); }
.toggle-dot { width: 40rpx; height: 40rpx; background: #fff; border-radius: 50%; transition: transform 0.3s; }
.toggle.on .toggle-dot { transform: translateX(40rpx); }

/* 编辑提示 */
.admin-edit-hint { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 16rpx; background: rgba(0,212,255,0.08); border: 1rpx dashed rgba(0,212,255,0.3); border-radius: 8rpx; margin-bottom: 16rpx; }
.edit-hint-icon { font-size: 28rpx; }
.edit-hint-text { font-size: 22rpx; color: rgba(0,212,255,0.7); }

/* 管理员面板 */
.admin-panel { border: 1rpx solid rgba(255,171,64,0.2); background: linear-gradient(145deg, rgba(255,171,64,0.05), rgba(20,25,60,0.9)); }
.admin-panel-title { display: flex; align-items: center; gap: 10rpx; margin-bottom: 20rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid rgba(255,171,64,0.15); }
.admin-panel-icon { font-size: 28rpx; }
.admin-panel-text { font-size: 28rpx; font-weight: 600; color: #ffab40; }
.admin-control-row { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid rgba(0,212,255,0.08); }
.admin-control-row:last-child { border-bottom: none; }
.admin-control-info { flex: 1; }
.admin-control-name { font-size: 26rpx; color: #fff; display: block; margin-bottom: 4rpx; }
.admin-control-desc { font-size: 22rpx; color: rgba(255,255,255,0.4); display: block; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 1000; display: flex; align-items: flex-end; }
.modal-box { width: 100%; background: linear-gradient(180deg, #1a1040, #0a0e27); border-radius: 24rpx 24rpx 0 0; padding: 32rpx; max-height: 80vh; display: flex; flex-direction: column; }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; flex-shrink: 0; }
.modal-title { font-size: 32rpx; font-weight: 700; color: #00d4ff; }
.modal-close { font-size: 36rpx; color: rgba(255,255,255,0.4); padding: 8rpx; }
.modal-body { overflow-y: auto; -webkit-overflow-scrolling: touch; }
.modal-input { width: 100%; min-height: 80rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; margin-bottom: 24rpx; }
.modal-textarea { width: 100%; height: 400rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 12rpx; padding: 20rpx; font-size: 26rpx; color: #fff; box-sizing: border-box; margin-bottom: 24rpx; }
.modal-footer { display: flex; gap: 16rpx; flex-shrink: 0; padding-top: 20rpx; }
.modal-cancel { flex: 1; background: rgba(255,255,255,0.1) !important; color: rgba(255,255,255,0.6) !important; border-radius: 12rpx !important; height: 80rpx !important; line-height: 80rpx !important; font-size: 28rpx !important; }
.modal-cancel::after { border: none; }
.modal-save { flex: 1; background: linear-gradient(135deg, #00d4ff, #9945ff) !important; color: #fff !important; border-radius: 12rpx !important; height: 80rpx !important; line-height: 80rpx !important; font-size: 28rpx !important; }
.modal-save::after { border: none; }
.modal-save[disabled] { opacity: 0.5; }

/* 表单样式 */
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 24rpx; color: rgba(255,255,255,0.6); display: block; margin-bottom: 8rpx; }
.picker-value { width: 100%; min-height: 80rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; line-height: 80rpx; }

/* 物品删除按钮 */
.item-card { position: relative; }
.item-delete { position: absolute; top: 10rpx; left: 10rpx; width: 36rpx; height: 36rpx; background: rgba(255,71,87,0.8); color: #fff; font-size: 20rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 2; }

/* 正在售卖 */
.selling-card { border: 1rpx solid rgba(255,71,87,0.2); background: linear-gradient(145deg, rgba(255,71,87,0.05), rgba(20,25,60,0.9)); }
.card-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.dev-edit-btn { display: flex; align-items: center; gap: 6rpx; padding: 6rpx 16rpx; background: rgba(255,71,87,0.15); border: 1rpx solid rgba(255,71,87,0.3); border-radius: 8rpx; }
.dev-edit-icon { font-size: 22rpx; }
.dev-edit-text { font-size: 22rpx; color: #ff4757; }
.dev-edit-btn:active { background: rgba(255,71,87,0.3); }
.selling-item { border-color: rgba(255,71,87,0.15); }
.selling-empty { text-align: center; padding: 32rpx 0; }
.selling-empty-text { font-size: 26rpx; color: rgba(255,255,255,0.3); }
.selling-tip { font-size: 24rpx; color: rgba(255,171,64,0.7); margin-bottom: 16rpx; padding: 12rpx 16rpx; background: rgba(255,171,64,0.08); border: 1rpx solid rgba(255,171,64,0.15); border-radius: 8rpx; }
.selling-textarea { height: 480rpx; }
.notify-hint { font-size: 22rpx; color: rgba(255,171,64,0.6); }

/* 新品上架滚动 */
.new-items-card { border: 1rpx solid rgba(255,171,64,0.2); background: linear-gradient(145deg, rgba(255,171,64,0.05), rgba(20,25,60,0.9)); overflow: hidden; }
.new-items-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20rpx; }
.new-items-label { display: flex; align-items: center; gap: 12rpx; }
.new-items-tag { padding: 4rpx 14rpx; background: linear-gradient(135deg, #ff6b35, #ffab40); border-radius: 6rpx; font-size: 18rpx; font-weight: 800; color: #fff; letter-spacing: 2rpx; animation: tagPulse 2s ease-in-out infinite; }
.new-items-title { font-size: 28rpx; font-weight: 700; color: #ffab40; }
.new-items-count { font-size: 22rpx; color: rgba(255,171,64,0.7); }
.new-items-marquee { overflow: hidden; margin: 0 -24rpx; padding: 0 24rpx; }
.new-items-track { display: flex; gap: 16rpx; transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
.new-items-track.sliding { transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
.new-item-card { min-width: 212rpx; background: rgba(0,0,0,0.4); border: 1rpx solid rgba(255,171,64,0.15); border-radius: 14rpx; padding: 20rpx; position: relative; flex-shrink: 0; }
.new-item-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2rpx; background: linear-gradient(90deg, transparent, rgba(255,171,64,0.5), transparent); }
.new-item-badge { display: inline-block; padding: 2rpx 10rpx; border-radius: 6rpx; font-size: 16rpx; color: #fff; font-weight: 600; margin-bottom: 10rpx; }
.new-item-name { font-size: 26rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 8rpx; }
.new-item-price { font-size: 24rpx; color: #ffab40; font-weight: 600; display: block; text-shadow: 0 0 8px rgba(255,171,64,0.3); }
.new-items-dots { display: flex; justify-content: center; gap: 10rpx; margin-top: 16rpx; }
.dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: rgba(255,255,255,0.2); transition: all 0.3s; }
.dot.active { background: #ffab40; width: 24rpx; border-radius: 5rpx; }

@keyframes tagPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.7; } }

/* 订阅 */
.subscribe-row { display: flex; align-items: center; justify-content: space-between; }
.subscribe-info { flex: 1; }
.subscribe-title { font-size: 28rpx; font-weight: 600; color: #fff; display: block; }
.subscribe-desc { font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; margin-top: 4rpx; }
.subscribe-right { flex-shrink: 0; }
.notify-counter { display: flex; align-items: center; gap: 12rpx; }
.counter-btn { width: 56rpx; height: 56rpx; background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(153,69,255,0.15)); border: 1rpx solid rgba(0,212,255,0.3); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; transition: all 0.2s; position: relative; overflow: hidden; }
.counter-btn::after { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); transition: left 0.4s; }
.counter-btn:active { transform: scale(0.92); background: linear-gradient(135deg, rgba(0,212,255,0.3), rgba(153,69,255,0.3)); }
.counter-btn:active::after { left: 100%; }
.counter-plus { font-size: 36rpx; color: #00d4ff; font-weight: 300; line-height: 1; }
.counter-badge { min-width: 40rpx; height: 40rpx; background: linear-gradient(135deg, #00d4ff, #9945ff); border-radius: 20rpx; display: flex; align-items: center; justify-content: center; padding: 0 10rpx; box-shadow: 0 4px 12px rgba(0,212,255,0.3); }
.counter-num { font-size: 22rpx; color: #fff; font-weight: 700; }
