  box-sizing: border-box;
}
.image-action-btn-mini:active {
  background: rgba(0, 212, 255, 0.2);
  transform: scale(0.96);
}
.action-icon-mini {
  font-size: 22rpx;
}
.action-text-mini {
  font-size: 20rpx;
  color: #00d4ff;
  font-weight: 600;
}
.modal-input.mini {
  flex: 1;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 10rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
