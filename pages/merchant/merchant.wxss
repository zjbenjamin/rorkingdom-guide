/* 远行商人 Liquid Glass */
.page { min-height: 100vh; background-color: #010314; background-image: radial-gradient(ellipse 60% 40% at 60% 30%, rgba(200,100,50,0.06) 0%, transparent 50%), linear-gradient(185deg, #020410 0%, #040c24 100%); animation: pageExpand 0.5s cubic-bezier(0.22, 0.61, 0.36, 1); padding-bottom: calc(180rpx + constant(safe-area-inset-bottom)); padding-bottom: calc(180rpx + env(safe-area-inset-bottom)); }
@keyframes pageExpand { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }

/* 基础卡片 */
.card { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 24rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.03) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 4rpx 16rpx rgba(0,0,0,0.12); }

.card-title { font-size: 26rpx; font-weight: 700; color: #00d4ff; margin-bottom: 20rpx; padding-left: 16rpx; border-left: 3rpx solid rgba(0,200,255,0.3); letter-spacing: 1rpx; }

/* 出差提示 */
.merchant-tip { text-align: center; padding: 20rpx 0; }
.tip-icon { font-size: 64rpx; display: block; margin-bottom: 16rpx; }
.tip-title { font-size: 28rpx; font-weight: 700; color: #fff; }
.tip-desc { font-size: 24rpx; color: rgba(255,255,255,0.6); }
.tip-hint { font-size: 20rpx; color: rgba(0,200,255,0.5); margin-top: 8rpx; display: block; }
.edit-btn { font-size: 22rpx; padding: 4rpx 10rpx; background: rgba(0,200,255,0.1); border: 1rpx solid rgba(0,200,255,0.15); border-radius: 8rpx; color: #00d4ff; text-align: center; }

/* 售卖头部垂直居中堆叠布局 */
.card-header-stacked {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
  width: 100%;
}

.card-title-center {
  font-size: 28rpx;
  font-weight: 700;
  color: #00d4ff;
  letter-spacing: 2rpx;
  text-align: center;
  padding: 0 20rpx;
  position: relative;
  margin-bottom: 4rpx;
}

.card-title-center::before,
.card-title-center::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 40rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.4));
}
.card-title-center::before {
  right: 100%;
  background: linear-gradient(270deg, transparent, rgba(0, 212, 255, 0.4));
}
.card-title-center::after {
  left: 100%;
  background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.4));
}

.selling-actions-center {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  flex-wrap: wrap;
}
.action-btn { display: flex; align-items: center; justify-content: center; gap: 6rpx; padding: 10rpx 20rpx; border-radius: 12rpx; font-size: 22rpx; font-weight: 600; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); border: 1rpx solid; white-space: nowrap; }
.action-btn:active { transform: scale(0.95); }
.action-icon { font-size: 22rpx; }
.action-text { font-size: 22rpx; }
.action-count { font-size: 16rpx; background: rgba(0,200,255,0.2); color: #00d4ff; padding: 0 8rpx; border-radius: 8rpx; font-weight: 700; }
.sub-btn { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08); color: rgba(255,255,255,0.6); }
.sub-btn.on { background: rgba(0,200,255,0.1); border-color: rgba(0,200,255,0.25); color: #00d4ff; box-shadow: 0 0 12rpx rgba(0,200,255,0.08); }
.add-btn { background: rgba(52,199,89,0.08); border-color: rgba(52,199,89,0.2); color: #34c759; box-shadow: 0 0 0 1rpx rgba(52,199,89,0.04) inset; }
.add-btn:active { background: rgba(52,199,89,0.15); }
.push-btn { background: rgba(0,200,255,0.1); border-color: rgba(0,200,255,0.2); color: #00d4ff; box-shadow: 0 0 0 1rpx rgba(0,200,255,0.04) inset; }
.push-btn:active { background: rgba(0,200,255,0.18); }

/* 管理员面板 */
.admin-panel { border: 1rpx solid rgba(255,171,64,0.15); background: rgba(255,171,64,0.04); box-shadow: 0 0 0 1rpx rgba(255,171,64,0.02) inset, 0 1rpx 0 rgba(255,171,64,0.03) inset; }
.admin-panel-title { display: flex; align-items: center; gap: 10rpx; margin-bottom: 16rpx; padding-bottom: 14rpx; border-bottom: 1rpx solid rgba(255,171,64,0.1); }
.admin-panel-icon { font-size: 28rpx; }
.admin-panel-text { font-size: 26rpx; font-weight: 700; color: #ffab40; }
.admin-control-row { display: flex; align-items: center; justify-content: space-between; padding: 14rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.admin-control-row:last-child { border-bottom: none; }
.admin-control-info { flex: 1; }
.admin-control-name { font-size: 24rpx; color: rgba(255,255,255,0.8); font-weight: 600; display: block; }
.admin-control-desc { font-size: 20rpx; color: rgba(255,255,255,0.35); display: block; margin-top: 2rpx; }

.admin-btn {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.1) 0%, rgba(0, 128, 255, 0.05) 100%);
  border: 1rpx solid rgba(0, 212, 255, 0.25);
  border-radius: 18rpx;
  color: #00d4ff;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 212, 255, 0.05), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  backdrop-filter: blur(8rpx);
}
.admin-btn:active {
  transform: scale(0.96) translateY(1rpx);
  background: linear-gradient(135deg, rgba(0, 212, 255, 0.2) 0%, rgba(0, 128, 255, 0.15) 100%);
  border-color: rgba(0, 212, 255, 0.55);
  box-shadow: 0 0 16rpx rgba(0, 212, 255, 0.25), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

/* 售卖容器 */
.selling-marquee-wrap { margin-top: 4rpx; }

/* 倒计时 */
.selling-countdown-bar { display: flex; align-items: center; justify-content: center; background: rgba(0,212,255,0.08); padding: 16rpx 0; margin-bottom: 16rpx; border-radius: 16rpx; border: 1rpx solid rgba(0,212,255,0.2); box-shadow: 0 4rpx 16rpx rgba(0,212,255,0.1); }
.hourglass-icon { display: inline-block; font-size: 28rpx; margin-right: 12rpx; transform-origin: center center; animation: hourglassSpin 2.5s infinite ease-in-out; }
@keyframes hourglassSpin {
  0% { transform: rotate(0deg); }
  40% { transform: rotate(180deg); }
  50% { transform: rotate(180deg); }
  90% { transform: rotate(360deg); }
  100% { transform: rotate(360deg); }
}
.countdown-label { font-size: 24rpx; color: rgba(255,255,255,0.7); margin-right: 12rpx; letter-spacing: 1rpx; }
.countdown-value { font-size: 28rpx; font-weight: 800; color: #00d4ff; font-family: 'DIN Alternate', monospace; letter-spacing: 2rpx; text-shadow: 0 0 10rpx rgba(0,212,255,0.3); }

/* 每件商品限售角标 */
.item-limit-badge { display: inline-block; background: rgba(255,171,64,0.15); border: 1rpx solid rgba(255,171,64,0.3); color: #ffab40; font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx; font-weight: 700; margin-top: 8rpx; font-family: 'DIN Alternate', monospace; }

/* --- 物品卡片优化 --- */
.item-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10rpx; }
.item-card { background: rgba(255,255,255,0.03); border: 1rpx solid rgba(255,255,255,0.06); border-radius: 18rpx; padding: 18rpx 16rpx; position: relative; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.02) inset, 0 1rpx 0 rgba(255,255,255,0.03) inset; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); opacity: 0; animation: cardEnter 0.4s cubic-bezier(0.22,0.61,0.36,1) forwards; }
.item-card.editable:active { background: rgba(0,200,255,0.06); border-color: rgba(0,200,255,0.15); transform: scale(0.98); }

.item-add-card { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx; min-height: 200rpx; border: 1rpx dashed rgba(255,255,255,0.12); background: rgba(255,255,255,0.02); opacity: 1; animation: none; }
.item-add-card:active { background: rgba(0,200,255,0.06); }
.item-add-icon { font-size: 48rpx; color: rgba(0,200,255,0.3); }
.item-add-text { font-size: 22rpx; color: rgba(255,255,255,0.35); }
.item-card:nth-child(1) { animation-delay: 0s; }
.item-card:nth-child(2) { animation-delay: 0.04s; }
.item-card:nth-child(3) { animation-delay: 0.08s; }
.item-card:nth-child(4) { animation-delay: 0.12s; }
.item-card:nth-child(5) { animation-delay: 0.16s; }
.item-card:nth-child(6) { animation-delay: 0.2s; }
@keyframes cardEnter { from { opacity: 0; transform: translateY(12rpx) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }

.item-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; min-height: 36rpx; }
.item-badge { display: inline-block; padding: 3rpx 10rpx; border-radius: 5rpx; font-size: 18rpx; color: #fff; font-weight: 700; }
.badge-normal { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7); }
.badge-rare { background: rgba(0,200,255,0.2); color: #00d4ff; }
.badge-epic { background: rgba(153,69,255,0.2); color: #9945ff; }
.badge-legend { background: rgba(255,171,64,0.2); color: #ffab40; }

.item-name { font-size: 26rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 6rpx; line-height: 1.3; }
.item-image { width: 120rpx; height: 120rpx; border-radius: 12rpx; margin: 0 auto 12rpx auto; display: block; border: 1rpx solid rgba(255,255,255,0.08); }
.item-price { font-size: 28rpx; font-weight: 800; color: #00d4ff; display: block; margin: 6rpx 0; font-family: 'DIN Alternate', monospace; }
.item-effect { font-size: 20rpx; color: rgba(255,255,255,0.5); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

.item-sub-btn { width: 36rpx; height: 36rpx; background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.25s cubic-bezier(0.16,1,0.3,1); }
.item-sub-btn.on { background: rgba(0,200,255,0.12); border-color: rgba(0,200,255,0.3); }
.item-sub-icon { font-size: 20rpx; color: rgba(255,255,255,0.4); }
.item-sub-btn.on .item-sub-icon { color: #00d4ff; }
.item-sub-btn:active { transform: scale(0.85); }

.item-card-actions { display: flex; align-items: center; gap: 12rpx; z-index: 10; }
.item-delete-btn { width: 36rpx; height: 36rpx; background: rgba(255,71,87,0.15); color: #ff4757; border: 1rpx solid rgba(255,71,87,0.3); font-size: 18rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.25s cubic-bezier(0.16,1,0.3,1); }
.item-delete-btn:active { background: #ff4757; color: #fff; transform: scale(0.85); }

.item-delete {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  width: 38rpx;
  height: 38rpx;
  background: rgba(255,71,87,0.15);
  color: #ff4757;
  border: 1rpx solid rgba(255,71,87,0.3);
  font-size: 20rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  box-sizing: border-box;
}
.item-delete:active {
  background: #ff4757;
  color: #fff;
  transform: scale(0.9);
}

/* 售卖物品 */
.selling-items {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}
.selling-item {
  background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.01) 100%);
  border: 1rpx solid rgba(255, 171, 64, 0.15);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.2), inset 0 1rpx 0 rgba(255,255,255,0.06);
  border-radius: 20rpx;
  padding: 24rpx 18rpx;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  overflow: hidden;
}
.selling-item .item-badge {
  margin-bottom: 12rpx;
}
.selling-items .item-add-card {
  border: 1rpx dashed rgba(255, 171, 64, 0.25) !important;
  background: rgba(255, 171, 64, 0.02) !important;
  box-shadow: none !important;
  min-height: 220rpx;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center !important;
  gap: 12rpx !important;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  box-sizing: border-box !important;
  animation: none !important;
  opacity: 1 !important;
}
.selling-items .item-add-card:active {
  background: rgba(255, 171, 64, 0.08) !important;
  border-color: rgba(255, 171, 64, 0.5) !important;
  transform: scale(0.97);
}
.selling-items .item-add-icon {
  font-size: 48rpx;
  color: #ffab40;
  line-height: 1;
  font-weight: 300;
}
.selling-items .item-add-text {
  font-size: 22rpx;
  color: rgba(255, 171, 64, 0.7);
  font-weight: 600;
  letter-spacing: 1rpx;
}
.selling-item:active {
  transform: translateY(-2rpx);
  border-color: rgba(255, 171, 64, 0.4);
  box-shadow: 0 12rpx 30rpx rgba(255, 171, 64, 0.08), inset 0 1rpx 0 rgba(255,255,255,0.08);
}
.selling-item::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border-radius: 20rpx;
  background: linear-gradient(135deg, transparent 40%, rgba(255,171,64,0.04) 50%, transparent 60%);
  background-size: 200% 200%;
  animation: sellShimmer 6s infinite linear;
  pointer-events: none;
}
@keyframes sellShimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
.selling-empty { text-align: center; padding: 32rpx 0; }
.selling-empty-text { font-size: 24rpx; color: rgba(255,255,255,0.35); }

/* Toggle 开关 */
.toggle { width: 88rpx; height: 48rpx; background: rgba(255,255,255,0.08); border-radius: 24rpx; padding: 4rpx; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); border: 1rpx solid rgba(255,255,255,0.06); }
.toggle.on { background: rgba(0,200,255,0.2); border-color: rgba(0,200,255,0.25); }
.toggle-dot { width: 40rpx; height: 40rpx; background: #fff; border-radius: 50%; transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1); box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.2); }
.toggle.on .toggle-dot { transform: translateX(40rpx); }

/* 订阅 */
.subscribe-row { display: flex; align-items: center; justify-content: space-between; }
.subscribe-info { flex: 1; }
.subscribe-title { font-size: 26rpx; font-weight: 600; color: #fff; display: block; }
.subscribe-desc { font-size: 20rpx; color: rgba(255,255,255,0.45); display: block; margin-top: 4rpx; }

/* 商品订阅列表 */
.sub-list-card { padding: 28rpx !important; }
.sub-item-scroll { margin-top: 20rpx; padding-right: 4rpx; }
.sub-item-row { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 12rpx; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.sub-item-row:last-child { border-bottom: none; }
.sub-item-left { display: flex; align-items: center; gap: 12rpx; flex: 1; min-width: 0; }
.sub-item-new { padding: 2rpx 10rpx; background: rgba(255,107,157,0.15); color: #ff6b9d; font-size: 16rpx; font-weight: 800; border-radius: 6rpx; border: 1rpx solid rgba(255,107,157,0.25); flex-shrink: 0; }
.sub-item-badge { flex-shrink: 0; }
.sub-item-info { flex: 1; min-width: 0; }
.sub-item-name { font-size: 24rpx; color: #fff; font-weight: 600; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sub-item-price { font-size: 20rpx; color: rgba(0,200,255,0.7); display: block; margin-top: 2rpx; }

.sub-item-actions { display: flex; align-items: center; gap: 10rpx; flex-shrink: 0; }
.unsub-btn { font-size: 20rpx; color: #ff4757; padding: 8rpx 16rpx; background: rgba(255,71,87,0.08); border: 1rpx solid rgba(255,71,87,0.2); border-radius: 10rpx; font-weight: 600; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); box-shadow: 0 0 0 1rpx rgba(255,71,87,0.04) inset; white-space: nowrap; }
.unsub-btn:active { transform: scale(0.95); background: rgba(255,71,87,0.15); }

/* 编辑提示 */
.admin-edit-hint { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 16rpx; background: rgba(0,200,255,0.04); border: 1rpx dashed rgba(0,200,255,0.15); border-radius: 10rpx; margin-bottom: 16rpx; }
.edit-hint-icon { font-size: 24rpx; }
.edit-hint-text { font-size: 20rpx; color: rgba(0,200,255,0.6); }

.source { font-size: 20rpx; color: rgba(255,255,255,0.3); display: block; margin-top: 8rpx; line-height: 1.5; }

/* 弹窗基础 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,2,12,0.8); backdrop-filter: blur(24rpx); -webkit-backdrop-filter: blur(24rpx); z-index: 10000; display: flex; align-items: flex-end; animation: modalFadeIn 0.4s cubic-bezier(0.16,1,0.3,1); }
@keyframes modalFadeIn { from { opacity: 0; transform: translateY(100rpx); } to { opacity: 1; transform: translateY(0); } }
.modal-box { width: 100%; background: rgba(16, 20, 48, 0.95); border-top: 1rpx solid rgba(255, 255, 255, 0.12); border-radius: 40rpx 40rpx 0 0; padding: 40rpx 32rpx; max-height: 92vh; display: flex; flex-direction: column; box-shadow: 0 -12rpx 60rpx rgba(0,0,0,0.6), inset 0 1rpx 0 rgba(255,255,255,0.06); box-sizing: border-box; }

.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40rpx; flex-shrink: 0; }
.modal-title-box { display: flex; align-items: center; gap: 16rpx; }
.modal-title-line { width: 6rpx; height: 32rpx; background: linear-gradient(to bottom, #00d4ff, #9945ff); border-radius: 3rpx; }
.modal-title { font-size: 34rpx; font-weight: 700; color: #fff; letter-spacing: 1rpx; }
.modal-close { font-size: 40rpx; color: rgba(255,255,255,0.3); padding: 10rpx; transition: color 0.2s; }
.modal-close:active { color: #ff4757; }
.modal-body { overflow-y: auto; -webkit-overflow-scrolling: touch; padding-right: 4rpx; flex: 1; }

/* 表单组件 */
.form-group { margin-bottom: 32rpx; }
.form-label { font-size: 24rpx; color: rgba(255,255,255,0.4); margin-bottom: 16rpx; font-weight: 600; display: block; text-transform: uppercase; letter-spacing: 1rpx; }
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24rpx; }
.form-hint { font-size: 20rpx; color: rgba(0,200,255,0.4); margin-top: 12rpx; display: block; }

.modal-input { width: 100%; height: 96rpx; line-height: 96rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(255,255,255,0.12); border-radius: 16rpx; padding: 0 24rpx; font-size: 26rpx; color: #fff; box-sizing: border-box; transition: all 0.3s; }
.modal-input:focus { border-color: rgba(0,212,255,0.5); background: rgba(0,0,0,0.5); }

.modal-textarea { width: 100%; height: 240rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(255,255,255,0.12); border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 26rpx; color: #fff; box-sizing: border-box; line-height: 1.6; }
.modal-textarea.mini { height: 160rpx; }
.modal-textarea:focus { border-color: rgba(0,212,255,0.5); background: rgba(0,0,0,0.5); }

.picker-value { width: 100%; height: 96rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(255,255,255,0.12); border-radius: 16rpx; padding: 0 24rpx; font-size: 26rpx; color: #fff; display: flex; align-items: center; justify-content: space-between; box-sizing: border-box; }
.picker-arrow { color: rgba(255,255,255,0.3); font-size: 20rpx; }

/* 图片上传区域 */
.image-upload-box { background: rgba(255,255,255,0.03); border-radius: 20rpx; border: 1rpx solid rgba(255,255,255,0.05); padding: 20rpx; }
.image-upload-actions { display: flex; gap: 20rpx; }
.image-action-card { flex: 1; height: 140rpx; background: rgba(0,212,255,0.06); border: 1rpx dashed rgba(0,212,255,0.2); border-radius: 16rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8rpx; transition: all 0.2s; }
.image-action-card:active { background: rgba(0,212,255,0.12); transform: scale(0.98); }
.image-action-card.mini { height: 100rpx; }
.image-action-card .action-icon { font-size: 40rpx; }
.image-action-card .action-text { font-size: 24rpx; color: rgba(255,255,255,0.8); font-weight: 600; }
.image-action-card .action-text.mini { font-size: 20rpx; }

.selling-image-preview { position: relative; border-radius: 16rpx; overflow: hidden; border: 1rpx solid rgba(0,212,255,0.2); background: #000; }
.selling-image-preview.large { width: 100%; height: 320rpx; }
.preview-img { width: 100%; height: 100%; }
.image-remove-btn { position: absolute; top: 16rpx; right: 16rpx; width: 48rpx; height: 48rpx; background: rgba(255,71,87,0.8); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx; z-index: 10; backdrop-filter: blur(8rpx); }

/* 售卖模式切换 */
.mode-selector { display: flex; background: rgba(0,0,0,0.3); border-radius: 20rpx; padding: 8rpx; margin-bottom: 40rpx; border: 1rpx solid rgba(255,255,255,0.05); }
.mode-tab { flex: 1; height: 80rpx; display: flex; align-items: center; justify-content: center; gap: 12rpx; font-size: 26rpx; color: rgba(255,255,255,0.4); border-radius: 14rpx; transition: all 0.3s; }
.mode-tab.active { background: rgba(0,212,255,0.12); color: #00d4ff; font-weight: 700; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2); }
.mode-icon { font-size: 32rpx; }

/* 底部按钮 */
.modal-footer { display: flex; gap: 24rpx; flex-shrink: 0; padding-top: 40rpx; padding-bottom: calc(20rpx + constant(safe-area-inset-bottom)); padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); }
.modal-footer.flex-column { flex-direction: column; gap: 32rpx; }
.modal-cancel { flex: 1; background: rgba(255, 255, 255, 0.08) !important; color: rgba(255,255,255,0.5) !important; border-radius: 20rpx !important; height: 100rpx !important; font-size: 28rpx !important; border: 1rpx solid rgba(255,255,255,0.1) !important; display: flex !important; align-items: center !important; justify-content: center !important; }
.modal-cancel:active { background: rgba(255, 255, 255, 0.15) !important; }
.modal-delete-btn {
  flex: 1 !important;
  background: rgba(255, 71, 87, 0.08) !important;
  color: #ff4757 !important;
  border-radius: 20rpx !important;
  height: 100rpx !important;
  font-size: 28rpx !important;
  border: 1rpx solid rgba(255, 71, 87, 0.2) !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  font-weight: 600 !important;
}
.modal-delete-btn:active {
  background: rgba(255, 71, 87, 0.15) !important;
  transform: translateY(1rpx);
}
.modal-save { flex: 1.5; background: linear-gradient(135deg, #00b4ff, #0081ff) !important; color: #fff !important; border-radius: 20rpx !important; height: 100rpx !important; font-size: 28rpx !important; font-weight: 700 !important; border: none !important; box-shadow: 0 8rpx 24rpx rgba(0,180,255,0.3) !important; display: flex !important; align-items: center !important; justify-content: center !important; }
.modal-save:active { transform: translateY(2rpx); opacity: 0.9; }
.modal-save[disabled] { opacity: 0.5; background: #333 !important; box-shadow: none !important; }

/* 推送横幅 */
.notify-banner { display: flex; align-items: center; gap: 16rpx; background: rgba(255,171,64,0.1); border: 1rpx solid rgba(255,171,64,0.2); border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 20rpx; }
.notify-icon { font-size: 32rpx; }
.notify-text { font-size: 22rpx; color: #ffab40; font-weight: 500; }

/* 上架按钮行 */
.selling-btn-row { display: flex; gap: 16rpx; width: 100%; }
.selling-main-btn { flex: 1.5 !important; }
.selling-silent-btn { flex: 1 !important; background: rgba(255,255,255,0.08) !important; color: rgba(255,255,255,0.6) !important; border: 1rpx solid rgba(255,255,255,0.12) !important; box-shadow: none !important; }
.selling-silent-btn:active { background: rgba(255,255,255,0.15) !important; }
.selling-hint { font-size: 20rpx; color: rgba(255,255,255,0.3); text-align: center; margin-top: 12rpx; }

/* 列表选择器优化 */
.picker-list-scroll {
  max-height: 60vh;
  padding-right: 10rpx;
  box-sizing: border-box;
}

.picker-card-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 4rpx;
}

.picker-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 20rpx 16rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

.picker-card:active {
  background: rgba(0, 200, 255, 0.08);
  border-color: rgba(0, 200, 255, 0.25);
  transform: scale(0.97);
  box-shadow: 0 0 12rpx rgba(0, 200, 255, 0.1);
}

.picker-card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.picker-badge {
  padding: 3rpx 10rpx;
  border-radius: 5rpx;
  font-size: 16rpx;
  color: #fff;
  font-weight: 700;
}

.picker-card-add {
  width: 38rpx;
  height: 38rpx;
  background: rgba(0, 212, 255, 0.15);
  color: #00d4ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  transition: all 0.2s;
}

.picker-card:active .picker-card-add {
  background: #00d4ff;
  color: #010314;
}

.picker-card-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: left;
}

.picker-card-effect {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  height: 50rpx;
  text-align: left;
}

.picker-card-price {
  font-size: 28rpx;
  font-weight: 800;
  color: #00d4ff;
  font-family: 'DIN Alternate', monospace;
  margin-top: auto;
  text-align: left;
}

/* 批量管理 */
.batch-scroll { margin: 0 -10rpx; padding: 0 10rpx; }
.batch-item { display: flex; align-items: center; justify-content: space-between; padding: 32rpx 20rpx; background: rgba(255,255,255,0.02); border-radius: 16rpx; margin-bottom: 12rpx; border: 1rpx solid rgba(255,255,255,0.05); }
.batch-item:active { background: rgba(0,212,255,0.06); border-color: rgba(0,212,255,0.2); }
.batch-item-right { display: flex; align-items: center; gap: 20rpx; }
.batch-item-price { font-size: 26rpx; color: rgba(255,255,255,0.5); font-weight: 600; }
.batch-arrow { font-size: 32rpx; color: rgba(255,255,255,0.2); }
.batch-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}
.batch-item-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.batch-checkbox {
  width: 38rpx;
  height: 38rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: rgba(0, 0, 0, 0.15);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  flex-shrink: 0;
}
.batch-checkbox.checked {
  border-color: #00d4ff;
  background: rgba(0, 212, 255, 0.15);
  box-shadow: 0 0 10rpx rgba(0, 212, 255, 0.3);
}
.checkbox-icon {
  font-size: 24rpx;
  color: #00d4ff;
  font-weight: bold;
  line-height: 1;
}


/* 计数按钮 */
.counter-btn { width: 56rpx; height: 56rpx; background: rgba(0,200,255,0.1); border: 1rpx solid rgba(0,200,255,0.2); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; transition: all 0.25s cubic-bezier(0.16,1,0.3,1); box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); }
.counter-btn:active { transform: scale(0.88); background: rgba(0,200,255,0.18); }
.counter-plus { font-size: 36rpx; color: #00d4ff; font-weight: 300; line-height: 1; }
.counter-badge { min-width: 40rpx; height: 40rpx; background: rgba(0,180,255,0.15); border-radius: 20rpx; display: flex; align-items: center; justify-content: center; padding: 0 10rpx; border: 1rpx solid rgba(0,200,255,0.2); }
.counter-num { font-size: 22rpx; color: #00d4ff; font-weight: 700; }

/* 在售商品卡片式上架管理样式 */
.selling-edit-scroll {
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
  padding: 16rpx;
}
.selling-edit-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}
.selling-edit-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 16rpx 12rpx;
  position: relative;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.selling-preview-card-wrap {
  position: relative;
  margin-bottom: 12rpx;
  padding: 8rpx;
  background: rgba(0, 0, 0, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  border-radius: 20rpx;
}
.preview-tag {
  position: absolute;
  top: -12rpx;
  left: 14rpx;
  font-size: 14rpx;
  font-weight: 700;
  color: #00d4ff;
  background: #101430;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  border: 1rpx solid rgba(0, 212, 255, 0.25);
