/* 远行商人 Liquid Glass */
.page { min-height: 100vh; background-color: #010314; background-image: radial-gradient(ellipse 60% 40% at 60% 30%, rgba(200,100,50,0.06) 0%, transparent 50%), linear-gradient(185deg, #020410 0%, #040c24 100%); animation: pageExpand 0.5s cubic-bezier(0.22, 0.61, 0.36, 1); padding-bottom: 180rpx; }
@keyframes pageExpand { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }

/* 基础卡片 */
.card { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 24rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.03) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 4rpx 16rpx rgba(0,0,0,0.12); }

.card-title { font-size: 26rpx; font-weight: 700; color: #00d4ff; margin-bottom: 20rpx; padding-left: 16rpx; border-left: 3rpx solid rgba(0,200,255,0.3); letter-spacing: 1rpx; }

/* 出差提示 */
.merchant-tip { text-align: center; padding: 20rpx 0; }
.tip-icon { font-size: 64rpx; display: block; margin-bottom: 16rpx; }
.tip-title { font-size: 28rpx; font-weight: 700; color: #fff; }
.tip-desc { font-size: 24rpx; color: rgba(255,255,255,0.6); }
.tip-hint { font-size: 20rpx; color: rgba(0,200,255,0.5); margin-top: 8rpx; display: block; }
.edit-btn { font-size: 22rpx; padding: 4rpx 10rpx; background: rgba(0,200,255,0.1); border: 1rpx solid rgba(0,200,255,0.15); border-radius: 8rpx; color: #00d4ff; text-align: center; }
.dev-edit-btn { display: flex; align-items: center; gap: 4rpx; padding: 6rpx 14rpx; background: rgba(255,71,87,0.08); border: 1rpx solid rgba(255,71,87,0.15); border-radius: 8rpx; color: #ff4757; font-size: 22rpx; }
.dev-add-btn { display: flex; align-items: center; gap: 4rpx; padding: 6rpx 14rpx; background: rgba(0,255,115,0.06); border: 1rpx solid rgba(0,255,115,0.15); border-radius: 8rpx; color: #00ff73; font-size: 22rpx; }

/* 管理员面板 */
.admin-panel { border-color: rgba(255,171,64,0.15); background: rgba(255,140,30,0.03); }
.admin-panel-title { display: flex; align-items: center; gap: 10rpx; margin-bottom: 16rpx; padding-bottom: 14rpx; border-bottom: 1rpx solid rgba(255,140,30,0.1); }
.admin-panel-text { font-size: 26rpx; font-weight: 700; color: #ffab40; }
.admin-control-row { display: flex; align-items: center; justify-content: space-between; padding: 14rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.04); }
.admin-control-row:last-child { border-bottom: none; }
.admin-control-name { font-size: 24rpx; color: rgba(255,255,255,0.8); font-weight: 600; display: block; }
.admin-control-desc { font-size: 20rpx; color: rgba(255,255,255,0.35); display: block; margin-top: 2rpx; }

.toggle { width: 88rpx; height: 48rpx; background: rgba(255,255,255,0.08); border-radius: 24rpx; padding: 4rpx; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); border: 1rpx solid rgba(255,255,255,0.06); }
.toggle.on { background: rgba(0,200,255,0.2); border-color: rgba(0,200,255,0.25); }
.toggle-dot { width: 40rpx; height: 40rpx; background: #fff; border-radius: 50%; transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1); box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.2); }
.toggle.on .toggle-dot { transform: translateX(40rpx); }

/* 正在售卖 */
.selling-card { border-color: rgba(255,71,87,0.12); background: rgba(255,40,60,0.03); }
.card-title-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.card-title-left { display: flex; align-items: center; gap: 16rpx; }
.selling-btns { display: flex; gap: 8rpx; }

/* 文字轮播 */
.selling-marquee-wrap { margin-top: 4rpx; }
.selling-marquee { overflow: hidden; padding: 8rpx 0; margin-bottom: 12rpx; }
.selling-marquee-track { display: flex; gap: 40rpx; white-space: nowrap; animation: marqueeScroll linear infinite; }
.selling-marquee-item { font-size: 24rpx; color: #ffab40; font-weight: 600; flex-shrink: 0; }
@keyframes marqueeScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

/* --- 物品卡片优化 --- */
.item-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10rpx; }
.item-card { background: rgba(255,255,255,0.03); border: 1rpx solid rgba(255,255,255,0.06); border-radius: 18rpx; padding: 18rpx 16rpx; position: relative; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.02) inset, 0 1rpx 0 rgba(255,255,255,0.03) inset; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); opacity: 0; animation: cardEnter 0.4s cubic-bezier(0.22,0.61,0.36,1) forwards; }
.item-card:nth-child(1) { animation-delay: 0s; }
.item-card:nth-child(2) { animation-delay: 0.04s; }
.item-card:nth-child(3) { animation-delay: 0.08s; }
.item-card:nth-child(4) { animation-delay: 0.12s; }
.item-card:nth-child(5) { animation-delay: 0.16s; }
.item-card:nth-child(6) { animation-delay: 0.2s; }
@keyframes cardEnter { from { opacity: 0; transform: translateY(12rpx) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }

.item-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; min-height: 36rpx; }
.item-badge { padding: 3rpx 10rpx; border-radius: 5rpx; font-size: 18rpx; color: #fff; font-weight: 700; }
.badge-normal { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.7); }
.badge-rare { background: rgba(0,200,255,0.2); color: #00d4ff; }
.badge-epic { background: rgba(153,69,255,0.2); color: #9945ff; }
.badge-legend { background: rgba(255,171,64,0.2); color: #ffab40; }

.item-name { font-size: 26rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 6rpx; line-height: 1.3; }
.item-price { font-size: 28rpx; font-weight: 800; color: #00d4ff; display: block; margin: 6rpx 0; font-family: 'DIN Alternate', monospace; }
.item-effect { font-size: 20rpx; color: rgba(255,255,255,0.5); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

.item-sub-btn { width: 36rpx; height: 36rpx; background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.25s cubic-bezier(0.16,1,0.3,1); }
.item-sub-btn.on { background: rgba(0,200,255,0.12); border-color: rgba(0,200,255,0.3); }
.item-sub-icon { font-size: 20rpx; color: rgba(255,255,255,0.4); }
.item-sub-btn.on .item-sub-icon { color: #00d4ff; }
.item-sub-btn:active { transform: scale(0.85); }

.item-delete { position: absolute; top: 10rpx; left: 10rpx; width: 32rpx; height: 32rpx; background: rgba(255,71,87,0.7); color: #fff; font-size: 18rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; z-index: 2; }

/* 售卖物品 */
.selling-items { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10rpx; }
.selling-item { border-color: rgba(255,71,87,0.1); }
.selling-empty { text-align: center; padding: 32rpx 0; }
.selling-empty-text { font-size: 24rpx; color: rgba(255,255,255,0.35); }

/* 新品上架 */
.new-items-card { border-color: rgba(255,171,64,0.15); background: rgba(255,140,30,0.03); overflow: hidden; }
.new-items-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.new-items-label { display: flex; align-items: center; gap: 10rpx; }
.new-items-tag { padding: 3rpx 12rpx; background: rgba(255,171,64,0.2); border-radius: 5rpx; font-size: 16rpx; font-weight: 800; color: #ffab40; letter-spacing: 2rpx; animation: tagPulse 2s ease-in-out infinite; }
@keyframes tagPulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }
.new-items-title { font-size: 26rpx; font-weight: 700; color: #ffab40; }
.new-items-count { font-size: 20rpx; color: rgba(255,171,64,0.6); }
.new-items-marquee { overflow: hidden; margin: 0 -28rpx; padding: 0 28rpx; }
.new-items-track { display: flex; gap: 14rpx; transition: transform 0.5s cubic-bezier(0.25,0.46,0.45,0.94); }
.new-item-card { min-width: 200rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,171,64,0.12); border-radius: 16rpx; padding: 18rpx 16rpx; position: relative; flex-shrink: 0; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.02) inset; }
.new-item-card::before { content: ''; position: absolute; top: 0; left: 12rpx; right: 12rpx; height: 1rpx; background: linear-gradient(90deg, transparent, rgba(255,171,64,0.3), transparent); }
.new-item-badge { display: inline-block; padding: 2rpx 8rpx; border-radius: 4rpx; font-size: 16rpx; color: #fff; font-weight: 700; margin-bottom: 8rpx; }
.new-item-name { font-size: 24rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 6rpx; }
.new-item-price { font-size: 24rpx; color: #ffab40; font-weight: 700; display: block; font-family: 'DIN Alternate', monospace; }
.new-items-dots { display: flex; justify-content: center; gap: 8rpx; margin-top: 14rpx; }
.dot { width: 8rpx; height: 8rpx; border-radius: 50%; background: rgba(255,255,255,0.15); transition: all 0.3s; }
.dot.active { background: #ffab40; width: 20rpx; border-radius: 4rpx; }

/* 订阅 */
.sub-badge { display: flex; align-items: center; gap: 6rpx; padding: 6rpx 14rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 20rpx; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); }
.sub-badge.on { background: rgba(0,200,255,0.1); border-color: rgba(0,200,255,0.25); box-shadow: 0 0 12rpx rgba(0,200,255,0.08); }
.sub-badge-icon { font-size: 22rpx; }
.sub-badge-text { font-size: 20rpx; color: rgba(255,255,255,0.6); font-weight: 500; }
.sub-badge.on .sub-badge-text { color: #00d4ff; }
.sub-badge-count { font-size: 16rpx; background: rgba(0,200,255,0.2); color: #00d4ff; padding: 0 8rpx; border-radius: 8rpx; font-weight: 700; }

.subscribe-row { display: flex; align-items: center; justify-content: space-between; }
.subscribe-info { flex: 1; }
.subscribe-title { font-size: 26rpx; font-weight: 600; color: #fff; display: block; }
.subscribe-desc { font-size: 20rpx; color: rgba(255,255,255,0.45); display: block; margin-top: 4rpx; }

/* 编辑提示 */
.admin-edit-hint { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 16rpx; background: rgba(0,200,255,0.04); border: 1rpx dashed rgba(0,200,255,0.15); border-radius: 10rpx; margin-bottom: 16rpx; }
.edit-hint-icon { font-size: 24rpx; }
.edit-hint-text { font-size: 20rpx; color: rgba(0,200,255,0.6); }

.source { font-size: 20rpx; color: rgba(255,255,255,0.3); display: block; margin-top: 8rpx; line-height: 1.5; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,2,12,0.75); backdrop-filter: blur(16rpx); z-index: 1000; display: flex; align-items: flex-end; animation: modalFadeIn 0.35s cubic-bezier(0.32,0.72,0,1); }
.modal-box { width: 100%; background: rgba(16,20,48,0.92); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 36rpx 36rpx 0 0; padding: 32rpx; max-height: 80vh; display: flex; flex-direction: column; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 -8rpx 40rpx rgba(0,0,0,0.3); }
@keyframes modalFadeIn { from { opacity: 0; transform: translateY(20rpx); } to { opacity: 1; transform: translateY(0); } }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; flex-shrink: 0; }
.modal-title { font-size: 30rpx; font-weight: 700; color: #00d4ff; }
.modal-close { font-size: 40rpx; color: rgba(255,255,255,0.4); padding: 8rpx; }
.modal-body { overflow-y: auto; flex: 1; }
.modal-input { width: 100%; min-height: 80rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 12rpx; padding: 20rpx; font-size: 26rpx; color: #fff; box-sizing: border-box; margin-bottom: 20rpx; }
.modal-textarea { width: 100%; height: 350rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 12rpx; padding: 20rpx; font-size: 26rpx; color: #fff; box-sizing: border-box; margin-bottom: 20rpx; }
.modal-footer { display: flex; gap: 16rpx; flex-shrink: 0; padding-top: 16rpx; align-items: center; }
.modal-cancel { flex: 1; background: rgba(255, 255, 255, 0.08) !important; color: rgba(255,255,255,0.7) !important; border-radius: 16rpx !important; height: 80rpx !important; font-size: 26rpx !important; border: 1rpx solid rgba(255,255,255,0.08) !important; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.modal-cancel::after { border: none; }
.modal-save { flex: 1; background: rgba(0, 200, 255, 0.12) !important; color: #00d4ff !important; border-radius: 16rpx !important; height: 80rpx !important; font-size: 26rpx !important; border: 1rpx solid rgba(0, 200, 255, 0.2) !important; box-shadow: 0 0 0 1rpx rgba(0,200,255,0.05) inset, 0 1rpx 0 rgba(150,220,255,0.05) inset; display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.modal-save::after { border: none; }
.modal-save[disabled] { opacity: 0.5; }

.form-group { margin-bottom: 20rpx; }
.form-label { font-size: 24rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 8rpx; }
.picker-value { width: 100%; min-height: 80rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 12rpx; padding: 20rpx; font-size: 26rpx; color: #fff; box-sizing: border-box; line-height: 1.4; }

.selling-mode-tabs { display: flex; gap: 10rpx; margin-bottom: 20rpx; background: rgba(255,255,255,0.03); padding: 4rpx; border-radius: 14rpx; border: 1rpx solid rgba(255,255,255,0.06); }
.selling-mode-tab { flex: 1; display: flex; align-items: center; justify-content: center; gap: 8rpx; padding: 16rpx 0; border-radius: 10rpx; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); }
.selling-mode-tab.on { background: rgba(0,200,255,0.1); }
.mode-tab-icon { font-size: 26rpx; }
.mode-tab-text { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.selling-mode-tab.on .mode-tab-text { color: #00d4ff; }
.selling-tip { font-size: 20rpx; color: rgba(255,171,64,0.6); margin-bottom: 14rpx; padding: 10rpx 14rpx; background: rgba(255,171,64,0.05); border: 1rpx solid rgba(255,171,64,0.1); border-radius: 8rpx; }
.selling-textarea { height: 400rpx; }
.notify-hint { font-size: 20rpx; color: rgba(255,171,64,0.5); }

/* 图片模式 */
.selling-image-wrap { margin-top: 4rpx; }
.selling-image { width: 100%; border-radius: 12rpx; display: block; }
.selling-image-preview { position: relative; width: 200rpx; height: 200rpx; border-radius: 12rpx; overflow: hidden; border: 1rpx solid rgba(255,255,255,0.1); margin-bottom: 16rpx; }
.image-remove-btn { position: absolute; top: 8rpx; right: 8rpx; width: 36rpx; height: 36rpx; background: rgba(255,71,87,0.85); color: #fff; font-size: 20rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.selling-image-actions { display: flex; gap: 12rpx; margin-bottom: 14rpx; }
.image-action-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 160rpx; height: 110rpx; background: rgba(255,255,255,0.03); border: 1rpx dashed rgba(255,255,255,0.12); border-radius: 12rpx; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); }
.image-action-btn:active { background: rgba(0,200,255,0.06); }
.action-icon { font-size: 34rpx; margin-bottom: 6rpx; }
.action-text { font-size: 22rpx; color: rgba(255,255,255,0.45); }

/* 选择器 */
.picker-list { max-height: 500rpx; overflow-y: auto; }
.picker-item { display: flex; align-items: center; justify-content: space-between; padding: 14rpx 12rpx; border-bottom: 1rpx solid rgba(255,255,255,0.04); transition: background 0.2s; }
.picker-item:last-child { border: none; }
.picker-item:active { background: rgba(0,200,255,0.05); }
.picker-item-left { display: flex; align-items: center; gap: 12rpx; flex: 1; min-width: 0; }
.picker-badge { padding: 2rpx 10rpx; border-radius: 5rpx; font-size: 16rpx; color: #fff; font-weight: 600; flex-shrink: 0; }
.picker-item-name { font-size: 26rpx; color: #fff; font-weight: 600; display: block; }
.picker-item-effect { font-size: 20rpx; color: rgba(255,255,255,0.4); display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.picker-item-price { font-size: 24rpx; color: #00d4ff; font-weight: 700; flex-shrink: 0; margin-left: 12rpx; font-family: 'DIN Alternate', monospace; }

/* 计数按钮 */
.counter-btn { width: 56rpx; height: 56rpx; background: rgba(0,200,255,0.1); border: 1rpx solid rgba(0,200,255,0.2); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; transition: all 0.25s cubic-bezier(0.16,1,0.3,1); box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); }
.counter-btn:active { transform: scale(0.88); background: rgba(0,200,255,0.18); }
.counter-plus { font-size: 36rpx; color: #00d4ff; font-weight: 300; line-height: 1; }
.counter-badge { min-width: 40rpx; height: 40rpx; background: rgba(0,180,255,0.15); border-radius: 20rpx; display: flex; align-items: center; justify-content: center; padding: 0 10rpx; border: 1rpx solid rgba(0,200,255,0.2); }
.counter-num { font-size: 22rpx; color: #00d4ff; font-weight: 700; }
