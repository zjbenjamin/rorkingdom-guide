}
.selling-preview-card-wrap .item-card {
  opacity: 1 !important;
  animation: none !important;
  margin-bottom: 0 !important;
  box-shadow: none !important;
  border-color: rgba(255, 171, 64, 0.2) !important;
  background: transparent !important;
  padding: 10rpx 8rpx !important;
}
.item-image-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin: 0 auto 12rpx auto;
  background: rgba(255, 255, 255, 0.02);
  border: 1rpx dashed rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.item-image-placeholder .placeholder-icon {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.3);
  font-weight: 600;
}
.selling-edit-card-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  width: 100%;
}
.image-action-btn-mini {
  width: 100%;
  height: 52rpx;
  background: rgba(0, 212, 255, 0.1);
  border: 1rpx solid rgba(0, 212, 255, 0.25);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  flex-shrink: 0;
