/* 攻略页科技感样式 */
.dev-card { background: linear-gradient(145deg, rgba(20,25,60,0.9), rgba(15,18,45,0.95)); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 20rpx; padding: 32rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 600rpx; }
.dev-icon { font-size: 88rpx; margin-bottom: 28rpx; }
.dev-title { font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 16rpx; }
.dev-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); margin-bottom: 16rpx; text-align: center; }
.dev-tip { font-size: 22rpx; color: rgba(0,212,255,0.5); }
