/* 道具图鉴科技感样式 */
.search-box { display: flex; align-items: center; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 40rpx; padding: 16rpx 24rpx; margin-bottom: 16rpx; }
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; color: #00d4ff; }
.search-input::placeholder { color: rgba(0,212,255,0.3); }
.types { white-space: nowrap; margin-bottom: 16rpx; }
.type-tag { display: inline-block; padding: 10rpx 24rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 28rpx; font-size: 22rpx; color: rgba(255,255,255,0.5); margin-right: 12rpx; }
.type-tag.on { background: linear-gradient(135deg, rgba(0,212,255,0.3), rgba(153,69,255,0.3)); border-color: #00d4ff; color: #00d4ff; font-weight: 600; box-shadow: 0 0 12px rgba(0,212,255,0.2); }
.item-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12rpx; }
.item-card { background: linear-gradient(145deg, rgba(20,25,60,0.9), rgba(15,18,45,0.95)); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 14rpx; padding: 20rpx; position: relative; }
.item-badge { position: absolute; top: 10rpx; right: 10rpx; padding: 3rpx 10rpx; border-radius: 6rpx; font-size: 16rpx; color: #fff; font-weight: 600; }
.badge-normal { background: rgba(255,255,255,0.2); }
.badge-rare { background: linear-gradient(135deg, #00d4ff, #0099cc); }
.badge-epic { background: linear-gradient(135deg, #9945ff, #7c3aed); }
.badge-legend { background: linear-gradient(135deg, #ffab40, #ff9100); }
.item-name { font-size: 26rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 8rpx; }
.item-desc { font-size: 20rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 6rpx; }
.item-cat { font-size: 18rpx; color: rgba(0,212,255,0.5); }
.empty { text-align: center; color: rgba(255,255,255,0.5); font-size: 24rpx; padding: 32rpx 0; }
.source { text-align: center; font-size: 18rpx; color: rgba(0,212,255,0.3); padding: 20rpx 0; }
