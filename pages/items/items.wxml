<view class="page">
  <view class="container">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索道具名称" value="{{search}}" bindinput="onSearch" />
    </view>
    <scroll-view scroll-x class="types">
      <view class="type-tag {{category===item?'on':''}}" wx:for="{{categories}}" wx:key="*this" bindtap="onCategory" data-c="{{item}}">{{item}}</view>
    </scroll-view>
    <view class="item-grid">
      <view class="item-card" wx:for="{{filtered}}" wx:key="id" bindtap="goDetail" data-item="{{item}}">
        <view class="item-badge badge-{{item.rarity==='普通'?'normal':item.rarity==='稀有'?'rare':item.rarity==='史诗'?'epic':'legend'}}">{{item.rarity}}</view>
        <image class="item-img" wx:if="{{item.imgUrl}}" src="{{item.imgUrl}}" mode="aspectFill" lazy-load binderror="onImgError" data-idx="{{index}}" />
        <view class="item-img-fallback" wx:else><text class="item-emoji">{{item.emoji}}</text></view>
        <text class="item-name">{{item.name}}</text>
        <text class="item-desc">{{item.desc}}</text>
      </view>
    </view>
    <view class="empty" wx:if="{{filtered.length===0}}">没有找到匹配的道具</view>
    <view class="source">数据来源：洛克王国手游WIKI（CC BY-NC-SA 4.0）https://wiki.biligame.com/rocom/</view>
  </view>
  <view class="navbar">
    <view class="nav-item" bindtap="go" data-url="/pages/index/index"><text class="nav-icon">🏠</text><text class="nav-text">首页</text></view>
    <view class="nav-item" wx:if="{{showCommunity}}" bindtap="go" data-url="/pages/community/community"><text class="nav-icon">👥</text><text class="nav-text">社区</text></view>
    <view class="nav-item" bindtap="go" data-url="/pages/activity/activity"><text class="nav-icon">📅</text><text class="nav-text">活动</text></view>
    <view class="nav-item" bindtap="go" data-url="/pages/login/login"><text class="nav-icon">👤</text><text class="nav-text">我的</text></view>
  </view>
</view>
