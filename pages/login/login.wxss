page { background: #010314; }
.page { min-height: 100vh; padding-top: 88rpx; padding-bottom: 180rpx; background-color: #010314; background-image: radial-gradient(ellipse 80% 50% at 30% 10%, rgba(0,180,255,0.1) 0%, transparent 60%), radial-gradient(ellipse 60% 40% at 70% 60%, rgba(100,60,255,0.06) 0%, transparent 50%), linear-gradient(185deg, #020410 0%, #040c24 100%); animation: pageExpand 0.55s cubic-bezier(0.22, 0.61, 0.36, 1); }
@keyframes pageExpand { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
.container { padding: 24rpx; }

.login-header { text-align: center; padding: 80rpx 0 48rpx; }
.logo-box { width: 140rpx; height: 140rpx; background: rgba(0, 200, 255, 0.06); border: 1rpx solid rgba(255, 255, 255, 0.1); border-radius: 36rpx; display: flex; align-items: center; justify-content: center; margin: 0 auto 20rpx; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.05) inset, 0 0 40rpx rgba(0,180,255,0.15); }
.logo-image { width: 100%; height: 100%; border-radius: 36rpx; }
.app-name { font-size: 44rpx; font-weight: 700; color: #fff; display: block; text-shadow: 0 0 16px rgba(0,212,255,0.4); }
.app-desc { font-size: 24rpx; color: rgba(0,212,255,0.6); display: block; margin-top: 8rpx; }

.login-card { background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(255, 255, 255, 0.08); border-radius: 28rpx; padding: 40rpx 32rpx; margin-bottom: 20rpx; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 8rpx 32rpx rgba(0,0,0,0.2); }
.login-tips { text-align: center; margin-bottom: 40rpx; }
.tips-title { font-size: 32rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 12rpx; }
.tips-desc { font-size: 24rpx; color: rgba(255,255,255,0.5); display: block; }

.avatar-section { text-align: center; margin-bottom: 32rpx; }
.avatar-btn { background: transparent !important; border: none !important; padding: 0 !important; margin: 0 auto !important; line-height: normal !important; display: block !important; width: fit-content !important; }
.avatar-btn::after { border: none; }
.avatar-wrap { width: 160rpx; height: 160rpx; border-radius: 50%; overflow: hidden; margin: 0 auto; border: 3rpx solid rgba(255, 255, 255, 0.1); background: rgba(255, 255, 255, 0.04); position: relative; }
.avatar-wrap::after { content: ''; position: absolute; inset: -6rpx; border-radius: 50%; background: conic-gradient(from 0deg, transparent, rgba(0,200,255,0.3), rgba(120,60,240,0.3), transparent); animation: avatarRing 3s linear infinite; pointer-events: none; }
@keyframes avatarRing { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
.avatar-img { width: 100%; height: 100%; position: relative; z-index: 1; }
.avatar-empty { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; position: relative; z-index: 1; }
.avatar-plus { font-size: 56rpx; color: rgba(0,212,255,0.5); }
.avatar-hint { font-size: 24rpx; color: rgba(0,212,255,0.5); display: block; margin-top: 12rpx; }

.form-section { margin-bottom: 28rpx; }
.form-item { display: flex; align-items: center; padding: 20rpx 24rpx; background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(255, 255, 255, 0.08); border-radius: 14rpx; margin-bottom: 16rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.03); }
.form-label { font-size: 26rpx; color: rgba(255,255,255,0.5); width: 100rpx; flex-shrink: 0; }
.form-input { flex: 1; min-height: 48rpx; font-size: 28rpx; color: #fff; }

.submit-btn { width: 100% !important; height: 88rpx !important; background: rgba(0, 200, 255, 0.12) !important; color: #00d4ff !important; border-radius: 44rpx !important; font-size: 30rpx !important; font-weight: 600 !important; border: 1rpx solid rgba(0, 200, 255, 0.2) !important; box-shadow: 0 0 0 1rpx rgba(0,200,255,0.05) inset, 0 1rpx 0 rgba(150,220,255,0.05) inset, 0 4px 20px rgba(0,120,255,0.08) !important; margin-bottom: 20rpx !important; display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.submit-btn::after { border: none; }
.submit-btn[disabled] { opacity: 0.5; }

.agree-section { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; font-size: 22rpx; color: rgba(255,255,255,0.45); margin-top: 16rpx; gap: 4rpx; }
.agree-checkbox-group { display: inline-block; }
.agree-label { display: flex; align-items: center; }
.agree-checkbox { transform: scale(0.65); margin-right: -4rpx; }
.agree-text-span { font-size: 22rpx; color: rgba(255,255,255,0.45); }
.agree-section .link { color: #00d4ff; font-weight: 500; }

.user-card { background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(255, 255, 255, 0.08); border-radius: 28rpx; padding: 32rpx; margin-bottom: 20rpx; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 8rpx 32rpx rgba(0,0,0,0.2); }
.user-header { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.user-card .avatar-wrap { width: 100rpx; height: 100rpx; position: relative; flex-shrink: 0; }
.user-avatar { width: 100rpx; height: 100rpx; border-radius: 50%; border: 3rpx solid rgba(255, 255, 255, 0.12); }
.level-tag { position: absolute; bottom: -4rpx; left: 50%; transform: translateX(-50%); font-size: 18rpx; font-weight: 700; padding: 4rpx 14rpx; border-radius: 12rpx; white-space: nowrap; border: 1rpx solid; display: flex; align-items: center; gap: 4rpx; }
.level-icon { font-size: 16rpx; }
.level-num { font-size: 18rpx; }
.user-title-text { font-size: 22rpx; font-weight: 600; display: block; margin-bottom: 6rpx; }
.user-detail { flex: 1; }
.user-name { font-size: 30rpx; font-weight: 700; color: #fff; }
.user-name-row { display: flex; align-items: center; gap: 10rpx; margin-bottom: 8rpx; }
.role-tag { padding: 2rpx 10rpx; border-radius: 6rpx; font-size: 18rpx; font-weight: 600; position: relative; overflow: hidden; }
.role-tag.editor { background: rgba(0,212,255,0.1); color: #00d4ff; border: 1rpx solid rgba(0,212,255,0.2); }
.role-tag.developer { background: rgba(255,171,64,0.1); color: #ffab40; border: 1rpx solid rgba(255,171,64,0.2); }
.user-exp { font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 12rpx; }
.exp-bar { width: 100%; height: 8rpx; background: rgba(255, 255, 255, 0.05); border-radius: 4rpx; overflow: hidden; }
.exp-fill { height: 100%; background: linear-gradient(90deg, #00d4ff, #9945ff); border-radius: 4rpx; }

.expire-bar { background: rgba(255, 171, 64, 0.05); border: 1rpx solid rgba(255, 171, 64, 0.12); border-radius: 14rpx; padding: 16rpx 20rpx; margin-bottom: 20rpx; font-size: 24rpx; color: #ffab40; box-shadow: inset 0 1rpx 0 rgba(255,200,100,0.04); }

.stat-grid { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.stat-box { flex: 1; text-align: center; background: rgba(255, 255, 255, 0.03); border: 1rpx solid rgba(255, 255, 255, 0.06); border-radius: 16rpx; padding: 20rpx 0; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.03); }
.stat-num { font-size: 32rpx; font-weight: 700; color: #00d4ff; display: block; text-shadow: 0 0 8px rgba(0,212,255,0.5); }
.stat-name { font-size: 22rpx; color: rgba(255,255,255,0.4); display: block; margin-top: 8rpx; }

.notify-section { background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(255, 255, 255, 0.08); border-radius: 28rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 8rpx 32rpx rgba(0,0,0,0.2); }
.notify-title { display: flex; align-items: center; gap: 10rpx; margin-bottom: 24rpx; flex-wrap: wrap; }
.notify-title-icon { font-size: 32rpx; }
.notify-title-text { font-size: 30rpx; font-weight: 700; color: #00d4ff; letter-spacing: 1rpx; }
.notify-title-hint { font-size: 20rpx; color: rgba(255,255,255,0.35); width: 100%; margin-top: 8rpx; padding-left: 42rpx; }
.notify-item { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 0; border-bottom: 1rpx solid rgba(255, 255, 255, 0.04); }
.notify-item:last-of-type { border-bottom: none; }
.notify-info { flex: 1; }
.notify-name { font-size: 28rpx; color: rgba(255,255,255,0.9); display: block; margin-bottom: 6rpx; font-weight: 500; }
.notify-desc { font-size: 22rpx; color: rgba(255,255,255,0.35); display: block; }
.notify-right { flex-shrink: 0; display: flex; align-items: center; gap: 12rpx; }
.notify-counter { display: flex; align-items: center; gap: 12rpx; }
.notify-reset { font-size: 20rpx; color: rgba(255,71,87,0.8); padding: 8rpx 16rpx; background: rgba(255,71,87,0.06); border: 1rpx solid rgba(255,71,87,0.15); border-radius: 8rpx; }
.counter-btn { width: 56rpx; height: 56rpx; background: rgba(0, 200, 255, 0.1); border: 1rpx solid rgba(0, 200, 255, 0.2); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; transition: all 0.2s; position: relative; overflow: hidden; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); }
.counter-btn:active { transform: scale(0.92); background: rgba(0, 200, 255, 0.18); }
.counter-plus { font-size: 36rpx; color: #00d4ff; font-weight: 300; line-height: 1; }
.counter-badge { min-width: 40rpx; height: 40rpx; background: rgba(0, 180, 255, 0.15); border-radius: 20rpx; display: flex; align-items: center; justify-content: center; padding: 0 10rpx; border: 1rpx solid rgba(0, 200, 255, 0.2); }
.counter-num { font-size: 22rpx; color: #00d4ff; font-weight: 700; }
.notify-na { font-size: 20rpx; color: rgba(255,255,255,0.4); background: rgba(255, 255, 255, 0.03); padding: 10rpx 20rpx; border-radius: 12rpx; border: 1rpx solid rgba(255, 255, 255, 0.06); }
.notify-tip { text-align: center; padding-top: 16rpx; }
.notify-tip-text { font-size: 22rpx; color: rgba(0,212,255,0.5); text-decoration: underline; }

.action-list { border-top: 1rpx solid rgba(255, 255, 255, 0.06); padding-top: 8rpx; }
.action-item { display: flex; align-items: center; padding: 20rpx 16rpx; border-radius: 16rpx; margin-bottom: 8rpx; background: rgba(255, 255, 255, 0.03); border: 1rpx solid rgba(255, 255, 255, 0.06); box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.03); }
.action-item:active { background: rgba(0, 200, 255, 0.08); }
.admin-item { background: rgba(120, 60, 240, 0.05); border-color: rgba(120, 60, 240, 0.12); }
.action-icon-wrap { width: 56rpx; height: 56rpx; border-radius: 14rpx; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; }
.admin-icon-wrap { background: rgba(120, 60, 240, 0.08); border: 1rpx solid rgba(120, 60, 240, 0.15); }
.danger-icon-wrap { background: rgba(255,71,87,0.06); border: 1rpx solid rgba(255,71,87,0.15); }
.action-icon { font-size: 28rpx; }
.action-text { flex: 1; font-size: 28rpx; color: rgba(255,255,255,0.7); font-weight: 500; }
.danger-text { color: #ff4757; }
.action-arrow { font-size: 28rpx; color: rgba(255,255,255,0.5); }

.feature-grid { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.feature-box { flex: 1; background: rgba(255, 255, 255, 0.03); border: 1rpx solid rgba(255, 255, 255, 0.06); border-radius: 20rpx; padding: 24rpx 8rpx; text-align: center; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.02) inset, 0 1rpx 0 rgba(255,255,255,0.03) inset; }
.feature-emoji { font-size: 44rpx; display: block; margin-bottom: 8rpx; }
.feature-title { font-size: 24rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 4rpx; }
.feature-desc { font-size: 20rpx; color: rgba(255,255,255,0.4); display: block; }

.notice-box { background: rgba(255, 255, 255, 0.03); border: 1rpx solid rgba(255, 255, 255, 0.06); border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.03); }
.notice-title { font-size: 26rpx; font-weight: 600; color: #00d4ff; display: block; margin-bottom: 12rpx; }
.notice-text { font-size: 24rpx; color: rgba(255,255,255,0.5); display: block; line-height: 2; }

.version { text-align: center; font-size: 22rpx; color: rgba(0,212,255,0.3); display: block; padding: 24rpx 0; }

.uid-card { display: flex; align-items: center; justify-content: space-between; background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(255, 255, 255, 0.08); border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 20rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); }
.uid-left { flex: 1; }
.uid-label { font-size: 24rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 4rpx; }
.uid-value { font-size: 32rpx; font-weight: 700; color: #00d4ff; display: block; }
.uid-empty { font-size: 24rpx; color: rgba(255,255,255,0.5); display: block; text-align: center; }
.uid-arrow { font-size: 32rpx; color: rgba(255,255,255,0.5); }

.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 2, 12, 0.75); backdrop-filter: blur(16rpx); z-index: 1000; display: flex; align-items: center; justify-content: center; }
.modal-box { width: 82%; background: rgba(16, 20, 48, 0.92); border: 1rpx solid rgba(255, 255, 255, 0.1); border-radius: 36rpx; padding: 32rpx; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 0 80rpx rgba(0,120,255,0.1), 0 24rpx 60rpx rgba(0,0,0,0.4); }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.modal-title { font-size: 30rpx; font-weight: 700; color: #00d4ff; }
.modal-close { font-size: 36rpx; color: rgba(255,255,255,0.4); padding: 8rpx; }
.modal-body { margin-bottom: 24rpx; }
.modal-input { width: 100%; min-height: 80rpx; background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(255, 255, 255, 0.08); border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; }
.modal-hint { font-size: 22rpx; color: rgba(255,255,255,0.4); display: block; margin-top: 12rpx; }
.modal-footer { display: flex; gap: 16rpx; }
.modal-cancel { flex: 1; background: rgba(255, 255, 255, 0.08) !important; color: rgba(255,255,255,0.7) !important; border-radius: 16rpx !important; height: 80rpx !important; font-size: 26rpx !important; border: 1rpx solid rgba(255,255,255,0.08) !important; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.modal-cancel::after { border: none; }
.modal-save { flex: 1; background: rgba(0, 200, 255, 0.12) !important; color: #00d4ff !important; border-radius: 16rpx !important; height: 80rpx !important; font-size: 26rpx !important; border: 1rpx solid rgba(0, 200, 255, 0.2) !important; box-shadow: 0 0 0 1rpx rgba(0,200,255,0.05) inset, 0 1rpx 0 rgba(150,220,255,0.05) inset; display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.modal-save::after { border: none; }

.privacy-modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.85); z-index: 2000; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(8rpx); }
.privacy-modal-box { width: 82%; background: rgba(16, 20, 48, 0.92); border: 1rpx solid rgba(255, 255, 255, 0.1); border-radius: 32rpx; padding: 40rpx 32rpx; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 16rpx 48rpx rgba(0,0,0,0.5); }
.privacy-modal-header { margin-bottom: 24rpx; text-align: center; }
.privacy-modal-title { font-size: 32rpx; font-weight: 700; color: #00d4ff; }
.privacy-modal-body { margin-bottom: 40rpx; line-height: 1.6; }
.privacy-modal-desc { font-size: 26rpx; color: rgba(255, 255, 255, 0.75); }
.privacy-modal-link-inline { font-size: 26rpx; color: #00d4ff; text-decoration: underline; font-weight: 600; display: inline; }
.privacy-modal-footer { display: flex; gap: 20rpx; }
.privacy-btn-cancel { flex: 1; background: rgba(255, 255, 255, 0.08) !important; color: rgba(255, 255, 255, 0.5) !important; border: 1rpx solid rgba(255, 255, 255, 0.12) !important; border-radius: 16rpx !important; height: 80rpx !important; font-size: 26rpx !important; font-weight: 500 !important; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.03); display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.privacy-btn-cancel::after { border: none; }
.privacy-btn-confirm { flex: 1; background: rgba(0, 200, 255, 0.12) !important; color: #00d4ff !important; border-radius: 16rpx !important; height: 80rpx !important; font-size: 26rpx !important; font-weight: 600 !important; border: 1rpx solid rgba(0, 200, 255, 0.2) !important; box-shadow: 0 0 0 1rpx rgba(0,200,255,0.05) inset, 0 1rpx 0 rgba(150,220,255,0.05) inset; display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.privacy-btn-confirm::after { border: none; }
