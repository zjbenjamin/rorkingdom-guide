/* 捕捉统计页 - Premium Cyber HUD v4.0 (高清晰/全中文/全可视化) */
page { 
  background: #020410; 
  min-height: 100vh; 
  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, sans-serif;
  color: #fff;
}

.page { 
  min-height: 100vh; 
  padding-top: 88rpx;
  padding-bottom: 180rpx; 
  background-color: #010314;
  background-image:
    radial-gradient(ellipse 80% 50% at 20% 15%, rgba(0, 180, 255, 0.12) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 80% 35%, rgba(100, 60, 255, 0.1) 0%, transparent 55%),
    radial-gradient(ellipse 50% 50% at 50% 65%, rgba(0, 120, 255, 0.07) 0%, transparent 50%),
    radial-gradient(ellipse 70% 40% at 40% 85%, rgba(160, 80, 255, 0.06) 0%, transparent 50%),
    linear-gradient(185deg, #020410 0%, #040c24 30%, #030618 70%, #020410 100%);
  animation: pageExpand 0.55s cubic-bezier(0.22, 0.61, 0.36, 1);
}
@keyframes pageExpand {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

.container { padding: 24rpx; }

/* --- 核心卡片容器 - iOS 26 Liquid Glass --- */
.premium-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 36rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 
    0 0 0 1rpx rgba(255, 255, 255, 0.06) inset,
    0 1rpx 0 rgba(255, 255, 255, 0.04) inset,
    0 12rpx 40rpx rgba(0, 0, 0, 0.25),
    0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  position: relative;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
  animation: sectionEnter 0.55s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
  opacity: 0;
}
/* 顶部玻璃高光线 */
.premium-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 20rpx;
  right: 20rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.08), transparent);
  pointer-events: none;
}

/* --- 各板块 Liquid Glass 颜色调性 --- */
.premium-card.tint-blue {
  background: rgba(0, 180, 255, 0.04);
  border-color: rgba(0, 180, 255, 0.12);
  box-shadow:
    0 0 0 1rpx rgba(0, 200, 255, 0.06) inset,
    0 1rpx 0 rgba(180, 220, 255, 0.06) inset,
    0 12rpx 40rpx rgba(0, 40, 120, 0.2),
    0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}
.premium-card.tint-blue::after {
  background: linear-gradient(90deg, transparent, rgba(100, 200, 255, 0.1), transparent);
}
.premium-card.tint-warm {
  background: rgba(255, 180, 60, 0.03);
  border-color: rgba(255, 180, 60, 0.1);
  box-shadow:
    0 0 0 1rpx rgba(255, 200, 100, 0.05) inset,
    0 1rpx 0 rgba(255, 220, 160, 0.05) inset,
    0 12rpx 40rpx rgba(60, 30, 0, 0.2),
    0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}
.premium-card.tint-warm::after {
  background: linear-gradient(90deg, transparent, rgba(255, 200, 100, 0.08), transparent);
}
.premium-card.tint-purple {
  background: rgba(120, 60, 240, 0.03);
  border-color: rgba(120, 60, 240, 0.1);
  box-shadow:
    0 0 0 1rpx rgba(140, 80, 255, 0.05) inset,
    0 1rpx 0 rgba(180, 140, 255, 0.05) inset,
    0 12rpx 40rpx rgba(40, 0, 80, 0.2),
    0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}
.premium-card.tint-purple::after {
  background: linear-gradient(90deg, transparent, rgba(160, 100, 255, 0.08), transparent);
}

.premium-card:nth-child(1) { animation-delay: 0s; }
.premium-card:nth-child(2) { animation-delay: 0.08s; }
.premium-card:nth-child(3) { animation-delay: 0.16s; }
.premium-card:nth-child(4) { animation-delay: 0.24s; }
@keyframes sectionEnter {
  from { opacity: 0; transform: translateY(24rpx) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}
.tint-blue .panel-header { border-bottom-color: rgba(0, 180, 255, 0.08); }
.tint-warm .panel-header { border-bottom-color: rgba(255, 180, 60, 0.08); }
.tint-purple .panel-header { border-bottom-color: rgba(120, 60, 240, 0.08); }
.panel-title {
  display: flex;
  flex-direction: column;
}

.title-main {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
  text-shadow: 0 0 16rpx rgba(0, 212, 255, 0.4);
  background: linear-gradient(135deg, #fff, #00d4ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.visual-bars {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  height: 40rpx;
  margin-bottom: 24rpx;
  background: rgba(0, 0, 0, 0.2);
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(0, 180, 255, 0.1);
  box-shadow: inset 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
}
.v-bar {
  flex: 1;
  background: linear-gradient(to top, rgba(0, 180, 255, 0.25), rgba(0, 200, 255, 0.7));
  border-radius: 3rpx;
  height: 15%;
  animation: bar-wave 1.2s ease-in-out infinite;
  position: relative;
  overflow: hidden;
  box-shadow: inset 0 -1rpx 0 rgba(255, 255, 255, 0.1);
}
.v-bar::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.4), transparent);
  animation: bar-shine 1s ease-in-out infinite;
}
.v-bar:nth-child(1) { animation-delay: 0s; }
.v-bar:nth-child(2) { animation-delay: 0.15s; }
.v-bar:nth-child(3) { animation-delay: 0.3s; }
.v-bar:nth-child(4) { animation-delay: 0.1s; }
.v-bar:nth-child(5) { animation-delay: 0.4s; }

@keyframes bar-wave {
  0%, 100% { height: 15%; background: linear-gradient(to top, rgba(0, 212, 255, 0.3), rgba(0, 212, 255, 0.6)); }
  50% { height: 100%; background: linear-gradient(to top, rgba(0, 212, 255, 0.7), rgba(0, 212, 255, 1)); }
}

@keyframes bar-shine {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

.stats-grid { 
  display: grid; 
  grid-template-columns: repeat(2, 1fr); 
  gap: 12rpx; 
  margin-bottom: 28rpx;
}
.stat-card {
  background: rgba(255, 255, 255, 0.04);
  padding: 24rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  position: relative;
  overflow: hidden;
  box-shadow: 
    0 0 0 1rpx rgba(255, 255, 255, 0.04) inset,
    0 1rpx 0 rgba(255, 255, 255, 0.03) inset,
    0 6rpx 20rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  animation: cardFadeIn 0.5s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
  opacity: 0;
  text-align: center;
}
.stat-card.carnival { 
  border-color: rgba(255, 171, 64, 0.12); 
  background: rgba(255, 140, 30, 0.03);
}
.stat-card.lucky { 
  border-color: rgba(224, 64, 251, 0.12); 
  background: rgba(200, 50, 240, 0.03);
}
.stat-card.total { 
  grid-column: span 2; 
  text-align: center; 
  background: rgba(0, 180, 255, 0.04); 
  border-color: rgba(0, 180, 255, 0.1); 
  box-shadow: 
    0 0 0 1rpx rgba(0, 200, 255, 0.05) inset,
    0 1rpx 0 rgba(150, 220, 255, 0.04) inset,
    0 4rpx 16rpx rgba(0, 40, 120, 0.12);
  padding: 18rpx 16rpx;
}
.stat-card.carnival { border-color: rgba(255, 171, 64, 0.2); }
.stat-card.lucky { border-color: rgba(224, 64, 251, 0.2); }
.stat-card:nth-child(1) { animation-delay: 0s; }
.stat-card:nth-child(2) { animation-delay: 0.1s; }
.stat-card:nth-child(3) { animation-delay: 0.2s; }
.stat-card:active { 
  transform: scale(0.96); 
  transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}
@keyframes cardFadeIn {
  from { opacity: 0; transform: translateY(16rpx) scale(0.96); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}
.stat-label { 
  font-size: 18rpx; 
  color: rgba(255, 255, 255, 0.55); 
  display: block; 
  margin-bottom: 6rpx; 
  font-weight: 600; 
  letter-spacing: 1rpx;
}
.stat-value { 
  font-size: 40rpx; 
  font-weight: 900; 
  font-family: 'DIN Alternate', 'Courier New', Courier, monospace; 
  color: #fff; 
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.4);
}
.stat-card.carnival .stat-value { 
  background: linear-gradient(135deg, #ffab40, #ff9100);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 20rpx rgba(255, 171, 64, 0.35);
}
.stat-card.lucky .stat-value { 
  background: linear-gradient(135deg, #e040fb, #9c27b0);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 20rpx rgba(224, 64, 251, 0.35);
}
/* 进度条优化 */
.progress-section { 
  background: rgba(0, 180, 255, 0.03); 
  padding: 24rpx; 
  border-radius: 24rpx; 
  margin-bottom: 32rpx; 
  border: 1rpx solid rgba(0, 180, 255, 0.08); 
  box-shadow: inset 0 1rpx 0 rgba(150, 220, 255, 0.04);
}
.section-meta { 
  display: flex; 
  justify-content: space-between; 
  align-items: center;
  font-size: 24rpx; 
  margin-bottom: 16rpx; 
  color: #fff; 
  font-weight: 700; 
}
.meta-val { 
  color: #00d4ff; 
  font-size: 28rpx;
  font-weight: 900;
}
.pity-bar-wrapper {
  position: relative;
  margin: 8rpx 0;
}
.pity-track { 
  height: 12rpx; 
  background: rgba(0, 0, 0, 0.4); 
  border-radius: 6rpx; 
  border: 1rpx solid rgba(255, 255, 255, 0.06); 
  position: relative; 
  overflow: hidden; 
  box-shadow: inset 0 1rpx 3rpx rgba(0, 0, 0, 0.3);
}
.pity-fill { 
  height: 100%; 
  background: linear-gradient(90deg, #00b8ff, #6c5ce7); 
  border-radius: 6rpx; 
  box-shadow: 
    0 0 12rpx rgba(0, 180, 255, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2); 
  transition: width 0.8s cubic-bezier(0.22, 0.61, 0.36, 1); 
  position: relative;
}
.pity-fill.warning {
  background: linear-gradient(90deg, #ffab40, #ff6d00);
  box-shadow: 
    0 0 12rpx rgba(255, 171, 64, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
}
.pity-fill.danger {
  background: linear-gradient(90deg, #ff4757, #c0392b);
  box-shadow: 
    0 0 16rpx rgba(255, 71, 87, 0.5),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
  animation: pity-pulse 1.2s infinite;
}

.pity-fill::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  animation: bar-scan 2.5s infinite linear;
}

/* 里程碑标记点 */
.pity-milestones {
  display: flex;
  justify-content: space-between;
  margin-top: 6rpx;
  padding: 0 2rpx;
}
.pity-milestone {
  font-size: 16rpx;
  color: rgba(255,255,255,0.2);
  font-weight: 600;
  transition: color 0.3s ease;
}
.pity-milestone.reached {
  color: rgba(0, 212, 255, 0.6);
}
.pity-milestone.danger-reached {
  color: rgba(255, 71, 87, 0.6);
}

@keyframes bar-scan {
  from { transform: translateX(-100%); }
  to { transform: translateX(100%); }
}

@keyframes pity-pulse {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.3); }
}

.pity-status { 
  margin-top: 16rpx; 
  text-align: center; 
  font-size: 24rpx; 
  color: #00d4ff; 
  font-weight: 800; 
  text-shadow: 0 0 10rpx rgba(0,212,255,0.3); 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  gap: 8rpx;
}
.pity-status .status-emoji {
  font-size: 28rpx;
}
.pity-status .status-text {
  font-size: 24rpx;
}


/* 操作按钮 - 统一毛玻璃基类 */
.control-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14rpx; }
.visual-action-btn {
  height: 130rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 
    0 0 0 1rpx rgba(255, 255, 255, 0.03) inset,
    0 1rpx 0 rgba(255, 255, 255, 0.04) inset,
    0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  position: relative;
  overflow: hidden;
  transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
}
.visual-action-btn:active { 
  transform: scale(0.94); 
  background: rgba(255, 255, 255, 0.07);
}
.visual-action-btn .btn-icon {
  font-size: 30rpx;
  line-height: 1;
}
.visual-action-btn .btn-text { 
  font-size: 24rpx; 
  font-weight: 700; 
  letter-spacing: 1rpx;
  text-align: center;
}

/* 仅文字颜色区分语义 */
.capture-btn .btn-text, .capture-btn .btn-icon { color: #00ff73; }
.miss-btn .btn-text, .miss-btn .btn-icon { color: #ff5252; }
.box-btn .btn-text, .box-btn .btn-icon, .carnival-btn .btn-text, .carnival-btn .btn-icon { color: #00d4ff; }

.help-hint {
  text-align: center;
  font-size: 18rpx;
  color: rgba(255,255,255,0.25);
  margin-top: 16rpx;
  letter-spacing: 1rpx;
}

/* --- 资产看板区优化 --- */
.wealth-main { 
  padding: 32rpx 0; 
  text-align: center; 
  display: flex;
  flex-direction: column;
  align-items: center;
}
.wealth-label-group {
  margin-bottom: 16rpx;
  text-align: center;
}
.label-main { 
  font-size: 22rpx; 
  color: rgba(255,255,255,0.6); 
  letter-spacing: 2rpx; 
  font-weight: 700; 
}
.label-sub {
  display: block;
  font-size: 18rpx;
  color: rgba(255,255,255,0.3);
  margin-top: 4rpx;
}
.wealth-display { 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  gap: 0; 
  margin-top: 8rpx; 
}
.value-group {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.amount { 
  font-size: 72rpx; 
  font-weight: 900; 
  color: #fff; 
  text-shadow: 0 0 30rpx rgba(255, 200, 100, 0.2);
  font-family: 'DIN Alternate', 'Courier New', monospace;
}
.amount-unit {
  font-size: 24rpx;
  color: rgba(255,255,255,0.4);
  font-weight: 600;
}

.init-form {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.premium-input {
  background: rgba(255, 255, 255, 0.04);
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: #fff;
  font-size: 28rpx;
  text-align: center;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.sub-tabs-premium { 
  display: flex; 
  gap: 10rpx; 
  margin-bottom: 24rpx; 
  background: rgba(255, 255, 255, 0.03);
  padding: 6rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.03);
}

.sub-tab-p.on { 
  background: rgba(0, 212, 255, 0.1); 
  border-color: rgba(0, 212, 255, 0.25); 
  color: #00d4ff; 
  font-weight: 700; 
  box-shadow: 0 0 12rpx rgba(0, 212, 255, 0.08), inset 0 1rpx 0 rgba(255,255,255,0.05);
}
.premium-input:focus {
  border-color: rgba(0, 212, 255, 0.4);
  box-shadow: 0 0 16rpx rgba(0, 212, 255, 0.12);
}

.profit-summary { 
  display: flex; 
  align-items: center; 
  background: rgba(255, 180, 60, 0.03); 
  border-radius: 24rpx; 
  padding: 24rpx; 
  margin-top: 32rpx; 
  border: 1rpx solid rgba(255, 180, 60, 0.08); 
  box-shadow: 
    0 0 0 1rpx rgba(255, 200, 100, 0.03) inset,
    0 1rpx 0 rgba(255, 220, 160, 0.03) inset;
}
.summary-divider { width: 1rpx; height: 44rpx; background: rgba(255, 180, 60, 0.15); }

.inv-item { 
  flex: 1; 
  background: rgba(120, 60, 240, 0.03); 
  padding: 18rpx 16rpx; 
  border-radius: 16rpx; 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  border: 1rpx solid rgba(120, 60, 240, 0.08); 
  box-shadow: 
    0 0 0 1rpx rgba(160, 100, 255, 0.03) inset,
    0 1rpx 0 rgba(180, 140, 255, 0.03) inset,
    0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.log-item { 
  display: flex; gap: 20rpx; align-items: center;
  background: rgba(255, 255, 255, 0.03); 
  padding: 20rpx 22rpx; 
  border-radius: 20rpx; 
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  margin-bottom: 12rpx;
  box-shadow: 
    0 0 0 1rpx rgba(255, 255, 255, 0.03) inset,
    0 1rpx 0 rgba(255, 255, 255, 0.02) inset,
    0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  animation: slideIn 0.4s cubic-bezier(0.22, 0.61, 0.36, 1);
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
@keyframes slideIn {
  from { opacity: 0; transform: translateX(-20rpx); }
  to { opacity: 1; transform: translateX(0); }
}
.history-log-list {
  max-height: 800rpx;
  overflow-y: auto;
  padding-right: 4rpx;
}
.history-log-list::-webkit-scrollbar { width: 3rpx; }
.history-log-list::-webkit-scrollbar-thumb { background: rgba(0, 180, 255, 0.15); border-radius: 2rpx; }
.history-log-list::-webkit-scrollbar-track { background: transparent; }
.log-badge { 
  width: 72rpx; height: 72rpx; min-width: 72rpx;
  border-radius: 18rpx; 
  display: flex; align-items: center; justify-content: center; 
  font-size: 22rpx; font-weight: 900; flex-shrink: 0;
  box-shadow: 
    0 0 0 1rpx rgba(255, 255, 255, 0.04) inset,
    0 1rpx 0 rgba(255, 255, 255, 0.04) inset,
    0 4rpx 12rpx rgba(0, 0, 0, 0.12);
  animation: badgePop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}
@keyframes badgePop {
  from { opacity: 0; transform: scale(0.4); }
  to { opacity: 1; transform: scale(1); }
}
.log-badge.ok { 
  background: rgba(0, 255, 115, 0.1); 
  color: #00ff73; 
  border: 1rpx solid rgba(0, 255, 115, 0.2);
}
.log-badge.miss { 
  background: rgba(255, 82, 82, 0.1); 
  color: #ff5252; 
  border: 1rpx solid rgba(255, 82, 82, 0.2);
}
.log-badge.other { 
  background: rgba(255, 255, 255, 0.04); 
  color: rgba(255,255,255,0.8); 
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}
.log-content {
  flex: 1;
  min-width: 0;
}
.log-ball { font-size: 24rpx; font-weight: 700; color: #fff; margin-bottom: 4rpx; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.log-pet { font-size: 20rpx; color: #00d4ff; margin-bottom: 4rpx; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.log-details { margin-top: 8rpx; padding-top: 8rpx; border-top: 1rpx solid rgba(255, 255, 255, 0.06); display: flex; justify-content: space-between; align-items: center; }
.log-cost { font-size: 20rpx; font-weight: 700; color: #ffab40; }
.log-time { font-size: 18rpx; color: rgba(255,255,255,0.3); font-weight: 600; }

.summary-item { flex: 1; text-align: center; }
.item-label { font-size: 18rpx; color: rgba(255,255,255,0.45); display: block; margin-bottom: 6rpx; }
.item-val { font-size: 32rpx; font-weight: 900; }
.item-val.pos, .rate-tag.pos { color: #00ff73; text-shadow: 0 0 12rpx rgba(0,255,115,0.3); }
.item-val.neg, .rate-tag.neg { color: #ff5252; text-shadow: 0 0 12rpx rgba(255,82,82,0.3); }
.summary-divider { width: 1rpx; height: 48rpx; background: rgba(255,255,255,0.1); }
.rate-tag { font-size: 32rpx; font-weight: 900; }

.action-footer { 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
  margin-top: 32rpx; 
  padding-top: 24rpx; 
  border-top: 1rpx solid rgba(255,255,255,0.08); 
}
