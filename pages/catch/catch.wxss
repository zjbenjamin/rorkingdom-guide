/* 捕捉统计页 - 统一科技感主题 */
page { background: #0a0e27; min-height: 100vh; }
.page { min-height: 100vh; padding-bottom: 120rpx; position: relative; overflow: hidden; }
.container { padding: 24rpx; }

/* 马戏团粒子特效 */
.circus-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 999; pointer-events: none; overflow: hidden; }
.circus-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 400rpx; height: 400rpx; background: radial-gradient(circle, rgba(255,171,64,0.3), transparent 70%); border-radius: 50%; animation: circusGlow 2s ease-out forwards; }
.circus-particle { position: absolute; font-size: 48rpx; animation-fill-mode: forwards; animation-timing-function: cubic-bezier(0.25, 0.46, 0.45, 0.94); }
.p1 { top: 40%; left: 10%; animation: circusFly1 3s ease-out forwards; font-size: 64rpx; }
.p2 { top: 30%; left: 20%; animation: circusFly2 3.5s ease-out forwards; animation-delay: 0.1s; }
.p3 { top: 50%; left: 15%; animation: circusFly3 2.8s ease-out forwards; animation-delay: 0.2s; }
.p4 { top: 35%; left: 30%; animation: circusFly1 3.2s ease-out forwards; animation-delay: 0.15s; }
.p5 { top: 45%; left: 25%; animation: circusFly2 2.9s ease-out forwards; animation-delay: 0.25s; }
.p6 { top: 55%; left: 35%; animation: circusFly3 3.3s ease-out forwards; animation-delay: 0.1s; }
.p7 { top: 40%; right: 10%; animation: circusFlyR1 3s ease-out forwards; font-size: 64rpx; }
.p8 { top: 30%; right: 20%; animation: circusFlyR2 3.5s ease-out forwards; animation-delay: 0.1s; }
.p9 { top: 50%; right: 15%; animation: circusFlyR3 2.8s ease-out forwards; animation-delay: 0.2s; }
.p10 { top: 35%; right: 30%; animation: circusFlyR1 3.2s ease-out forwards; animation-delay: 0.15s; }
.p11 { top: 45%; right: 25%; animation: circusFlyR2 2.9s ease-out forwards; animation-delay: 0.25s; }
.p12 { top: 55%; right: 35%; animation: circusFlyR3 3.3s ease-out forwards; animation-delay: 0.1s; }

@keyframes circusGlow { 0% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); } 30% { opacity: 1; transform: translate(-50%, -50%) scale(1.5); } 100% { opacity: 0; transform: translate(-50%, -50%) scale(3); } }
@keyframes circusFly1 { 0% { transform: translate(0, 0) rotate(0deg); opacity: 1; } 100% { transform: translate(-120rpx, -800rpx) rotate(360deg); opacity: 0; } }
@keyframes circusFly2 { 0% { transform: translate(0, 0) rotate(0deg); opacity: 1; } 100% { transform: translate(-60rpx, -900rpx) rotate(-270deg); opacity: 0; } }
@keyframes circusFly3 { 0% { transform: translate(0, 0) rotate(0deg); opacity: 1; } 100% { transform: translate(-180rpx, -700rpx) rotate(450deg); opacity: 0; } }
@keyframes circusFlyR1 { 0% { transform: translate(0, 0) rotate(0deg); opacity: 1; } 100% { transform: translate(120rpx, -800rpx) rotate(-360deg); opacity: 0; } }
@keyframes circusFlyR2 { 0% { transform: translate(0, 0) rotate(0deg); opacity: 1; } 100% { transform: translate(60rpx, -900rpx) rotate(270deg); opacity: 0; } }
@keyframes circusFlyR3 { 0% { transform: translate(0, 0) rotate(0deg); opacity: 1; } 100% { transform: translate(180rpx, -700rpx) rotate(-450deg); opacity: 0; } }

.card-title { font-size: 28rpx; font-weight: 700; color: #00d4ff; margin-bottom: 20rpx; padding-left: 16rpx; border-left: 4rpx solid #00d4ff; display: flex; justify-content: space-between; align-items: center; }
.expand { font-size: 22rpx; color: rgba(0,212,255,0.5); font-weight: normal; }

/* 异色统计 */
.encounter-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12rpx; margin-bottom: 20rpx; }
.enc-item { text-align: center; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 12rpx; padding: 20rpx 8rpx; }
.enc-item.enc-total { grid-column: span 2; background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(153,69,255,0.15)); border-color: rgba(0,212,255,0.25); }
.enc-num { font-size: 40rpx; font-weight: 700; display: block; }
.enc-label { font-size: 20rpx; color: rgba(255,255,255,0.5); display: block; margin-top: 8rpx; }
.enc-carnival .enc-num { color: #ffab40; text-shadow: 0 0 10px rgba(255,171,64,0.5); }
.enc-luckybox .enc-num { color: #e040fb; text-shadow: 0 0 10px rgba(224,64,251,0.5); }
.enc-total .enc-num { color: #00d4ff; text-shadow: 0 0 12px rgba(0,212,255,0.6); }

/* 保底进度 */
/* 保底进度粒子效果 */
.pity-box { background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 12rpx; padding: 20rpx; margin-bottom: 20rpx; }
.pity-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.pity-title { font-size: 24rpx; color: rgba(255,255,255,0.6); }
.pity-val { font-size: 24rpx; color: #00d4ff; font-weight: 700; }
.particle-bar { margin-bottom: 12rpx; }
.particle-track { position: relative; height: 20rpx; background: rgba(0,0,0,0.4); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 10rpx; overflow: visible; }
.particle-fill { height: 100%; background: linear-gradient(90deg, #00d4ff, #9945ff); border-radius: 10rpx; position: relative; transition: width 0.5s ease; overflow: visible; }
.particle-glow { position: absolute; right: -4rpx; top: 50%; transform: translateY(-50%); width: 24rpx; height: 24rpx; background: radial-gradient(circle, #00d4ff, transparent 70%); border-radius: 50%; animation: glow-pulse 1.5s ease-in-out infinite; }
@keyframes glow-pulse { 0%, 100% { opacity: 0.6; transform: translateY(-50%) scale(1); } 50% { opacity: 1; transform: translateY(-50%) scale(1.3); } }
.particle-spark { position: absolute; width: 8rpx; height: 8rpx; background: #fff; border-radius: 50%; top: 50%; animation: spark-float 2s ease-in-out infinite; }
.spark-1 { right: 0; animation-delay: 0s; }
.spark-2 { right: 20%; animation-delay: 0.5s; }
.spark-3 { right: 40%; animation-delay: 1s; }
.spark-4 { right: 60%; animation-delay: 1.5s; }
@keyframes spark-float { 0%, 100% { opacity: 0; transform: translateY(0); } 50% { opacity: 1; transform: translateY(-16rpx); } }
.particle-markers { position: absolute; top: 0; left: 0; right: 0; bottom: 0; }
.marker { position: absolute; top: 0; width: 1rpx; height: 100%; background: rgba(255,255,255,0.15); }
.marker-text { position: absolute; bottom: -28rpx; left: 50%; transform: translateX(-50%); font-size: 16rpx; color: rgba(255,255,255,0.5); }
.pity-hint-row { display: flex; align-items: center; justify-content: center; gap: 8rpx; margin-top: 20rpx; }
.pity-emoji { font-size: 28rpx; animation: emoji-bounce 1s ease-in-out infinite; }
@keyframes emoji-bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-6rpx); } }
.pity-hint { font-size: 24rpx; color: #00d4ff; font-weight: 600; text-shadow: 0 0 8px rgba(0,212,255,0.5); }

/* 操作按钮网格 */
.action-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12rpx; margin-bottom: 12rpx; }
.action-btn { display: flex; align-items: center; justify-content: center; gap: 6rpx; padding: 20rpx 16rpx; border-radius: 14rpx; font-size: 24rpx; font-weight: 600; position: relative; overflow: hidden; min-width: 0; background: rgba(0,212,255,0.1); border: 1rpx solid rgba(0,212,255,0.2); color: #00d4ff; box-sizing: border-box; }
.action-btn::after { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent); animation: btn-shine 3s ease-in-out infinite; }
.action-icon { font-size: 32rpx; flex-shrink: 0; }
.action-text { font-size: 24rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: inherit; }
@keyframes btn-shine { 0% { left: -100%; } 50%, 100% { left: 100%; } }
.result-hint { display: block; text-align: center; font-size: 20rpx; color: rgba(255,255,255,0.5); }

/* 初始化提示 */
.setup-hint { text-align: center; padding: 40rpx 20rpx; }
.setup-icon { font-size: 64rpx; display: block; margin-bottom: 16rpx; }
.setup-text { font-size: 26rpx; color: rgba(255,255,255,0.5); display: block; line-height: 1.6; }

/* 洛克贝 */
.coin-row { display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 12rpx; padding: 20rpx; margin-bottom: 12rpx; }
.coin-row.total-row { background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(153,69,255,0.15)); border-color: rgba(0,212,255,0.2); }
.coin-row.final-row { background: linear-gradient(135deg, rgba(153,69,255,0.2), rgba(255,71,184,0.1)); border-color: rgba(153,69,255,0.3); margin-bottom: 0; }
.coin-label { font-size: 24rpx; color: rgba(255,255,255,0.6); }
.coin-val { font-size: 36rpx; font-weight: 700; color: #ffab40; }
.coin-val.negative { color: #ff4757; }
.coin-val.total { color: #9945ff; text-shadow: 0 0 8px rgba(153,69,255,0.5); }
.coin-input-row { display: flex; gap: 12rpx; margin-bottom: 12rpx; }
.coin-input { flex: 1; background: rgba(0,0,0,0.4); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 10rpx; padding: 16rpx; font-size: 26rpx; color: #00d4ff; }
.coin-input::placeholder { color: rgba(0,212,255,0.3); }
.coin-btn { background: linear-gradient(135deg, #00d4ff, #9945ff); color: #fff; padding: 16rpx 32rpx; border-radius: 10rpx; font-size: 26rpx; font-weight: 600; flex-shrink: 0; }
.coin-btn.disabled { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.3); }
.reset-row { text-align: right; margin-bottom: 12rpx; }
.reset-link { font-size: 22rpx; color: #ff4757; }

/* 特殊事件 */
.sub-tabs { display: flex; gap: 8rpx; margin-bottom: 16rpx; }
.sub-tab { flex: 1; padding: 14rpx 0; text-align: center; border-radius: 8rpx; font-size: 24rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); color: rgba(255,255,255,0.5); }
.sub-tab.on { background: linear-gradient(135deg, rgba(0,212,255,0.2), rgba(153,69,255,0.2)); border-color: rgba(0,212,255,0.3); color: #00d4ff; font-weight: 600; }
.ball-total-row { display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 10rpx; padding: 16rpx 20rpx; margin-bottom: 12rpx; }
.ball-total-label { font-size: 26rpx; color: rgba(255,255,255,0.6); }
.ball-total-val { font-size: 32rpx; font-weight: 700; color: #00d4ff; text-shadow: 0 0 8px rgba(0,212,255,0.5); }
.special-row { display: flex; gap: 10rpx; align-items: center; }
.special-picker { flex: 1; background: rgba(0,0,0,0.4); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 10rpx; padding: 16rpx; min-width: 0; }
.picker-content { display: flex; justify-content: space-between; align-items: center; }
.picker-text { font-size: 26rpx; color: #00d4ff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.picker-arrow { font-size: 20rpx; color: rgba(0,212,255,0.5); }
.special-count { width: 120rpx; flex-shrink: 0; background: rgba(0,0,0,0.4); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 10rpx; padding: 16rpx; font-size: 26rpx; text-align: center; color: #00d4ff; }
.special-btn { background: linear-gradient(135deg, #00d4ff, #9945ff); color: #fff; padding: 16rpx 28rpx; border-radius: 10rpx; font-size: 26rpx; font-weight: 600; flex-shrink: 0; }

/* 历史记录 */
.history-row { display: flex; align-items: center; gap: 12rpx; padding: 14rpx 0; border-bottom: 1rpx solid rgba(0,212,255,0.08); font-size: 22rpx; color: rgba(255,255,255,0.7); }
.history-row:last-child { border: none; }
.hbadge { padding: 4rpx 14rpx; border-radius: 6rpx; font-size: 18rpx; color: #fff; font-weight: 600; background: linear-gradient(135deg, #00d4ff, #9945ff); }
.hbadge.ok { background: linear-gradient(135deg, #00e676, #00c853); }
.hbadge.miss { background: linear-gradient(135deg, #ff4757, #cc3a48); }
.hbadge.pause { background: linear-gradient(135deg, #ffab40, #ff9100); }
.hname { font-weight: 600; color: #fff; }
.hpet { font-size: 20rpx; color: #ffab40; margin-left: 6rpx; }
.hcount { color: rgba(255,255,255,0.5); }
.hcost { font-size: 20rpx; color: #ffab40; margin-left: 8rpx; }
.htime { color: rgba(255,255,255,0.5); margin-left: auto; font-size: 20rpx; }
.clear-row { text-align: right; margin-top: 12rpx; }
.clear-link { font-size: 20rpx; color: #ff4757; }

/* 咕噜球明细 */
.ball-detail-title { font-size: 26rpx; font-weight: 600; color: rgba(0,212,255,0.7); margin: 20rpx 0 12rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(0,212,255,0.1); }

/* 使用球类型 */
.ball-row { display: flex; align-items: center; padding: 14rpx 0; border-bottom: 1rpx solid rgba(0,212,255,0.08); }
.ball-row.selected { background: rgba(0,212,255,0.1); border-radius: 10rpx; padding: 14rpx 8rpx; margin: 4rpx 0; }
.ball-row:last-child { border: none; }
.ball-dot { width: 20rpx; height: 20rpx; border-radius: 50%; margin-right: 16rpx; box-shadow: 0 0 8px currentColor; }
.ball-info { flex: 1; }
.ball-name { font-size: 26rpx; font-weight: 600; color: #fff; display: block; }
.ball-rate { font-size: 20rpx; color: rgba(255,255,255,0.4); }
.ball-price { font-size: 22rpx; color: #ffab40; margin-right: 16rpx; flex-shrink: 0; }
.ball-price.free { color: rgba(0,230,118,0.7); }
.ball-count { font-size: 32rpx; font-weight: 700; color: #00d4ff; margin-left: auto; }
.ball-use-row { display: flex; align-items: center; gap: 12rpx; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(0,212,255,0.1); }
.ball-use-label { font-size: 24rpx; color: rgba(255,255,255,0.6); flex-shrink: 0; }
.ball-use-input { flex: 1; background: rgba(0,0,0,0.4); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 10rpx; padding: 12rpx; font-size: 26rpx; color: #00d4ff; text-align: center; }
.ball-use-btn { background: linear-gradient(135deg, #00d4ff, #9945ff); color: #fff; padding: 12rpx 24rpx; border-radius: 10rpx; font-size: 24rpx; font-weight: 600; flex-shrink: 0; }
.ball-cost-hint { text-align: center; font-size: 22rpx; color: #ffab40; margin-top: 12rpx; }
.empty-ball { text-align: center; padding: 32rpx 0; }
.empty-hint { font-size: 24rpx; color: rgba(255,255,255,0.5); }
.expand-hint { text-align: center; color: rgba(0,212,255,0.4); font-size: 24rpx; padding: 20rpx 0; display: block; }

/* 球剩余记录弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 1000; display: flex; align-items: flex-end; }
.modal-box { width: 100%; background: linear-gradient(180deg, #1a1040, #0a0e27); border-radius: 24rpx 24rpx 0 0; padding: 32rpx; max-height: 80vh; display: flex; flex-direction: column; }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; flex-shrink: 0; }
.modal-title { font-size: 32rpx; font-weight: 700; color: #00d4ff; }
.modal-close { font-size: 36rpx; color: rgba(255,255,255,0.4); padding: 8rpx; }
.modal-body { overflow-y: auto; }
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 12rpx; }
.form-input { width: 100%; min-height: 72rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 10rpx; padding: 18rpx 20rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; }
.form-picker { min-height: 72rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 10rpx; padding: 18rpx 20rpx; display: flex; align-items: center; }
.picker-text { font-size: 28rpx; color: #fff; }
.check-hint { font-size: 24rpx; color: rgba(255,171,64,0.7); padding: 12rpx 16rpx; background: rgba(255,171,64,0.08); border: 1rpx solid rgba(255,171,64,0.15); border-radius: 8rpx; margin-bottom: 20rpx; }
.check-mode-tabs { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.check-mode-tab { flex: 1; text-align: center; padding: 14rpx 0; font-size: 26rpx; color: rgba(255,255,255,0.4); background: rgba(0,0,0,0.2); border: 1rpx solid rgba(0,212,255,0.08); border-radius: 10rpx; }
.check-mode-tab.on { background: linear-gradient(135deg, rgba(0,212,255,0.2), rgba(153,69,255,0.2)); color: #00d4ff; border-color: rgba(0,212,255,0.3); font-weight: 600; }
.modal-footer { display: flex; gap: 16rpx; flex-shrink: 0; padding-top: 20rpx; }
.modal-cancel { flex: 1; background: rgba(255,255,255,0.1) !important; color: rgba(255,255,255,0.6) !important; border-radius: 12rpx !important; height: 80rpx !important; line-height: 80rpx !important; font-size: 28rpx !important; }
.modal-cancel::after { border: none; }
.modal-save { flex: 1; background: linear-gradient(135deg, #00d4ff, #9945ff) !important; color: #fff !important; border-radius: 12rpx !important; height: 80rpx !important; line-height: 80rpx !important; font-size: 28rpx !important; }
.modal-save::after { border: none; }

.foot { text-align: center; font-size: 20rpx; color: rgba(0,212,255,0.3); padding: 24rpx 0; }