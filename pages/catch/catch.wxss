/* --- 弹窗基础样式 --- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 2, 12, 0.75);
  backdrop-filter: blur(16rpx);
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: modalFadeIn 0.4s cubic-bezier(0.32, 0.72, 0, 1);
}
.modal-box {
  width: 88%;
  background: rgba(16, 20, 45, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  padding: 36rpx 32rpx;
  box-shadow: 
    0 0 0 1rpx rgba(255, 255, 255, 0.05) inset,
    0 2rpx 0 rgba(255, 255, 255, 0.04) inset,
    0 0 100rpx rgba(0, 120, 255, 0.12),
    0 24rpx 60rpx rgba(0, 0, 0, 0.45);
  position: relative;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}
.modal-box::after {
  content: '';
  position: absolute;
  top: 0; left: 24rpx; right: 24rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  pointer-events: none;
}

@keyframes modalFadeIn {
  from { opacity: 0; transform: scale(0.9) translateY(16rpx); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.modal-header {
