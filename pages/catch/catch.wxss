/* --- 马戏团粒子特效 --- */
.circus-overlay {
  position: fixed;
  top: 0; left: 0; width: 100vw; height: 100vh;
  z-index: 9999;
  pointer-events: none;
  overflow: hidden;
}

.circus-particle {
  position: absolute;
  font-size: 40rpx;
  opacity: 0;
  animation: circus-float 4s ease-in-out infinite;
}

.circus-glow {
  position: absolute;
  top: 50%; left: 50%;
  width: 200%; height: 200%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(255, 171, 64, 0.15) 0%, transparent 60%);
  animation: circus-glow-pulse 2s ease-in-out infinite;
}

/* 粒子位置分布 */
.p1 { top: 10%; left: 10%; animation-delay: 0s; }
.p2 { top: 20%; right: 15%; animation-delay: 0.5s; }
.p3 { bottom: 15%; left: 20%; animation-delay: 1s; }
.p4 { bottom: 25%; right: 10%; animation-delay: 1.5s; }
.p5 { top: 40%; left: 50%; animation-delay: 2s; }
.p6 { bottom: 50%; right: 30%; animation-delay: 2.5s; }
.p7 { top: 70%; left: 15%; animation-delay: 0.2s; }
.p8 { top: 15%; right: 40%; animation-delay: 0.8s; }
.p9 { bottom: 40%; left: 40%; animation-delay: 1.2s; }
.p10 { top: 60%; right: 20%; animation-delay: 1.8s; }
.p11 { bottom: 10%; right: 50%; animation-delay: 2.2s; }
.p12 { top: 50%; left: 5%; animation-delay: 2.8s; }

@keyframes circus-float {
  0% { transform: translateY(0) scale(1) rotate(0deg); opacity: 0; }
  20% { opacity: 1; }
  80% { opacity: 1; }
  100% { transform: translateY(-150rpx) scale(1.3) rotate(30deg); opacity: 0; }
}

@keyframes circus-glow-pulse {
  0%, 100% { opacity: 0.2; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.5; transform: translate(-50%, -50%) scale(1.1); }
}

/* --- 悬浮液态玻璃Dock栏 --- */
.dock {
  position: fixed;
  bottom: 28rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 999;
}
.dock-inner {
  display: flex;
  gap: 24rpx;
  align-items: center;
  padding: 16rpx 36rpx;
  border-radius: 60rpx;
  background: rgba(16, 20, 48, 0.72);
  backdrop-filter: blur(32rpx);
  -webkit-backdrop-filter: blur(32rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 
    0 0 0 1rpx rgba(255, 255, 255, 0.04) inset,
    0 1rpx 0 rgba(255, 255, 255, 0.06) inset,
    0 12rpx 48rpx rgba(0, 0, 0, 0.35),
    0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}
.dock-item {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  background: transparent;
}
.dock-item:active {
  transform: scale(0.85);
  background: rgba(255, 255, 255, 0.08);
}
.dock-item.active {
  background: rgba(255, 255, 255, 0.1);
  box-shadow: 0 0 16rpx rgba(0, 212, 255, 0.12);
}
.dock-icon {
  font-size: 36rpx;
  line-height: 1;
}
