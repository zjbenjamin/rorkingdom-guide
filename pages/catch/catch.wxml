<view class="page">
  <!-- 马戏团粒子特效 -->
  <view class="circus-overlay" wx:if="{{showCircusParticles}}">
    <view class="circus-particle p1">🎪</view>
    <view class="circus-particle p2">✨</view>
    <view class="circus-particle p3">🌟</view>
    <view class="circus-particle p4">🎉</view>
    <view class="circus-particle p5">🎊</view>
    <view class="circus-particle p6">⭐</view>
    <view class="circus-particle p7">🎪</view>
    <view class="circus-particle p8">✨</view>
    <view class="circus-particle p9">🌟</view>
    <view class="circus-particle p10">🎉</view>
    <view class="circus-particle p11">🎊</view>
    <view class="circus-particle p12">⭐</view>
    <view class="circus-glow"></view>
  </view>
  <view class="container">
    <!-- 异色捕捉主监控屏 -->
     <view class="premium-card monitor-panel tint-blue">
      <!-- 动效可视化动态条 -->
      <view class="visual-bars">
        <view class="v-bar"></view>
        <view class="v-bar"></view>
        <view class="v-bar"></view>
        <view class="v-bar"></view>
        <view class="v-bar"></view>
      </view>

      <view class="panel-header">
        <view class="panel-title">
          <text class="title-main">异色捕捉实时监测</text>
          <text class="title-sub">系统运行状态：良好 v1.0.8D</text>
        </view>
        <view class="panel-ops">
          <view class="capsule-btn warning" bindtap="onClearEncounter">
            <text>重置数据</text>
          </view>
        </view>
      </view>

      <view wx:if="{{!canStartCapture}}" class="init-loading">
        <view class="radar-scan"></view>
        <view class="init-icon">📡</view>
        <view class="init-text">
          <text class="glitch-text">等待系统同步...</text>
          <text class="init-sub">请先初始化洛克贝资产并购买咕噜球</text>
        </view>
      </view>

      <block wx:if="{{canStartCapture}}">
        <view class="stats-grid">
          <view class="stat-card total">
            <text class="stat-label">累计奇遇次数</text>
            <text class="stat-value">{{carnivalCount+luckyBoxCount}}</text>
          </view>
          <view class="stat-card carnival">
            <text class="stat-label">狂欢时刻</text>
            <text class="stat-value">{{carnivalCount}}</text>
          </view>
          <view class="stat-card lucky">
            <text class="stat-label">惊喜幸运盒</text>
            <text class="stat-value">{{luckyBoxCount}}</text>
          </view>
        </view>

        <view class="progress-section">
          <view class="section-meta">
            <view class="section-title-group" style="display:flex; align-items:center;">
              <text>保底进度监测</text>
              <view class="mode-tag {{autoResetPity?'active':''}}" bindtap="toggleAutoResetPity" style="margin-left:20rpx;">
                <view class="tag-dot"></view>
                <text>{{autoResetPity?'自动重置':'手动重置'}}</text>
              </view>
            </view>
            <text class="meta-val">{{pityCount}} / 80</text>
          </view>
          <view class="pity-bar-wrapper">
            <view class="pity-track">
              <view class="pity-fill {{pityCount >= 70 ? 'danger' : pityCount >= 40 ? 'warning' : ''}}" style="width: {{pityCount / 80 * 100}}%"></view>
            </view>
          </view>
          <view class="pity-status" bindtap="onClearPity">
            <text class="status-emoji">{{pityEmoji}}</text>
            <text class="status-text">{{pityHint}}</text>
            <text class="manual-reset-hint" wx:if="{{!autoResetPity}}" style="font-size:18rpx; color:rgba(255,255,255,0.3); margin-left:10rpx;">(点击重置)</text>
          </view>
        </view>

        <view class="control-grid">
          <view class="visual-action-btn box-btn" bindtap="onAddLuckyBox" bindlongpress="onLuckyBoxLongPress">
            <text class="btn-icon">🎁</text>
            <text class="btn-text">幸运盒 +1</text>
          </view>
          <view class="visual-action-btn carnival-btn" bindtap="onAddCarnival" bindlongpress="onCarnivalLongPress">
            <text class="btn-icon">🌟</text>
            <text class="btn-text">狂欢 +1</text>
          </view>
          <view class="visual-action-btn capture-btn" bindtap="onResult" bindlongpress="onLongResult" data-r="success">
            <text class="btn-icon">✨</text>
            <text class="btn-text">捕获成功</text>
          </view>
          <view class="visual-action-btn miss-btn" bindtap="onResult" bindlongpress="onLongResult" data-r="miss">
            <text class="btn-icon">💫</text>
            <text class="btn-text">这次歪了</text>
          </view>
        </view>
        <view class="help-hint">※ 长按按钮可进入手动精细化记录模式</view>
      </block>
    </view>

    <!-- 洛克贝核心资产看板 -->
    <view class="premium-card wealth-panel tint-warm">
      <view class="panel-header">
        <text class="panel-title">洛克贝资产看板</text>
        <view class="mode-tag {{quickRecordMode?'active':''}}" bindtap="toggleQuickRecord">
          <view class="tag-dot"></view>
          <text>自动记录模式</text>
        </view>
      </view>
      
      <view class="init-form" wx:if="{{!wealthSet}}">
        <input class="premium-input" placeholder="输入初始洛克贝数量" type="number" value="{{coinInput}}" bindinput="onWealthInput" style="background:rgba(0,0,0,0.3); padding:24rpx; border-radius:16rpx; margin-bottom:20rpx; border:1rpx solid rgba(255,255,255,0.1);" />
        <view class="visual-btn-primary" bindtap="onSetWealth">初始化资产</view>
      </view>

      <view class="wealth-main" wx:if="{{wealthSet}}">
        <view class="wealth-label-group">
          <text class="label-main">当前剩余资产</text>
          <text class="label-sub">初始存量: {{initialWealth}}</text>
        </view>
        <view class="wealth-display">
          <view class="value-group">
            <text class="amount">{{totalWealth}}</text>
          </view>
        </view>
      </view>

      <view class="profit-summary" wx:if="{{wealthSet}}">
        <view class="summary-item">
          <text class="item-label">净盈亏变动</text>
          <text class="item-val {{accumulatedWealth>=0?'pos':'neg'}}">{{accumulatedWealth>=0?'+':''}}{{accumulatedWealth}}</text>
        </view>
        <view class="summary-divider"></view>
        <view class="summary-item">
          <text class="item-label">盈亏收益率</text>
          <text class="rate-tag {{accumulatedWealth>=0?'pos':'neg'}}">{{accumulatedWealth>=0?'+':''}}{{profitRate}}%</text>
        </view>
      </view>

      <view class="action-footer" wx:if="{{wealthSet}}">
        <view class="visual-btn-text" bindtap="onResetWealth">重置资产</view>
        <view class="capsule-btn" bindtap="openWealthAdjustModal">
          <text>💰 资产微调</text>
        </view>
      </view>
    </view>

    <!-- 咕噜球仓库与操作 -->
    <view class="premium-card ball-panel tint-purple">
      <view class="panel-header">
        <view class="panel-title">
          <text class="title-main">咕噜球仓库</text>
          <text class="title-sub">库存明细与采购</text>
        </view>
        <view class="capsule-btn danger" bindtap="onResetBalls">重置球库</view>
      </view>

      <view class="sub-tabs-premium">
        <view class="sub-tab-p {{specialTab==='buy'?'on':''}}" bindtap="onSpecialTab" data-t="buy">购买新球</view>
        <view class="sub-tab-p {{specialTab==='craft'?'on':''}}" bindtap="onSpecialTab" data-t="craft">合成新球</view>
      </view>

      <view class="inventory-stats">
        <view class="inv-item">
          <text class="inv-label">库存总数</text>
          <text class="inv-val">{{totalBallUsed}}</text>
        </view>
        <view class="inv-item">
          <text class="inv-label">历史消耗</text>
          <text class="inv-val used" style="color:#ff4757;">{{usedBallTotal}}</text>
        </view>
      </view>

      <!-- 快速采购/合成按钮区 -->
      <view class="quick-add-row">
        <picker class="premium-picker" bindchange="onSpecialBall" range="{{specialBalls}}" mode="selector">
          <view class="picker-inner">
            <text>{{specialBall}}</text>
            <text class="arrow" style="color:rgba(255,255,255,0.3); font-size:16rpx;">▼</text>
          </view>
        </picker>
        <input class="premium-count-input" placeholder="数量" type="number" value="{{specialCount}}" bindinput="onSpecialCount" />
        <view class="visual-btn-add" bindtap="onAddSpecial">入库</view>
      </view>

      <!-- 入库记录 -->
      <view class="special-history-list" wx:if="{{specialHistory.length > 0}}">
        <view class="history-item-mini" wx:for="{{specialHistory}}" wx:key="index">
          <text class="h-type {{item.type === '购买' ? 'buy' : 'craft'}}">{{item.type}}</text>
          <text class="h-name">{{item.ball}}</text>
          <text class="h-count">x{{item.count}}</text>
          <text class="h-cost" wx:if="{{item.cost > 0}}">💵{{item.cost}}</text>
          <text class="h-time">{{item.time}}</text>
        </view>
      </view>

      <!-- 咕噜球列表按钮化 -->
      <view class="ball-visual-list">
        <view wx:for="{{balls}}" wx:key="id" wx:if="{{item.count > 0}}">
          <view class="ball-item-card {{selectedBall===index?'selected':''}} {{pinnedBallIndex===index?'pinned':''}}" bindtap="onSelectBall" data-i="{{index}}">
            <view class="ball-icon-circle">{{item.icon}}</view>
            <view class="ball-info-main">
              <text class="ball-name-txt">{{item.name}}</text>
              <view class="ball-meta-tags">
                <text class="tag buy" wx:if="{{item.count - item.freeCount > 0}}">购 x{{item.count - item.freeCount}}</text>
                <text class="tag free" wx:if="{{item.freeCount > 0}}">赠 x{{item.freeCount}}</text>
              </view>
            </view>
            <view class="ball-count-display">
              <text class="num">{{item.count}}</text>
              <text class="unit">个</text>
            </view>
            <view class="pinned-indicator" wx:if="{{pinnedBallIndex===index}}">首选</view>
          </view>
        </view>
      </view>

      <!-- 选中后的操作区 -->
      <view class="selected-op-panel" wx:if="{{selectedBall!==null && balls[selectedBall].count > 0}}">
        <text class="op-label">使用 {{balls[selectedBall].name}}</text>
        <view class="op-input-group">
          <input class="op-input" type="number" value="{{selectedBallCount}}" bindinput="onBallCountInput" />
          <view class="visual-btn-confirm" bindtap="onUseBall">确认消耗</view>
        </view>
      </view>
      
      <view wx:if="{{!hasActiveBalls}}" class="empty-status">
        <text class="empty-icon">📦</text>
        <text>库存清空，请先采购咕噜球</text>
      </view>
    </view>

    <!-- 捕捉历史日志 -->
    <view class="premium-card history-panel">
      <view class="panel-header">
        <view class="panel-title">
          <text class="title-main">捕捉行动日志</text>
          <text class="title-sub">最近 20 条记录</text>
        </view>
        <view class="history-ops" style="display:flex; gap:12rpx;">
          <view class="capsule-btn warning" bindtap="onUndo" wx:if="{{history.length > 0}}">撤销</view>
          <view class="capsule-btn danger" bindtap="onClearHistory">清空</view>
        </view>
      </view>

      <view class="history-log-list">
        <view wx:for="{{history}}" wx:key="index" class="log-item">
          <view class="log-badge {{item.result.indexOf('成功')>=0?'ok':item.result==='歪了'?'miss':'other'}}">
            {{item.result.indexOf('成功')>=0?'成功':item.result==='歪了'?'歪了':'事件'}}
          </view>
          <view class="log-content">
            <text class="log-ball">{{item.balls}}</text>
            <text class="log-pet" wx:if="{{item.pet}}">目标: {{item.pet}}</text>
            <view class="log-details">
              <text class="log-cost" wx:if="{{item.cost>0}}">消耗: 💵{{item.cost}}</text>
              <text class="log-time">{{item.time}}</text>
            </view>
          </view>
        </view>
        <view wx:if="{{history.length===0}}" class="empty-status">
          <text class="empty-icon">📋</text>
          <text>暂无捕捉记录</text>
        </view>
      </view>
    </view>

    <view class="foot">更新：{{buildTime}}</view>
  </view>

  <!-- 球剩余记录弹窗 -->
  <view class="modal-mask" wx:if="{{showBallCheckModal}}" bindtap="closeBallCheckModal">
    <view class="modal-box" catchtap="preventClose">
      <view class="modal-header">
        <text class="modal-title">📝 记录球剩余数量</text>
        <text class="modal-close" catchtap="closeBallCheckModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="check-hint">每10次奇遇事件，请记录当前已购买/合成的球剩余数量</view>
        <view class="check-mode-tabs">
          <view class="check-mode-tab {{ballCheckMode === 'select' ? 'on' : ''}}" catchtap="onBallCheckModeSwitch" data-mode="select">已购球选择</view>
          <view class="check-mode-tab {{ballCheckMode === 'custom' ? 'on' : ''}}" catchtap="onBallCheckModeSwitch" data-mode="custom">自选记录</view>
        </view>
        <view class="form-group" wx:if="{{ballCheckMode === 'select'}}">
          <text class="form-label">球类型</text>
          <picker class="form-picker" range="{{ballCheckAllBalls}}" bindchange="onBallCheckBallChange">
            <view class="picker-text">{{ballCheckBall}} ▾</view>
          </picker>
        </view>
        <view class="form-group" wx:if="{{ballCheckMode === 'custom'}}">
          <text class="form-label">捕捉器名称</text>
          <input class="form-input" placeholder="输入捕捉器/球名称" value="{{ballCheckCustomName}}" bindinput="onBallCheckCustomInput" />
        </view>
        <view class="form-group">
          <text class="form-label">剩余数量</text>
          <input class="form-input" type="number" placeholder="输入剩余数量" value="{{ballCheckCount}}" bindinput="onBallCheckCountInput" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-cancel" catchtap="closeBallCheckModal">跳过</button>
        <button class="modal-save" catchtap="onBallCheckConfirm">记录</button>
      </view>
    </view>
  </view>

  <!-- 出异色/歪了球使用弹窗 -->
  <view class="modal-mask" wx:if="{{showResultBallModal}}" bindtap="closeResultBallModal">
    <view class="modal-box" catchtap="preventClose">
      <view class="modal-header">
        <text class="modal-title">{{resultType === 'success' ? '✨ 捕获成功' : '😵 歪了'}} - 记录使用球</text>
        <text class="modal-close" catchtap="closeResultBallModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="check-hint">请确认本次捕捉后的球剩余数量</view>
        <view class="form-group">
          <text class="form-label">球类型</text>
          <picker class="form-picker" range="{{resultBallList}}" bindchange="onResultBallChange">
            <view class="picker-text">{{resultBall}} ▾</view>
          </picker>
        </view>
        <view class="form-group">
          <text class="form-label">剩余数量</text>
          <input class="form-input" type="number" placeholder="输入剩余球数量" value="{{resultBallCount}}" bindinput="onResultBallCountInput" />
        </view>
        <view class="form-group">
          <text class="form-label">回顾洛克贝（正数盈利，负数亏损）</text>
          <input class="form-input" type="number" placeholder="输入洛克贝数量（可正可负）" value="{{resultGainInput}}" bindinput="onResultGainInput" />
        </view>
        <view class="form-group">
          <text class="form-label">备注</text>
          <input class="form-input" placeholder="输入备注信息（选填）" value="{{resultRemark}}" bindinput="onResultRemarkInput" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-cancel" catchtap="closeResultBallModal">取消</button>
        <button class="modal-save" catchtap="onResultBallConfirm">确认记录</button>
      </view>
    </view>
  </view>

  <!-- 资产微调弹窗 -->
  <view class="modal-mask" wx:if="{{showWealthAdjustModal}}" bindtap="closeWealthAdjustModal">
    <view class="modal-box" catchtap="preventClose">
      <view class="modal-header">
        <text class="modal-title">💰 资产微调</text>
        <text class="modal-close" catchtap="closeWealthAdjustModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="check-mode-tabs">
          <view class="check-mode-tab {{adjustType === 'add' ? 'on' : ''}}" catchtap="onAdjustTypeSwitch" data-type="add">增加资产</view>
          <view class="check-mode-tab {{adjustType === 'sub' ? 'on' : ''}}" catchtap="onAdjustTypeSwitch" data-type="sub">减少资产</view>
        </view>
        <view class="form-group">
          <text class="form-label">调整金额</text>
          <input class="form-input" type="number" placeholder="输入调整金额" value="{{adjustAmount}}" bindinput="onAdjustAmountInput" />
        </view>
        <view class="form-group">
          <text class="form-label">备注</text>
          <input class="form-input" placeholder="例如：任务获得、掉线补偿" value="{{adjustRemark}}" bindinput="onAdjustRemarkInput" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-cancel" catchtap="closeWealthAdjustModal">取消</button>
        <button class="modal-save" catchtap="onConfirmAdjustWealth">确认调整</button>
      </view>
    </view>
  </view>

  <dock current="catch" />
</view>