<view class="page">
  <!-- 马戏团粒子特效 -->
  <view class="circus-overlay" wx:if="{{showCircusParticles}}">
    <view class="circus-particle p1">🎪</view>
    <view class="circus-particle p2">✨</view>
    <view class="circus-particle p3">🌟</view>
    <view class="circus-particle p4">🎉</view>
    <view class="circus-particle p5">🎊</view>
    <view class="circus-particle p6">⭐</view>
    <view class="circus-particle p7">🎪</view>
    <view class="circus-particle p8">✨</view>
    <view class="circus-particle p9">🌟</view>
    <view class="circus-particle p10">🎉</view>
    <view class="circus-particle p11">🎊</view>
    <view class="circus-particle p12">⭐</view>
    <view class="circus-glow"></view>
  </view>
  <view class="container">
    <!-- 异色统计 -->
    <view class="card">
      <view class="card-title">异色统计 <text class="clear-link" bindtap="onClearEncounter">清除</text></view>
      <view wx:if="{{!canStartCapture}}" class="setup-hint">
        <text class="setup-icon">🎮</text>
        <text class="setup-text">请先设置初始洛克贝并购买/合成咕噜球后开始统计</text>
      </view>
      <block wx:if="{{canStartCapture}}">
      <view class="encounter-stats">
        <view class="enc-item enc-carnival"><text class="enc-num">{{carnivalCount}}</text><text class="enc-label">狂欢时刻</text></view>
        <view class="enc-item enc-luckybox"><text class="enc-num">{{luckyBoxCount}}</text><text class="enc-label">惊喜幸运盒</text></view>
        <view class="enc-item enc-total"><text class="enc-num">{{carnivalCount+luckyBoxCount}}</text><text class="enc-label">触发奇遇事件次数</text></view>
      </view>

      <view class="pity-box">
        <view class="pity-header">
          <text class="pity-title">保底进度</text>
          <text class="pity-val">{{pityCount}}/80</text>
        </view>
        <view class="particle-bar">
          <view class="particle-track">
            <view class="particle-fill" style="width: {{pityCount / 80 * 100}}%">
              <view class="particle-glow"></view>
              <view class="particle-spark spark-1" wx:if="{{pityCount > 20}}"></view>
              <view class="particle-spark spark-2" wx:if="{{pityCount > 40}}"></view>
              <view class="particle-spark spark-3" wx:if="{{pityCount > 60}}"></view>
              <view class="particle-spark spark-4" wx:if="{{pityCount > 70}}"></view>
            </view>
            <view class="particle-markers">
              <view class="marker" style="left: 50%"><text class="marker-text">40</text></view>
              <view class="marker" style="left: 87.5%"><text class="marker-text">70</text></view>
            </view>
          </view>
        </view>
        <view class="pity-hint-row">
          <text class="pity-emoji">{{pityEmoji}}</text>
          <text class="pity-hint">{{pityHint}}</text>
        </view>
      </view>

      <view class="action-grid">
        <view class="action-btn primary" bindtap="onAddLuckyBox" bindlongpress="onLuckyBoxLongPress">
          <text class="action-icon">🎁</text>
          <text class="action-text">幸运盒 +1</text>
        </view>
        <view class="action-btn primary" bindtap="onAddCarnival" bindlongpress="onCarnivalLongPress">
          <text class="action-icon">🌟</text>
          <text class="action-text">狂欢 +1</text>
        </view>
        <view class="action-btn success" bindtap="onResult" data-r="success">
          <text class="action-icon">✅</text>
          <text class="action-text">出异色</text>
        </view>
        <view class="action-btn danger" bindtap="onResult" data-r="miss">
          <text class="action-icon">😵</text>
          <text class="action-text">歪了</text>
        </view>
      </view>
        <text class="result-hint">数据仅供参考，以游戏内实际为准</text>
      </block>
    </view>

    <!-- 洛克贝记录 -->
    <view class="card">
      <view class="card-title">洛克贝记录</view>
      <view class="coin-row">
        <text class="coin-label">初始值</text>
        <text class="coin-val">💵{{initialWealth}}</text>
      </view>
      <view class="coin-input-row">
        <input class="coin-input" placeholder="输入初始洛克贝" type="number" value="{{coinInput}}" bindinput="onWealthInput" disabled="{{wealthSet}}" />
        <view class="coin-btn {{wealthSet?'disabled':''}}" bindtap="onSetWealth">设置</view>
      </view>
      <view class="reset-row" wx:if="{{wealthSet}}">
        <text class="reset-link" bindtap="onResetWealth">撤销</text>
      </view>
      <view class="coin-row total-row">
        <text class="coin-label">累计洛克贝</text>
        <text class="coin-val {{accumulatedWealth>=0?'':'negative'}}">💵{{accumulatedWealth}}</text>
      </view>
      <view class="coin-row final-row">
        <text class="coin-label">当前洛克贝</text>
        <text class="coin-val total">💵{{totalWealth}}</text>
      </view>
    </view>

    <!-- 特殊事件统计 -->
    <view class="card">
      <view class="card-title">特殊事件统计</view>
      <view class="sub-tabs">
        <view class="sub-tab {{specialTab==='buy'?'on':''}}" bindtap="onSpecialTab" data-t="buy">购买球</view>
        <view class="sub-tab {{specialTab==='craft'?'on':''}}" bindtap="onSpecialTab" data-t="craft">合成球</view>
      </view>
      <view class="ball-total-row">
        <text class="ball-total-label">剩余球总数</text>
        <text class="ball-total-val">{{totalBallUsed}}</text>
      </view>
      <view class="ball-total-row">
        <text class="ball-total-label">使用球总数</text>
        <text class="ball-total-val">{{usedBallTotal}}</text>
      </view>
      <view class="special-row">
        <picker class="special-picker" bindchange="onSpecialBall" range="{{specialBalls}}" mode="selector">
          <view class="picker-content">
            <text class="picker-text">{{specialBall}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
        <input class="special-count" placeholder="数量" type="number" value="{{specialCount}}" bindinput="onSpecialCount" />
        <view class="special-btn" bindtap="onAddSpecial">确定</view>
      </view>
      <view class="history-row" wx:for="{{specialHistory}}" wx:key="index">
        <view class="hbadge">{{item.type}}</view>
        <text class="hname">{{item.ball}}</text>
        <text class="hcount">x{{item.count}}</text>
        <text class="hcost" wx:if="{{item.cost>0}}">💵{{item.cost}}</text>
        <text class="hcost free" wx:elif="{{item.type==='合成'}}">💵免费</text>
        <text class="htime">{{item.time}}</text>
      </view>
      <view class="clear-row" wx:if="{{specialHistory.length>0}}">
        <text class="clear-link" bindtap="onClearSpecial">清空</text>
      </view>

      <!-- 咕噜球明细 -->
      <view class="ball-detail-title">咕噜球明细</view>
      <view wx:for="{{balls}}" wx:key="id" wx:if="{{item.count > 0}}">
        <view class="ball-row {{selectedBall===index?'selected':''}}" bindtap="onSelectBall" data-i="{{index}}">
          <view class="ball-dot" style="background:{{item.color}}"></view>
          <view class="ball-info">
            <text class="ball-name">{{item.name}}</text>
            <text class="ball-rate">{{item.rate}}</text>
          </view>
          <text class="ball-price" wx:if="{{item.price>0}}">💵{{item.price}}</text>
          <text class="ball-price free" wx:else>免费</text>
          <text class="ball-count">{{item.count}}</text>
        </view>
      </view>
      <view class="ball-use-row" wx:if="{{selectedBall!==null && balls[selectedBall].count > 0}}">
        <text class="ball-use-label">使用 {{balls[selectedBall].name}}</text>
        <input class="ball-use-input" placeholder="数量" type="number" value="{{selectedBallCount}}" bindinput="onBallCountInput" />
        <view class="ball-use-btn" bindtap="onUseBall">确认</view>
      </view>
      <view wx:if="{{!hasActiveBalls}}" class="empty-ball">
        <text class="empty-hint">暂无已购买/合成的球</text>
      </view>
    </view>

    <!-- 捕捉记录 -->
    <view class="card">
      <view class="card-title">捕捉记录 <text class="clear-link" bindtap="onClearHistory">清空</text></view>
      <view wx:for="{{history}}" wx:key="index" class="history-row">
        <view class="hbadge {{item.result.indexOf('成功')>=0?'ok':item.result==='歪了'?'miss':'pause'}}">{{item.result.indexOf('成功')>=0?'✅':item.result==='歪了'?'😵':'⏸️'}}</view>
        <text class="hname">{{item.balls}}</text>
        <text class="hpet" wx:if="{{item.pet}}">【{{item.pet}}】</text>
        <text class="hcount">x{{item.total}}</text>
        <text class="hcost" wx:if="{{item.cost>0}}">-💵{{item.cost}}</text>
        <text class="htime">{{item.time}}</text>
      </view>
      <text wx:if="{{history.length===0}}" class="empty">暂无记录</text>
    </view>

    <view class="foot">更新：{{buildTime}}</view>
  </view>

  <!-- 球剩余记录弹窗 -->
  <view class="modal-mask" wx:if="{{showBallCheckModal}}" bindtap="closeBallCheckModal">
    <view class="modal-box" catchtap="preventClose">
      <view class="modal-header">
        <text class="modal-title">📝 记录球剩余数量</text>
        <text class="modal-close" catchtap="closeBallCheckModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="check-hint">每10次奇遇事件，请记录当前已购买/合成的球剩余数量</view>
        <view class="check-mode-tabs">
          <view class="check-mode-tab {{ballCheckMode === 'select' ? 'on' : ''}}" catchtap="onBallCheckModeSwitch" data-mode="select">已购球选择</view>
          <view class="check-mode-tab {{ballCheckMode === 'custom' ? 'on' : ''}}" catchtap="onBallCheckModeSwitch" data-mode="custom">自选记录</view>
        </view>
        <view class="form-group" wx:if="{{ballCheckMode === 'select'}}">
          <text class="form-label">球类型</text>
          <picker class="form-picker" range="{{ballCheckAllBalls}}" bindchange="onBallCheckBallChange">
            <view class="picker-text">{{ballCheckBall}} ▾</view>
          </picker>
        </view>
        <view class="form-group" wx:if="{{ballCheckMode === 'custom'}}">
          <text class="form-label">捕捉器名称</text>
          <input class="form-input" placeholder="输入捕捉器/球名称" value="{{ballCheckCustomName}}" bindinput="onBallCheckCustomInput" />
        </view>
        <view class="form-group">
          <text class="form-label">剩余数量</text>
          <input class="form-input" type="number" placeholder="输入剩余数量" value="{{ballCheckCount}}" bindinput="onBallCheckCountInput" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-cancel" catchtap="closeBallCheckModal">跳过</button>
        <button class="modal-save" catchtap="onBallCheckConfirm">记录</button>
      </view>
    </view>
  </view>
</view>