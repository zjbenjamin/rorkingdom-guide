/* 活动页 */
.page { min-height: 100vh; padding-top: 88rpx; padding-bottom: 180rpx; background-color: #010314; background-image: radial-gradient(ellipse 80% 50% at 50% 20%, rgba(255,171,64,0.08) 0%, transparent 60%), linear-gradient(185deg, #020410 0%, #040c24 100%); animation: pageExpand 0.5s cubic-bezier(0.22, 0.61, 0.36, 1); padding-bottom: 180rpx; }
@keyframes pageExpand { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }

.tabs { display: flex; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 14rpx; margin-bottom: 20rpx; overflow: hidden; padding: 4rpx; gap: 4rpx; }
.tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 24rpx; color: rgba(255,255,255,0.4); border-radius: 10rpx; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); }
.tab.on { background: rgba(0,200,255,0.12); color: #00d4ff; font-weight: 700; box-shadow: 0 0 12rpx rgba(0,200,255,0.08); }

.act-list { display: flex; flex-direction: column; gap: 14rpx; }

.act-card { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 20rpx; padding: 24rpx; margin-bottom: 0; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.03) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 4rpx 16rpx rgba(0,0,0,0.12); opacity: 0; animation: cardEnter 0.45s cubic-bezier(0.22,0.61,0.36,1) forwards; }
.act-card:nth-child(1) { animation-delay: 0s; }
.act-card:nth-child(2) { animation-delay: 0.06s; }
.act-card:nth-child(3) { animation-delay: 0.12s; }
.act-card:nth-child(4) { animation-delay: 0.18s; }
.act-card:nth-child(5) { animation-delay: 0.24s; }
@keyframes cardEnter { from { opacity: 0; transform: translateY(16rpx) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }

.act-card.headline { background: rgba(255,80,80,0.06); border-color: rgba(255,80,80,0.15); box-shadow: 0 0 0 1rpx rgba(255,80,80,0.04) inset, 0 1rpx 0 rgba(255,120,120,0.04) inset, 0 4rpx 20rpx rgba(255,0,0,0.1); }
.headline-title { font-size: 34rpx !important; font-weight: 800 !important; }
.act-summary { font-size: 24rpx; color: rgba(255,255,255,0.7); display: block; margin-top: 12rpx; line-height: 1.6; white-space: pre-line; }

.section-title { display: flex; align-items: center; gap: 16rpx; margin: 28rpx 0 20rpx; }
.section-line { flex: 1; height: 1rpx; background: linear-gradient(90deg, transparent, rgba(0,200,255,0.2), transparent); }
.section-text { font-size: 24rpx; color: rgba(0,200,255,0.4); white-space: nowrap; }

.act-header { cursor: pointer; }
.act-badges { display: flex; gap: 10rpx; margin-bottom: 12rpx; flex-wrap: wrap; }
.badge { padding: 4rpx 14rpx; border-radius: 8rpx; font-size: 18rpx; color: #fff; font-weight: 600; }
.badge-go { background: rgba(0,255,115,0.2); color: #00ff73; }
.badge-top { background: rgba(255,71,87,0.2); color: #ff4757; }
.badge-soon { background: rgba(255,171,64,0.2); color: #ffab40; }
.badge-official { background: rgba(153,69,255,0.2); color: #9945ff; }
.badge-type { background: rgba(0,200,255,0.1); border: 1rpx solid rgba(0,200,255,0.2); }
.act-title { font-size: 30rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 10rpx; }

.act-body { padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.06); margin-top: 12rpx; animation: bodyExpand 0.35s cubic-bezier(0.22,0.61,0.36,1); overflow: hidden; }
@keyframes bodyExpand { from { opacity: 0; max-height: 0; padding-top: 0; } to { opacity: 1; max-height: 2000rpx; padding-top: 16rpx; } }

.act-desc { font-size: 24rpx; color: rgba(255,255,255,0.6); line-height: 1.7; display: block; margin-bottom: 16rpx; }
.act-footer { display: flex; justify-content: space-between; align-items: flex-end; }
.act-rewards { display: flex; flex-wrap: wrap; gap: 8rpx; }
.act-reward { padding: 4rpx 14rpx; background: rgba(0,200,255,0.08); border: 1rpx solid rgba(0,200,255,0.12); border-radius: 8rpx; font-size: 20rpx; color: rgba(0,200,255,0.7); }
.act-date { font-size: 20rpx; color: rgba(255,255,255,0.4); }
.empty { text-align: center; color: rgba(255,255,255,0.4); font-size: 24rpx; padding: 40rpx 0; }

/* 管理员栏 */
.admin-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; padding: 16rpx 20rpx; background: rgba(0,200,255,0.05); border: 1rpx solid rgba(0,200,255,0.12); border-radius: 14rpx; }
.admin-text { font-size: 24rpx; color: #00d4ff; font-weight: 600; }
.admin-btn { background: rgba(0,200,255,0.12); color: #00d4ff; border: 1rpx solid rgba(0,200,255,0.2); padding: 8rpx 24rpx; border-radius: 20rpx; font-size: 22rpx; transition: all 0.25s cubic-bezier(0.16,1,0.3,1); }
.admin-btn:active { transform: scale(0.95); }

.act-admin-btns { display: flex; gap: 16rpx; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.06); }
.act-admin-btn { padding: 8rpx 24rpx; border-radius: 10rpx; font-size: 22rpx; font-weight: 600; transition: all 0.25s cubic-bezier(0.16,1,0.3,1); }
.act-admin-btn.edit { background: rgba(0,200,255,0.08); color: #00d4ff; border: 1rpx solid rgba(0,200,255,0.2); }
.act-admin-btn.del { background: rgba(255,71,87,0.08); color: #ff4757; border: 1rpx solid rgba(255,71,87,0.2); }
.act-admin-btn:active { transform: scale(0.95); }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,2,12,0.75); backdrop-filter: blur(16rpx); z-index: 10000; display: flex; align-items: flex-end; animation: modalFadeIn 0.35s cubic-bezier(0.32,0.72,0,1); }
.modal-box { width: 100%; background: rgba(16,20,48,0.92); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 36rpx 36rpx 0 0; padding: 32rpx; max-height: 85vh; display: flex; flex-direction: column; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 -8rpx 40rpx rgba(0,0,0,0.3); }
@keyframes modalFadeIn { from { opacity: 0; transform: translateY(20rpx); } to { opacity: 1; transform: translateY(0); } }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; flex-shrink: 0; }
.modal-title { font-size: 30rpx; font-weight: 700; color: #00d4ff; }
.modal-close { font-size: 40rpx; color: rgba(255,255,255,0.4); padding: 8rpx; }
.modal-body { flex: 1; overflow-y: auto; }
.form-group { margin-bottom: 24rpx; }
.form-group.half { flex: 1; }
.form-row { display: flex; gap: 16rpx; }
.form-label { font-size: 24rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 10rpx; }
.form-input { width: 100%; min-height: 72rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 12rpx; padding: 18rpx 20rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); }
.form-input:focus { border-color: rgba(0,200,255,0.3); }
.form-textarea { width: 100%; height: 160rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 12rpx; padding: 18rpx 20rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; }
.form-picker { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 12rpx; padding: 18rpx 20rpx; }
.picker-text { font-size: 28rpx; color: #fff; }
.modal-footer { flex-shrink: 0; padding-top: 20rpx; padding-bottom: env(safe-area-inset-bottom); }
.modal-submit { background: rgba(0,200,255,0.12) !important; color: #00d4ff !important; border-radius: 40rpx !important; height: 88rpx !important; font-size: 28rpx !important; border: 1rpx solid rgba(0,200,255,0.2) !important; box-shadow: 0 0 0 1rpx rgba(0,200,255,0.05) inset, 0 1rpx 0 rgba(150,220,255,0.05) inset; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.modal-submit:active { transform: scale(0.97); }
.modal-submit[disabled] { opacity: 0.5; }
.image-section { margin-top: 8rpx; }
.image-preview { position: relative; width: 200rpx; height: 200rpx; border-radius: 12rpx; overflow: hidden; border: 1rpx solid rgba(255,255,255,0.1); }
.preview-img { width: 100%; height: 100%; }
.image-remove { position: absolute; top: 8rpx; right: 8rpx; width: 40rpx; height: 40rpx; background: rgba(255,71,87,0.9); color: #fff; font-size: 24rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.image-actions { display: flex; gap: 16rpx; }
.image-action-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 160rpx; height: 120rpx; background: rgba(255,255,255,0.03); border: 1rpx dashed rgba(255,255,255,0.15); border-radius: 12rpx; transition: all 0.3s cubic-bezier(0.16,1,0.3,1); }
.image-action-btn:active { background: rgba(0,200,255,0.06); }
.action-icon { font-size: 36rpx; margin-bottom: 8rpx; }
.action-text { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.act-image { width: 100%; border-radius: 12rpx; margin-bottom: 16rpx; }
.file-import { display: flex; align-items: center; gap: 8rpx; margin-top: 12rpx; padding: 12rpx 16rpx; background: rgba(0,200,255,0.04); border: 1rpx dashed rgba(0,200,255,0.2); border-radius: 10rpx; }

/* 订阅 */
.subscribe-card { padding: 20rpx 24rpx; margin-bottom: 16rpx; }
.subscribe-row { display: flex; align-items: center; justify-content: space-between; }
.subscribe-info { flex: 1; }
.subscribe-title { font-size: 28rpx; font-weight: 600; color: #fff; display: block; }
.subscribe-desc { font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; margin-top: 4rpx; }
.subscribe-right { flex-shrink: 0; }
.notify-counter { display: flex; align-items: center; gap: 12rpx; }
.counter-btn { width: 56rpx; height: 56rpx; background: rgba(0,200,255,0.1); border: 1rpx solid rgba(0,200,255,0.2); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; transition: all 0.25s cubic-bezier(0.16,1,0.3,1); box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); }
.counter-btn:active { transform: scale(0.88); background: rgba(0,200,255,0.18); }
.counter-plus { font-size: 36rpx; color: #00d4ff; font-weight: 300; line-height: 1; }
.counter-badge { min-width: 40rpx; height: 40rpx; background: rgba(0,180,255,0.15); border-radius: 20rpx; display: flex; align-items: center; justify-content: center; padding: 0 10rpx; border: 1rpx solid rgba(0,200,255,0.2); }
.counter-num { font-size: 22rpx; color: #00d4ff; font-weight: 700; }
