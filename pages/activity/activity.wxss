/* 活动页科技感样式 */
.tabs { display: flex; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 12rpx; margin-bottom: 20rpx; overflow: hidden; }
.tab { flex: 1; text-align: center; padding: 20rpx 0; font-size: 26rpx; color: rgba(255,255,255,0.5); }
.tab.on { background: linear-gradient(135deg, rgba(0,212,255,0.3), rgba(153,69,255,0.3)); color: #00d4ff; font-weight: 600; box-shadow: 0 0 12px rgba(0,212,255,0.2); }
.act-list { display: flex; flex-direction: column; gap: 16rpx; }

/* 置顶头条卡片 */
.act-card.headline { background: linear-gradient(145deg, rgba(255,71,87,0.15), rgba(153,69,255,0.15)); border: 1rpx solid rgba(255,71,87,0.3); box-shadow: 0 0 24px rgba(255,71,87,0.15); }
.headline-title { font-size: 34rpx !important; font-weight: 800 !important; }
.act-summary { font-size: 24rpx; color: rgba(255,255,255,0.7); display: block; margin-top: 12rpx; line-height: 1.6; white-space: pre-line; }

/* 分隔标题 */
.section-title { display: flex; align-items: center; gap: 16rpx; margin: 28rpx 0 20rpx; }
.section-line { flex: 1; height: 1rpx; background: linear-gradient(90deg, transparent, rgba(0,212,255,0.3), transparent); }
.section-text { font-size: 24rpx; color: rgba(0,212,255,0.5); white-space: nowrap; }

/* 活动卡片 */
.act-card { background: linear-gradient(145deg, rgba(20,25,60,0.9), rgba(15,18,45,0.95)); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 16rpx; padding: 24rpx; }
.act-header { cursor: pointer; }
.act-badges { display: flex; gap: 10rpx; margin-bottom: 12rpx; flex-wrap: wrap; }
.badge { padding: 4rpx 14rpx; border-radius: 8rpx; font-size: 18rpx; color: #fff; font-weight: 600; }
.badge-go { background: linear-gradient(135deg, #00e676, #00c853); }
.badge-top { background: linear-gradient(135deg, #ff4757, #cc3a48); box-shadow: 0 0 8px rgba(255,71,87,0.4); }
.badge-soon { background: linear-gradient(135deg, #ffab40, #ff9100); }
.badge-official { background: linear-gradient(135deg, #9945ff, #7c3aed); }
.badge-type { background: rgba(0,212,255,0.2); border: 1rpx solid rgba(0,212,255,0.3); }
.act-title { font-size: 30rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 10rpx; }
.expand-hint { font-size: 22rpx; color: rgba(0,212,255,0.4); margin-top: 6rpx; display: block; text-align: right; }
.act-body { padding-top: 16rpx; border-top: 1rpx solid rgba(0,212,255,0.08); margin-top: 12rpx; }
.act-desc { font-size: 24rpx; color: rgba(255,255,255,0.6); line-height: 1.7; display: block; margin-bottom: 16rpx; }
.act-footer { display: flex; justify-content: space-between; align-items: flex-end; }
.act-rewards { display: flex; flex-wrap: wrap; gap: 8rpx; }
.act-reward { padding: 4rpx 14rpx; background: rgba(0,212,255,0.1); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 8rpx; font-size: 20rpx; color: rgba(0,212,255,0.8); }
.act-date { font-size: 20rpx; color: rgba(255,255,255,0.3); }
.empty { text-align: center; color: rgba(255,255,255,0.3); font-size: 24rpx; padding: 40rpx 0; }

/* 管理员栏 */
.admin-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; padding: 16rpx 20rpx; background: rgba(0,212,255,0.1); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 12rpx; }
.admin-text { font-size: 24rpx; color: #00d4ff; font-weight: 600; }
.admin-btn { background: linear-gradient(135deg, #00d4ff, #9945ff); color: #fff; padding: 8rpx 24rpx; border-radius: 20rpx; font-size: 22rpx; }

/* 管理员按钮 */
.act-admin-btns { display: flex; gap: 16rpx; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid rgba(0,212,255,0.08); }
.act-admin-btn { padding: 8rpx 24rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: 600; }
.act-admin-btn.edit { background: rgba(0,212,255,0.15); color: #00d4ff; border: 1rpx solid rgba(0,212,255,0.3); }
.act-admin-btn.del { background: rgba(255,71,87,0.15); color: #ff4757; border: 1rpx solid rgba(255,71,87,0.3); }

/* 编辑弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 1000; display: flex; align-items: flex-end; }
.modal-box { width: 100%; background: linear-gradient(180deg, #1a1040, #0a0e27); border-radius: 24rpx 24rpx 0 0; padding: 32rpx; max-height: 85vh; display: flex; flex-direction: column; }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; flex-shrink: 0; }
.modal-title { font-size: 32rpx; font-weight: 700; color: #00d4ff; }
.modal-close { font-size: 36rpx; color: rgba(255,255,255,0.4); padding: 8rpx; }
.modal-body { flex: 1; overflow-y: auto; -webkit-overflow-scrolling: touch; }
.form-group { margin-bottom: 24rpx; }
.form-group.half { flex: 1; }
.form-row { display: flex; gap: 16rpx; }
.form-label { font-size: 26rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 12rpx; }
.form-input { width: 100%; min-height: 72rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 10rpx; padding: 18rpx 20rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; }
.form-textarea { width: 100%; height: 160rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 10rpx; padding: 18rpx 20rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; }
.form-picker { background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 10rpx; padding: 18rpx 20rpx; }
.picker-text { font-size: 28rpx; color: #fff; }
.modal-footer { flex-shrink: 0; padding-top: 20rpx; padding-bottom: env(safe-area-inset-bottom); }
.modal-submit { background: linear-gradient(135deg, #00d4ff, #9945ff) !important; color: #fff !important; border-radius: 40rpx !important; height: 88rpx !important; line-height: 88rpx !important; font-size: 28rpx !important; border: none !important; }
.image-section { margin-top: 8rpx; }
.image-preview { position: relative; width: 200rpx; height: 200rpx; border-radius: 12rpx; overflow: hidden; border: 1rpx solid rgba(0,212,255,0.2); }
.preview-img { width: 100%; height: 100%; }
.image-remove { position: absolute; top: 8rpx; right: 8rpx; width: 40rpx; height: 40rpx; background: rgba(255,71,87,0.9); color: #fff; font-size: 24rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.image-actions { display: flex; gap: 16rpx; }
.image-action-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 160rpx; height: 120rpx; background: rgba(0,0,0,0.3); border: 1rpx dashed rgba(0,212,255,0.3); border-radius: 12rpx; }
.action-icon { font-size: 36rpx; margin-bottom: 8rpx; }
.action-text { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.act-image { width: 100%; border-radius: 12rpx; margin-bottom: 16rpx; }
.file-import { display: flex; align-items: center; gap: 8rpx; margin-top: 12rpx; padding: 12rpx 16rpx; background: rgba(0,212,255,0.08); border: 1rpx dashed rgba(0,212,255,0.3); border-radius: 8rpx; }
.file-import-icon { font-size: 28rpx; }
.file-import-text { font-size: 22rpx; color: rgba(0,212,255,0.7); }
.modal-submit[disabled] { opacity: 0.5; }

/* 订阅 */
.subscribe-card { padding: 20rpx 24rpx; margin-bottom: 16rpx; }
.subscribe-row { display: flex; align-items: center; justify-content: space-between; }
.subscribe-info { flex: 1; }
.subscribe-title { font-size: 28rpx; font-weight: 600; color: #fff; display: block; }
.subscribe-desc { font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; margin-top: 4rpx; }
.subscribe-right { flex-shrink: 0; }
.notify-counter { display: flex; align-items: center; gap: 12rpx; }
.counter-btn { width: 56rpx; height: 56rpx; background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(153,69,255,0.15)); border: 1rpx solid rgba(0,212,255,0.3); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; transition: all 0.2s; position: relative; overflow: hidden; }
.counter-btn::after { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); transition: left 0.4s; }
.counter-btn:active { transform: scale(0.92); background: linear-gradient(135deg, rgba(0,212,255,0.3), rgba(153,69,255,0.3)); }
.counter-btn:active::after { left: 100%; }
.counter-plus { font-size: 36rpx; color: #00d4ff; font-weight: 300; line-height: 1; }
.counter-badge { min-width: 40rpx; height: 40rpx; background: linear-gradient(135deg, #00d4ff, #9945ff); border-radius: 20rpx; display: flex; align-items: center; justify-content: center; padding: 0 10rpx; box-shadow: 0 4px 12px rgba(0,212,255,0.3); }
.counter-num { font-size: 22rpx; color: #fff; font-weight: 700; }
