.tabs { display: flex; background: #ffffff; border-radius: 12rpx; margin-bottom: 16rpx; overflow: hidden; }
.tab { flex: 1; text-align: center; padding: 20rpx 0; font-size: 26rpx; color: #666; }
.tab.on { background: #ff6900; color: #fff; font-weight: 600; }
.act-list { display: flex; flex-direction: column; gap: 12rpx; }
.act-card { background: #ffffff; border-radius: 16rpx; padding: 20rpx; box-shadow: 0 1px 6px rgba(0,0,0,0.04); }
.act-header { cursor: pointer; }
.act-badges { display: flex; gap: 8rpx; margin-bottom: 8rpx; }
.badge { padding: 3rpx 12rpx; border-radius: 8rpx; font-size: 18rpx; color: #fff; font-weight: 500; }
.badge-go { background: #34c759; }
.badge-top { background: #ff3b30; }
.badge-official { background: #5856d6; }
.act-title { font-size: 30rpx; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 8rpx; }
.expand-hint { font-size: 22rpx; color: #999; margin-top: 4rpx; display: block; }
.expand-hint.up { transform: rotate(90deg); }
.act-body { padding-top: 12rpx; border-top: 1px solid #f0f0f0; margin-top: 8rpx; }
.act-desc { font-size: 24rpx; color: #666; line-height: 1.6; display: block; margin-bottom: 12rpx; }
.act-footer { display: flex; justify-content: space-between; align-items: flex-end; }
.act-rewards { display: flex; flex-wrap: wrap; gap: 6rpx; }
.act-reward { padding: 3rpx 12rpx; background: #f5f7fa; border-radius: 8rpx; font-size: 20rpx; color: #666; }
.act-date { font-size: 20rpx; color: #999; }
