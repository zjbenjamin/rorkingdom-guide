<view class="page">
  <view class="container">
    <view class="admin-bar" wx:if="{{isAdmin}}">
      <text class="admin-text">管理员模式</text>
      <view class="admin-btn" bindtap="onAddActivity"><text>+ 新增活动</text></view>
    </view>
    <view class="tabs">
      <view class="tab {{status===item?'on':''}}" wx:for="{{statuses}}" wx:key="*this" bindtap="onStatus" data-s="{{item}}">{{item}}</view>
    </view>
    <view class="act-list">
      <view class="act-card headline" wx:for="{{filtered}}" wx:key="id" wx:if="{{item.status==='置顶'}}">
        <view class="act-header" bindtap="onExpand" data-id="{{item.id}}">
          <view class="act-badges">
            <view class="badge badge-top">📌 置顶头条</view>
            <view class="badge badge-official" wx:if="{{item.type==='官方权威信息'}}">官方权威信息</view>
          </view>
          <text class="act-title headline-title">{{item.title}}</text>
          <text class="act-summary" wx:if="{{item.richContent && item.richContent.length > 0}}">{{item.content}}</text>
          <block wx:if="{{item.richContent && item.richContent.length > 0}}">
            <view class="act-rich-content">
              <block wx:for="{{item.richContent}}" wx:for-item="block" wx:key="index">
                <view wx:if="{{block.type === 'music'}}" class="rich-music-block {{currentPlayUrl === block.url && isPlaying ? 'playing' : ''}}" catchtap="playSong" data-url="{{block.url}}" data-name="{{block.name || '推荐单曲'}}">
                  <text class="music-icon {{currentPlayUrl === block.url && isPlaying ? 'rotating' : ''}}">🎵</text>
                  <view class="music-info">
                    <text class="music-name">{{block.name || '推荐单曲'}}</text>
                    <text class="music-url">{{block.url}}</text>
                  </view>
                  <text class="music-play-btn">{{currentPlayUrl === block.url && isPlaying ? '暂停' : '点我听歌'}}</text>
                </view>
                <view wx:elif="{{block.type === 'iframe'}}" class="rich-iframe-block">
                  <text class="iframe-icon">🌐</text>
                  <view class="iframe-info">
                    <text class="iframe-name">{{block.name || '外部网页'}}</text>
                    <text class="iframe-url">{{block.url}}</text>
                  </view>
                  <view class="iframe-actions">
                    <view class="iframe-btn open" catchtap="openIframe" data-url="{{block.url}}">打开</view>
                    <view class="iframe-btn copy" catchtap="copyIframe" data-url="{{block.url}}">复制</view>
                  </view>
                </view>
                <view wx:elif="{{block.type === 'quote'}}" class="rich-quote-block">
                  <text class="quote-text">{{block.content}}</text>
                </view>
                <view wx:else class="rich-text-block" style="font-size:{{block.size}}rpx;color:{{block.color}};font-weight:{{block.weight || 'normal'}};font-style:{{block.style || 'normal'}};">
                  {{block.content}}
                </view>
              </block>
            </view>
          </block>
          <text class="act-summary" wx:else>{{item.desc}}</text>
        </view>
        <view class="act-source" wx:if="{{item.source}}">来源：{{item.source}}</view>
        <view class="act-footer" wx:if="{{item.rewards.length > 0 || item.start}}">
          <view class="act-rewards" wx:if="{{item.rewards.length > 0}}">
            <text class="act-reward" wx:for="{{item.rewards}}" wx:for-item="r" wx:key="*this">{{r}}</text>
          </view>
          <text class="act-date" wx:if="{{item.start}}">{{item.start}}~{{item.end}}</text>
        </view>
        <view class="act-admin-btns" wx:if="{{isAdmin}}">
          <view class="act-admin-btn edit" catchtap="onEditActivity" data-item="{{item}}">编辑</view>
          <view class="act-admin-btn del" catchtap="onDeleteActivity" data-item="{{item}}" wx:if="{{item.isCloud}}">删除</view>
        </view>
      </view>
    </view>
    <view class="section-title" wx:if="{{status==='全部'}}">
      <text class="section-line"></text>
      <text class="section-text">其他活动</text>
      <text class="section-line"></text>
    </view>
    <view class="act-list">
      <view class="act-card" wx:for="{{filtered}}" wx:key="id" wx:if="{{item.status!=='置顶'}}">
        <view class="act-badges">
          <view class="badge badge-go" wx:if="{{item.status==='进行中'}}">进行中</view>
          <view class="badge badge-soon" wx:if="{{item.status==='即将开始'}}">即将开始</view>
          <view class="badge badge-type" wx:if="{{item.type}}">{{item.type}}</view>
        </view>
        <text class="act-title">{{item.title}}</text>
        <image class="act-image" wx:if="{{item.image}}" src="{{item.image}}" mode="widthFix" />
        <text class="act-desc" wx:if="{{item.richContent && item.richContent.length > 0}}">{{item.content}}</text>
        <block wx:if="{{item.richContent && item.richContent.length > 0}}">
          <view class="act-rich-content">
            <block wx:for="{{item.richContent}}" wx:for-item="block" wx:key="index">
              <view wx:if="{{block.type === 'music'}}" class="rich-music-block {{currentPlayUrl === block.url && isPlaying ? 'playing' : ''}}" catchtap="playSong" data-url="{{block.url}}" data-name="{{block.name || '推荐单曲'}}">
                <text class="music-icon {{currentPlayUrl === block.url && isPlaying ? 'rotating' : ''}}">🎵</text>
                <view class="music-info">
                  <text class="music-name">{{block.name || '推荐单曲'}}</text>
                  <text class="music-url">{{block.url}}</text>
                </view>
                <text class="music-play-btn">{{currentPlayUrl === block.url && isPlaying ? '暂停' : '点我听歌'}}</text>
              </view>
              <view wx:elif="{{block.type === 'iframe'}}" class="rich-iframe-block">
                <text class="iframe-icon">🌐</text>
                <view class="iframe-info">
                  <text class="iframe-name">{{block.name || '外部网页'}}</text>
                  <text class="iframe-url">{{block.url}}</text>
                </view>
                <view class="iframe-actions">
                  <view class="iframe-btn open" catchtap="openIframe" data-url="{{block.url}}">打开</view>
                  <view class="iframe-btn copy" catchtap="copyIframe" data-url="{{block.url}}">复制</view>
                </view>
              </view>
              <view wx:elif="{{block.type === 'quote'}}" class="rich-quote-block">
                <text class="quote-text">{{block.content}}</text>
              </view>
              <view wx:else class="rich-text-block" style="font-size:{{block.size}}rpx;color:{{block.color}};font-weight:{{block.weight || 'normal'}};font-style:{{block.style || 'normal'}};">
                {{block.content}}
              </view>
            </block>
          </view>
        </block>
        <text class="act-desc" wx:else>{{item.desc}}</text>
        <view class="act-source" wx:if="{{item.source}}">来源：{{item.source}}</view>
        <view class="act-footer" wx:if="{{item.rewards.length > 0 || item.start}}">
          <view class="act-rewards" wx:if="{{item.rewards.length > 0}}">
            <text class="act-reward" wx:for="{{item.rewards}}" wx:for-item="r" wx:key="*this">{{r}}</text>
          </view>
          <text class="act-date" wx:if="{{item.start}}">{{item.start}}~{{item.end}}</text>
        </view>
        <view class="act-admin-btns" wx:if="{{isAdmin}}">
          <view class="act-admin-btn edit" catchtap="onEditActivity" data-item="{{item}}">编辑</view>
          <view class="act-admin-btn del" catchtap="onDeleteActivity" data-item="{{item}}" wx:if="{{item.isCloud}}">删除</view>
        </view>
      </view>
    </view>
    <view class="empty" wx:if="{{filtered.length===0}}">暂无活动</view>
  </view>

  <!-- 编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showEditModal}}" bindtap="onCloseModal">
    <view class="modal-box" catchtap="preventClose">
      <view class="modal-header">
        <text class="modal-title">{{editingItem ? '编辑活动' : '新增活动'}}</text>
        <text class="modal-close" bindtap="onCloseModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="form-group">
          <text class="form-label">标题</text>
          <input class="form-input" placeholder="活动标题" value="{{editTitle}}" bindinput="onEditInput" maxlength="50" />
        </view>
        <view class="form-group">
          <text class="form-label">类型</text>
          <input class="form-input" placeholder="如：限时活动、日常活动" value="{{editType}}" bindinput="onTypeInput" />
        </view>
        <view class="form-group">
          <text class="form-label">状态</text>
          <picker class="form-picker" range="{{['进行中','即将开始','置顶']}}" bindchange="onStatusChange">
            <text class="picker-text">{{editStatus}} ▾</text>
          </picker>
        </view>
        <view class="form-group">
          <text class="form-label">描述</text>
          <textarea class="form-textarea" placeholder="活动描述..." value="{{editDesc}}" bindinput="onDescInput" maxlength="500" cursor-spacing="120" />
          <view class="file-import" catchtap="importActivityFile">
            <text class="file-import-icon">📄</text>
            <text class="file-import-text">导入文件（XML/DOCX）</text>
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">奖励（每行一个）</text>
          <textarea class="form-textarea" placeholder="洛克贝x1000&#10;经验果x5" value="{{editRewards}}" bindinput="onRewardsInput" maxlength="200" cursor-spacing="120" />
        </view>
        <view class="form-row">
          <view class="form-group half">
            <text class="form-label">开始日期</text>
            <input class="form-input" placeholder="2026-01-01" value="{{editStart}}" bindinput="onStartInput" />
          </view>
          <view class="form-group half">
            <text class="form-label">结束日期</text>
            <input class="form-input" placeholder="2026-01-31" value="{{editEnd}}" bindinput="onEndInput" />
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">图片（可选）</text>
          <view class="image-section">
            <view class="image-preview" wx:if="{{editImage}}" catchtap="previewEditImage">
              <image class="preview-img" src="{{editImage}}" mode="aspectFill" />
              <view class="image-remove" catchtap="removeEditImage">✕</view>
            </view>
            <view class="image-actions" wx:if="{{!editImage}}">
              <view class="image-action-btn" catchtap="chooseEditImage">
                <text class="action-icon">📷</text>
                <text class="action-text">相册</text>
              </view>
              <view class="image-action-btn" catchtap="inputEditImageUrl">
                <text class="action-icon">🔗</text>
                <text class="action-text">链接</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="modal-submit" bindtap="onSubmitActivity" disabled="{{submitting}}">{{submitting ? '提交中...' : (editingItem ? '更新' : '发布')}}</button>
      </view>
    </view>
  </view>

  <dock current="activity" />
</view>
