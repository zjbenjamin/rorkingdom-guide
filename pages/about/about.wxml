<view class="page">
  <view class="container">
    <view class="about-header">
      <view class="header-glow"></view>
      <text class="about-icon">🏰</text>
      <text class="about-name">{{aboutData.appName || '洛手助手BENJAMIN'}}</text>
      <text class="about-ver">{{aboutData.version || '版本 v1.0.7A'}}</text>
      <view class="header-tags">
        <view class="header-tag">离线可用</view>
        <view class="header-tag">数据安全</view>
        <view class="header-tag">免费使用</view>
      </view>
    </view>

    <view class="card" wx:if="{{isAdmin}}">
      <view class="admin-tip">
        <text class="admin-tip-icon">⚙</text>
        <text class="admin-tip-text">管理模式：点击下方卡片内容可编辑</text>
      </view>
    </view>

    <view class="card">
      <view class="card-title">开发者信息</view>
      <view class="dev-row">
        <view class="avatar-wrap">
          <image class="dev-avatar" src="{{aboutData.devAvatar || '/images/avatar.jpg'}}" mode="aspectFill"></image>
          <view class="verified-badge">V</view>
        </view>
        <view class="dev-info" bindtap="onEdit" data-field="devName" data-value="{{aboutData.devName || '浙里本杰明'}}">
          <text class="dev-name">{{aboutData.devName || '浙里本杰明'}}</text>
          <text class="dev-role">项目开发者</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">我的洛克王国UID</view>
      <view class="uid-row" bindtap="onEdit" data-field="uid" data-value="{{aboutData.uid || '476200'}}">
        <view class="uid-info">
          <text class="uid-label">玩家UID</text>

          <text class="uid-val">{{aboutData.uid || '476200'}}</text>
        </view>
        <view class="uid-copy" catchtap="copyUID">复制</view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">免费福利</view>
      <view class="gift-list">
        <view class="gift-item" wx:for="{{aboutData.gifts}}" wx:key="index">
          <text class="gift-icon">🎁</text>
          <text class="gift-text">{{item}}</text>
          <view class="gift-del" catchtap="deleteGift" data-idx="{{index}}" wx:if="{{isAdmin}}">✕</view>
        </view>
        <view class="gift-add" catchtap="addGift" wx:if="{{isAdmin}}">
          <text class="gift-add-icon">+</text>
          <text class="gift-add-text">添加福利</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">音乐/应用平台</view>
      <view class="platform-list">
        <view class="platform-item" wx:for="{{aboutData.platforms}}" wx:key="index" bindtap="copyPlatformUrl" data-item="{{item}}">
          <text class="platform-icon">🎵</text>
          <view class="platform-info">
            <text class="platform-name">{{item.name}}</text>
            <text class="platform-url">{{item.url}}</text>
          </view>
          <view class="platform-copy">复制</view>
          <view class="platform-del" catchtap="deletePlatform" data-idx="{{index}}" wx:if="{{isAdmin}}">✕</view>
        </view>
        <view class="platform-add" catchtap="addPlatform" wx:if="{{isAdmin}}">
          <text class="platform-add-icon">+</text>
          <text class="platform-add-text">添加平台外链</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">联系方式</view>
      <view class="contact-row" bindtap="copyEmail">
        <text class="contact-icon">📧</text>
        <view class="contact-info" catchtap="onEdit" data-field="contact" data-value="{{aboutData.contact || 'flyzccboard@yeah.net'}}">
          <text class="contact-label">邮箱</text>
          <text class="contact-val">{{aboutData.contact || 'flyzccboard@yeah.net'}}</text>
        </view>
        <view class="contact-copy">复制</view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">数据来源</view>
      <view class="source-list">
        <view class="source-item">
          <text class="source-icon">📖</text>
          <text class="source-text">精灵图鉴：洛克王国手游WIKI（CC BY-NC-SA 4.0）</text>
        </view>
        <view class="source-item">
          <text class="source-icon">🎒</text>
          <text class="source-text">道具图鉴：洛克王国手游WIKI（CC BY-NC-SA 4.0）</text>
        </view>
        <view class="source-item">
          <text class="source-icon">🥚</text>
          <text class="source-text">蛋组数据：洛克王国WIKI（CC BY-NC-SA 4.0）</text>
        </view>
        <view class="source-item">
          <text class="source-icon">📅</text>
          <text class="source-text">活动动态：洛克王国世界微信公众号</text>
        </view>
        <view class="source-item">
          <text class="source-icon">🎯</text>
          <text class="source-text">捕捉规则：洛克王国世界官方客服</text>
        </view>
        <view class="source-item">
          <text class="source-icon">🎨</text>
          <text class="source-text">页面图片：设计师手绘与开放社区授权视觉素材</text>
        </view>
        <view class="source-item">
          <text class="source-icon">🔗</text>
          <text class="source-text">数据来源：https://wiki.biligame.com/rocom</text>
        </view>
        <view class="source-item">
          <text class="source-icon">📋</text>
          <text class="source-text">授权协议：CC BY-NC-SA 4.0</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">等级系统</view>
      <view class="level-rules">
        <view class="level-rule-item">
          <text class="level-rule-icon">🐣</text>
          <view class="level-rule-info">
            <text class="level-rule-name">Lv.1 小洛克</text>
            <text class="level-rule-desc">初始等级</text>
          </view>
        </view>
        <view class="level-rule-item">
          <text class="level-rule-icon">🎓</text>
          <view class="level-rule-info">
            <text class="level-rule-name">Lv.2 见习魔法生</text>
            <text class="level-rule-desc">累计登录3天</text>
          </view>
        </view>
        <view class="level-rule-item">
          <text class="level-rule-icon">✨</text>
          <view class="level-rule-info">
            <text class="level-rule-name">Lv.4 高级魔法生</text>
            <text class="level-rule-desc">累计登录15天</text>
          </view>
        </view>
        <view class="level-rule-item">
          <text class="level-rule-icon">📖</text>
          <view class="level-rule-info">
            <text class="level-rule-name">Lv.6 精灵研究员</text>
            <text class="level-rule-desc">累计登录60天</text>
          </view>
        </view>
        <view class="level-rule-item">
          <text class="level-rule-icon">🔮</text>
          <view class="level-rule-info">
            <text class="level-rule-name">Lv.8 魔法大师</text>
            <text class="level-rule-desc">累计登录120天</text>
          </view>
        </view>
        <view class="level-rule-item">
          <text class="level-rule-icon">🏰</text>
          <view class="level-rule-info">
            <text class="level-rule-name">Lv.10 王国守护者</text>
            <text class="level-rule-desc">累计登录365天</text>
          </view>
        </view>
        <view class="level-rule-item">
          <text class="level-rule-icon">👑</text>
          <view class="level-rule-info">
            <text class="level-rule-name">Lv.15 至尊洛克</text>
            <text class="level-rule-desc">累计登录365天+UID+250次捕捉</text>
          </view>
        </view>
        <view class="level-rule-tip">
          <text class="level-rule-tip-icon">💡</text>
          <text class="level-rule-tip-text">额外加成：设置洛克王国UID +1级，每50次捕捉 +1级（最高20级）</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">特别鸣谢</view>
      <view class="thanks-list">
        <view class="thanks-item">
          <text class="thanks-icon">🏆</text>
          <text class="thanks-text">洛克王国手游WIKI团队</text>
        </view>
        <view class="thanks-item">
          <text class="thanks-icon">💎</text>
          <text class="thanks-text">洛克王国世界官方客服</text>
        </view>
        <view class="thanks-item">
          <text class="thanks-icon">🌟</text>
          <text class="thanks-text">洛克王国世界微信公众号</text>
        </view>
        <view class="thanks-item">
          <text class="thanks-icon">🎮</text>
          <text class="thanks-text">腾讯魔方工作室群</text>
        </view>
        <view class="thanks-item">
          <text class="thanks-icon">❤️</text>
          <text class="thanks-text">所有支持本小程序的玩家</text>
        </view>
        <view class="thanks-item">
          <text class="thanks-icon">🤖</text>
          <text class="thanks-text">先进开发工具与开源技术社区参考参与修补维护</text>
        </view>
        <view class="thanks-item">
          <text class="thanks-icon">☁️</text>
          <text class="thanks-text">第三方合规图床提供静态资源云托管服务</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">隐私政策</view>
      <view class="privacy-list">
        <view class="privacy-item">
          <text class="privacy-icon">💾</text>
          <text class="privacy-text">本地存储：偏好设置、捕捉统计等数据仅保存在设备本地</text>
        </view>
        <view class="privacy-item">
          <text class="privacy-icon">🔒</text>
          <text class="privacy-text">无第三方SDK：不存在数据共享和行为追踪</text>
        </view>
        <view class="privacy-item">
          <text class="privacy-icon">📤</text>
          <text class="privacy-text">分享功能：仅用于转发页面内容</text>
        </view>
        <view class="privacy-item">
          <text class="privacy-icon">🔐</text>
          <text class="privacy-text">登录数据：3天自动过期，到期自动清除本地授权</text>
        </view>
      </view>
    </view>

    <view class="card">
      <view class="card-title">免责声明</view>
      <view class="disclaimer-list">
        <text class="disclaimer">1. 本应用为非官方攻略工具，与腾讯魔方工作室群无关</text>
        <text class="disclaimer">2. 游戏数据仅供参考，以游戏内实际数据为准</text>
        <text class="disclaimer">3. 仅供学习交流使用，请勿用于商业用途</text>
      </view>
    </view>

    <view class="card">
      <view class="card-title">更新日志</view>
      <view class="changelog-list">
        <view class="changelog-item">
          <view class="changelog-ver">全新版 v1.0.1 体验版</view>
          <view class="changelog-date">2026-06-18</view>
          <view class="changelog-content">
            <text class="changelog-add">新增：全局 iOS 26 Liquid Glass 设计语言，毛玻璃卡片、多层光影、悬浮Dock导航栏</text>
            <text class="changelog-add">新增：编辑器支持多平台视频链接解析与内嵌播放，表格/图文混排/字体样式全面升级</text>
            <text class="changelog-add">新增：远行商人商品补货订阅、批量编辑、全量替换、XLSX文件导入</text>
            <text class="changelog-add">新增：远行商人上架弹窗「仅更新内容」按钮，可随时更新不推送通知</text>
            <text class="changelog-add">新增：订阅消息推送系统，管理后台统一开关与测试推送</text>
            <text class="changelog-opt">优化：后台编辑器触控体验全面升级，工具栏按钮放大、编辑器高度提升</text>
            <text class="changelog-opt">优化：首页公告栏播放器独立样式，音乐/视频卡片区分展示</text>
            <text class="changelog-opt">优化：远行商人模块重构，序列化公共函数提取、管理员精确查询、错误处理增强</text>
            <text class="changelog-fix">修复：首页公告栏管理员检测时序问题、通知跳转页面硬编码、文件导入列对齐错位</text>
            <text class="changelog-opt">合规：隐私政策及用户协议同步更新至最新法律法规要求</text>
          </view>
        </view>
      </view>
    </view>

    <view class="about-foot">
      <text class="foot-text">© 2026 洛手助手BENJAMIN</text>
      <text class="foot-text" wx:if="{{aboutData.icp}}">{{aboutData.icp}}</text>
    </view>

    <view class="feedback-btn" bindtap="onFeedback">
      <text class="feedback-icon">💬</text>
      <text class="feedback-text">意见反馈</text>
    </view>
  </view>

  <!-- 编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal">
    <view class="modal-box" catchtap="preventClose">
      <view class="modal-header">
        <text class="modal-title">{{editModalTitle}}</text>
        <text class="modal-close" bindtap="closeModal">✕</text>
      </view>
      <block wx:if="{{editMode === 'addPlatform'}}">
        <input class="modal-input" placeholder="请输入平台名称（如：QQ音乐）" value="{{platformName}}" bindinput="onPlatformNameInput" maxlength="50" />
        <input class="modal-input" placeholder="请输入平台外链 URL" value="{{platformUrl}}" bindinput="onPlatformUrlInput" maxlength="200" />
      </block>
      <textarea class="modal-textarea" wx:elif="{{editingField === 'changelogContent'}}" placeholder="请输入多行更新日志..." value="{{editValue}}" bindinput="onEditInput" maxlength="1000" />
      <input class="modal-input" wx:else placeholder="请输入内容" value="{{editValue}}" bindinput="onEditInput" maxlength="50" />
      <view class="modal-footer">
        <button class="modal-cancel" bindtap="closeModal">取消</button>
        <button class="modal-save" bindtap="saveEdit" disabled="{{submitting}}">{{submitting ? '保存中...' : '保存'}}</button>
      </view>
    </view>
  </view>
  <dock current="about" />
</view>