.about-header { background: linear-gradient(135deg, #ff6900, #ff8533); border-radius: 20rpx; padding: 40rpx; text-align: center; margin-bottom: 16rpx; }
.about-icon { font-size: 64rpx; display: block; margin-bottom: 12rpx; }
.about-name { font-size: 36rpx; font-weight: 700; color: #fff; display: block; }
.about-ver { font-size: 22rpx; color: rgba(255,255,255,0.8); }
.card { background: #ffffff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 1px 8px rgba(0,0,0,0.04); }
.card-title { font-size: 30rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 16rpx; padding-left: 12rpx; border-left: 4px solid #ff6900; }
.dev-row { display: flex; align-items: center; background: #f8f9fa; border-radius: 12rpx; padding: 16rpx; }
.dev-avatar { width: 60rpx; height: 60rpx; background: linear-gradient(135deg, #ff6900, #ff8533); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 26rpx; font-weight: 600; margin-right: 12rpx; }
.dev-info { flex: 1; }
.dev-name { font-size: 28rpx; font-weight: 600; color: #1a1a1a; display: block; }
.dev-role { font-size: 20rpx; color: #ff6900; }
.contact-row { display: flex; align-items: center; background: #f8f9fa; border-radius: 12rpx; padding: 16rpx; }
.contact-icon { font-size: 28rpx; margin-right: 12rpx; }
.contact-info { flex: 1; }
.contact-label { font-size: 20rpx; color: #999; display: block; }
.contact-val { font-size: 26rpx; color: #1a1a1a; font-weight: 600; }
.contact-copy { font-size: 20rpx; color: #ff6900; padding: 4rpx 12rpx; background: #fff5f0; border-radius: 6rpx; }
.source { font-size: 22rpx; color: #999; display: block; margin-bottom: 6rpx; }
.privacy-item { font-size: 24rpx; color: #666; display: block; margin-bottom: 8rpx; line-height: 1.5; }
.disclaimer { font-size: 24rpx; color: #666; display: block; margin-bottom: 4rpx; }
.action-btns { display: flex; gap: 12rpx; margin-bottom: 16rpx; }
.btn-copy { flex: 1; background: #f5f7fa; color: #333; border: none; border-radius: 40rpx; height: 80rpx; line-height: 80rpx; font-size: 28rpx; }
.btn-copy::after { border: none; }
.btn-share { flex: 1; background: #ff6900; color: #fff; border: none; border-radius: 40rpx; height: 80rpx; line-height: 80rpx; font-size: 28rpx; }
.btn-share::after { border: none; }
.about-foot { text-align: center; }
.foot-text { font-size: 20rpx; color: #999; display: block; margin-bottom: 4rpx; }
