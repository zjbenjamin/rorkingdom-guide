/* 关于页 Liquid Glass */
.page { min-height: 100vh; background-color: #010314; background-image: radial-gradient(ellipse 70% 40% at 50% 20%, rgba(180,100,255,0.08) 0%, transparent 50%), linear-gradient(185deg, #020410 0%, #040c24 100%); animation: pageExpand 0.5s cubic-bezier(0.22, 0.61, 0.36, 1); padding-bottom: calc(180rpx + constant(safe-area-inset-bottom)); padding-bottom: calc(180rpx + env(safe-area-inset-bottom)); }
@keyframes pageExpand { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
@keyframes btn-shine { 0% { left: -100%; } 50%, 100% { left: 100%; } }

.about-header { background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(255, 255, 255, 0.08); border-radius: 32rpx; padding: 60rpx 40rpx; text-align: center; margin-bottom: 24rpx; position: relative; overflow: hidden; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 8rpx 32rpx rgba(0,0,0,0.2); }
.header-glow { position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(0,212,255,0.1) 0%, transparent 50%); }
.about-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; position: relative; z-index: 1; }
.about-name { font-size: 44rpx; font-weight: 900; color: #fff; display: block; text-shadow: 0 0 20px rgba(0,212,255,0.4); position: relative; z-index: 1; }
.about-ver { font-size: 24rpx; color: rgba(255,255,255,0.6); display: block; margin-bottom: 20rpx; position: relative; z-index: 1; }
.header-tags { display: flex; justify-content: center; gap: 12rpx; position: relative; z-index: 1; }
.header-tag { padding: 6rpx 16rpx; background: rgba(0,212,255,0.15); border: 1rpx solid rgba(0,212,255,0.3); border-radius: 20rpx; font-size: 20rpx; color: rgba(0,212,255,0.8); }

/* 通用卡片 */
.card { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.03) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset; }
.card-title { font-size: 28rpx; font-weight: 700; color: #00d4ff; margin-bottom: 20rpx; padding-left: 16rpx; border-left: 4rpx solid #00d4ff; text-transform: uppercase; letter-spacing: 2rpx; }

/* 开发者 */
.dev-row { display: flex; align-items: center; background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(255, 255, 255, 0.08); border-radius: 20rpx; padding: 24rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); }
.avatar-wrap { position: relative; width: 72rpx; height: 72rpx; margin-right: 20rpx; flex-shrink: 0; }
.dev-avatar { width: 100%; height: 100%; border-radius: 50%; display: block; box-shadow: 0 0 16px rgba(0,212,255,0.3); background: linear-gradient(135deg, #00d4ff, #9945ff); }
.verified-badge { position: absolute; bottom: -4rpx; right: -4rpx; width: 28rpx; height: 28rpx; background: linear-gradient(135deg, #ffab40, #ffeb3b); border-radius: 50%; border: 4rpx solid #0a0e27; display: flex; align-items: center; justify-content: center; color: #000; font-size: 18rpx; font-weight: 900; z-index: 2; box-shadow: 0 0 8px rgba(255,171,64,0.5); font-family: sans-serif; font-style: italic; }
.dev-info { flex: 1; }
.dev-name { font-size: 30rpx; font-weight: 600; color: #fff; display: block; }
.dev-role { font-size: 22rpx; color: #00d4ff; margin-top: 4rpx; display: block; }

/* UID */
.uid-row { display: flex; align-items: center; justify-content: space-between; background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 16rpx; padding: 24rpx; }
.uid-info { flex: 1; }
.uid-label { font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 8rpx; }
.uid-val { font-size: 48rpx; font-weight: 800; color: #00d4ff; text-shadow: 0 0 16px rgba(0,212,255,0.5); }
.uid-copy { padding: 14rpx 28rpx; background: rgba(0,200,255,0.12); border-radius: 12rpx; font-size: 26rpx; font-weight: 600; color: #00d4ff; border: 1rpx solid rgba(0,200,255,0.2); text-align: center; }

/* 联系方式 */
.contact-row { display: flex; align-items: center; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 16rpx; padding: 20rpx; }
.contact-icon { font-size: 32rpx; margin-right: 16rpx; }
.contact-info { flex: 1; }
.contact-label { font-size: 22rpx; color: rgba(255,255,255,0.4); display: block; }
.contact-val { font-size: 26rpx; color: #fff; font-weight: 600; display: block; }
.contact-copy { font-size: 22rpx; color: #00d4ff; padding: 10rpx 20rpx; background: rgba(0,200,255,0.1); border-radius: 8rpx; font-weight: 500; border: 1rpx solid rgba(0,200,255,0.15); text-align: center; }

/* 平台 */
.platform-copy { font-size: 22rpx; color: #00d4ff; padding: 6rpx 16rpx; background: rgba(0,200,255,0.1); border-radius: 8rpx; font-weight: 500; flex-shrink: 0; margin-left: 12rpx; text-align: center; border: 1rpx solid rgba(0,200,255,0.15); }
.platform-del { font-size: 24rpx; color: rgba(255,71,87,0.8); padding: 8rpx 16rpx; flex-shrink: 0; margin-left: 12rpx; }
.platform-add { display: flex; align-items: center; justify-content: center; gap: 8rpx; padding: 16rpx 0; margin-top: 12rpx; border: 1rpx dashed rgba(0,212,255,0.3); border-radius: 12rpx; }
.platform-add-icon { font-size: 28rpx; color: #00d4ff; }
.platform-add-text { font-size: 24rpx; color: rgba(0,212,255,0.6); }
.platform-list { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 16rpx; padding: 20rpx; }
.platform-item { display: flex; align-items: center; gap: 12rpx; padding: 14rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.platform-item:last-child { border: none; }
.platform-icon { font-size: 32rpx; }
.platform-info { flex: 1; }
.platform-name { font-size: 24rpx; color: rgba(255,255,255,0.8); font-weight: 600; display: block; }
.platform-url { font-size: 20rpx; color: rgba(255,255,255,0.4); display: block; margin-top: 2rpx; }

/* 福利 */
.gift-list { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,171,64,0.15); border-radius: 16rpx; padding: 20rpx; }
.gift-item { display: flex; align-items: center; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,171,64,0.1); }
.gift-item:last-child { border: none; }
.gift-icon { font-size: 32rpx; }
.gift-text { font-size: 26rpx; color: #ffab40; font-weight: 500; flex: 1; }
.gift-del { font-size: 24rpx; color: rgba(255,71,87,0.8); padding: 8rpx; }
.gift-add { display: flex; align-items: center; justify-content: center; gap: 8rpx; padding: 16rpx 0; margin-top: 12rpx; border: 1rpx dashed rgba(255,171,64,0.3); border-radius: 12rpx; }
.gift-add-icon { font-size: 28rpx; color: #ffab40; }
.gift-add-text { font-size: 24rpx; color: rgba(255,171,64,0.6); }

/* 数据来源 */
.source-list { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 16rpx; padding: 20rpx; }
.source-item { display: flex; align-items: flex-start; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.source-item:last-child { border: none; }
.source-icon { font-size: 24rpx; margin-top: 2rpx; }
.source-text { font-size: 22rpx; color: rgba(255,255,255,0.6); line-height: 1.5; }

/* 鸣谢 */
.thanks-list { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(153,69,255,0.15); border-radius: 16rpx; padding: 20rpx; }
.thanks-item { display: flex; align-items: center; gap: 12rpx; padding: 14rpx 0; border-bottom: 1rpx solid rgba(153,69,255,0.1); }
.thanks-item:last-child { border: none; }
.thanks-icon { font-size: 28rpx; }
.thanks-text { font-size: 24rpx; color: rgba(255,255,255,0.7); font-weight: 500; }

/* 隐私 */
.privacy-list { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 16rpx; padding: 20rpx; }
.privacy-item { display: flex; align-items: flex-start; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.privacy-item:last-child { border: none; }
.privacy-icon { font-size: 24rpx; margin-top: 2rpx; }
.privacy-text { font-size: 22rpx; color: rgba(255,255,255,0.6); line-height: 1.5; }

/* 免责 */
.disclaimer-list { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 16rpx; padding: 20rpx; }
.disclaimer { font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 10rpx; line-height: 1.6; }
.disclaimer:last-child { margin-bottom: 0; }

/* 页脚 */
.about-foot { text-align: center; padding: 20rpx 0; }
.foot-text { font-size: 20rpx; color: rgba(0,212,255,0.3); display: block; margin-bottom: 6rpx; }

/* 更新日志 */
.changelog-item { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.changelog-item:last-child { margin-bottom: 0; }
.changelog-ver { font-size: 30rpx; font-weight: 700; color: #00d4ff; display: inline-block; }
.changelog-date { font-size: 22rpx; color: rgba(255,255,255,0.4); display: inline-block; margin-left: 16rpx; }
.changelog-content { margin-top: 16rpx; }
.changelog-add { font-size: 24rpx; color: #34c759; display: block; line-height: 1.8; }
.changelog-opt { font-size: 24rpx; color: rgba(255,255,255,0.7); display: block; line-height: 1.8; }
.changelog-fix { font-size: 24rpx; color: #ffab40; display: block; line-height: 1.8; }
.changelog-del { font-size: 24rpx; color: #ff4757; display: block; line-height: 1.8; }

/* 等级系统 */
.level-rules { background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 16rpx; padding: 20rpx; }
.level-rule-item { display: flex; align-items: center; gap: 16rpx; padding: 16rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.06); }
.level-rule-item:last-child { border: none; }
.level-rule-icon { font-size: 36rpx; width: 48rpx; text-align: center; }
.level-rule-info { flex: 1; }
.level-rule-name { font-size: 26rpx; color: rgba(255,255,255,0.8); font-weight: 600; display: block; }
.level-rule-desc { font-size: 22rpx; color: rgba(255,255,255,0.4); display: block; margin-top: 4rpx; }
.level-rule-tip { display: flex; align-items: flex-start; gap: 10rpx; padding: 16rpx; background: rgba(0,200,255,0.06); border: 1rpx dashed rgba(0,200,255,0.15); border-radius: 12rpx; margin-top: 12rpx; }
.level-rule-tip-icon { font-size: 24rpx; flex-shrink: 0; margin-top: 2rpx; }
.level-rule-tip-text { font-size: 22rpx; color: rgba(0,200,255,0.7); line-height: 1.6; }

/* 意见反馈 */
.feedback-btn { display: flex; align-items: center; justify-content: center; gap: 12rpx; margin-top: 32rpx; padding: 28rpx; background: rgba(0,200,255,0.08); border: 1rpx solid rgba(0,200,255,0.15); border-radius: 20rpx; position: relative; overflow: hidden; }
.feedback-btn::after { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(0,200,255,0.1), transparent); animation: btn-shine 3s ease-in-out infinite; }
.feedback-icon { font-size: 32rpx; position: relative; z-index: 1; }
.feedback-text { font-size: 28rpx; color: #00d4ff; font-weight: 600; position: relative; z-index: 1; }

/* 管理员提示 */
.admin-tip { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 20rpx; background: rgba(255,171,64,0.08); border: 1rpx solid rgba(255,171,64,0.15); border-radius: 12rpx; }
.admin-tip-icon { font-size: 28rpx; }
.admin-tip-text { font-size: 24rpx; color: #ffab40; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,2,12,0.75); backdrop-filter: blur(16rpx); z-index: 10000; display: flex; align-items: center; justify-content: center; }
.modal-box { width: 82%; background: rgba(16,20,48,0.92); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 36rpx; padding: 32rpx; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset; }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.modal-title { font-size: 30rpx; font-weight: 700; color: #00d4ff; }
.modal-close { font-size: 40rpx; color: rgba(255,255,255,0.4); padding: 8rpx; }
.modal-input { width: 100%; min-height: 80rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; margin-bottom: 24rpx; }
.modal-textarea { width: 100%; height: 350rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; margin-bottom: 24rpx; }
.modal-footer { display: flex; gap: 16rpx; }
.modal-cancel { flex: 1; background: rgba(255,255,255,0.08) !important; color: rgba(255,255,255,0.7) !important; border-radius: 16rpx !important; height: 80rpx !important; font-size: 26rpx !important; border: 1rpx solid rgba(255,255,255,0.08) !important; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.modal-cancel::after { border: none; }
.modal-save { flex: 1; background: rgba(0,200,255,0.12) !important; color: #00d4ff !important; border-radius: 16rpx !important; height: 80rpx !important; font-size: 26rpx !important; border: 1rpx solid rgba(0,200,255,0.2) !important; box-shadow: 0 0 0 1rpx rgba(0,200,255,0.05) inset, 0 1rpx 0 rgba(150,220,255,0.05) inset; display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.modal-save::after { border: none; }
.modal-save[disabled] { opacity: 0.5; }
