/* 关于页科技感样式 */
.page { min-height: 100vh; background-color: #010314; background-image: radial-gradient(ellipse 70% 40% at 50% 20%, rgba(180,100,255,0.08) 0%, transparent 50%), linear-gradient(185deg, #020410 0%, #040c24 100%); animation: pageExpand 0.5s cubic-bezier(0.22, 0.61, 0.36, 1); padding-bottom: 180rpx; }
@keyframes pageExpand { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
.about-header { background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(255, 255, 255, 0.08); border-radius: 32rpx; padding: 60rpx 40rpx; text-align: center; margin-bottom: 24rpx; position: relative; overflow: hidden; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 8rpx 32rpx rgba(0,0,0,0.2); }
.header-glow { position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(0,212,255,0.1) 0%, transparent 50%); }
.about-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; position: relative; z-index: 1; }
.about-name { font-size: 44rpx; font-weight: 900; color: #fff; display: block; text-shadow: 0 0 20px rgba(0,212,255,0.4); position: relative; z-index: 1; }
.about-ver { font-size: 24rpx; color: rgba(255,255,255,0.6); display: block; margin-bottom: 20rpx; position: relative; z-index: 1; }
.header-tags { display: flex; justify-content: center; gap: 12rpx; position: relative; z-index: 1; }
.header-tag { padding: 6rpx 16rpx; background: rgba(0,212,255,0.15); border: 1rpx solid rgba(0,212,255,0.3); border-radius: 20rpx; font-size: 20rpx; color: rgba(0,212,255,0.8); }
.card-title { font-size: 28rpx; font-weight: 700; color: #00d4ff; margin-bottom: 20rpx; padding-left: 16rpx; border-left: 4rpx solid #00d4ff; text-transform: uppercase; letter-spacing: 2rpx; }
.dev-row { display: flex; align-items: center; background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(255, 255, 255, 0.08); border-radius: 20rpx; padding: 24rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); }
.avatar-wrap { position: relative; width: 72rpx; height: 72rpx; margin-right: 20rpx; flex-shrink: 0; }
.dev-avatar { width: 100%; height: 100%; border-radius: 50%; display: block; box-shadow: 0 0 16px rgba(0,212,255,0.3); background: linear-gradient(135deg, #00d4ff, #9945ff); }
.verified-badge { position: absolute; bottom: -4rpx; right: -4rpx; width: 28rpx; height: 28rpx; background: linear-gradient(135deg, #ffab40, #ffeb3b); border-radius: 50%; border: 4rpx solid #0a0e27; display: flex; align-items: center; justify-content: center; color: #000; font-size: 18rpx; font-weight: 900; z-index: 2; box-shadow: 0 0 8px rgba(255,171,64,0.5); font-family: sans-serif; font-style: italic; }
.dev-info { flex: 1; }
.dev-name { font-size: 30rpx; font-weight: 600; color: #fff; display: block; }
.dev-role { font-size: 22rpx; color: #00d4ff; margin-top: 4rpx; display: block; }
.uid-row { display: flex; align-items: center; justify-content: space-between; background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 16rpx; padding: 24rpx; }
.uid-info { flex: 1; }
.uid-label { font-size: 22rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 8rpx; }
.uid-val { font-size: 48rpx; font-weight: 800; color: #00d4ff; text-shadow: 0 0 16px rgba(0,212,255,0.5); }
.uid-copy { padding: 14rpx 28rpx; background: rgba(0,200,255,0.12); border-radius: 12rpx; font-size: 26rpx; font-weight: 600; color: #00d4ff; border: 1rpx solid rgba(0,200,255,0.2); text-align: center; }
.contact-copy { font-size: 22rpx; color: #00d4ff; padding: 10rpx 20rpx; background: rgba(0,200,255,0.1); border-radius: 8rpx; font-weight: 500; border: 1rpx solid rgba(0,200,255,0.15); text-align: center; }
.platform-copy { font-size: 22rpx; color: #00d4ff; padding: 6rpx 16rpx; background: rgba(0,200,255,0.1); border-radius: 8rpx; font-weight: 500; flex-shrink: 0; margin-left: 12rpx; text-align: center; border: 1rpx solid rgba(0,200,255,0.15); }
.platform-del { font-size: 24rpx; color: rgba(255,71,87,0.8); padding: 8rpx 16rpx; flex-shrink: 0; margin-left: 12rpx; }
.platform-add { display: flex; align-items: center; justify-content: center; gap: 8rpx; padding: 16rpx 0; margin-top: 12rpx; border: 1rpx dashed rgba(0,212,255,0.3); border-radius: 12rpx; }
.platform-add-icon { font-size: 28rpx; color: #00d4ff; }
.platform-add-text { font-size: 24rpx; color: rgba(0,212,255,0.6); }
