.banner-card { border-radius: 24rpx; overflow: hidden; margin-bottom: 20rpx; position: relative; }
.banner-bg { background: linear-gradient(135deg, #5b6abf 0%, #7c4dff 30%, #651fff 60%, #4a148c 100%); border-radius: 24rpx; padding: 32rpx 28rpx 24rpx; position: relative; overflow: hidden; min-height: 360rpx; }
.banner-deco-1 { position: absolute; top: -40rpx; right: -20rpx; width: 200rpx; height: 200rpx; background: rgba(255,255,255,0.08); border-radius: 50%; }
.banner-deco-2 { position: absolute; bottom: 20rpx; left: -30rpx; width: 150rpx; height: 150rpx; background: rgba(255,255,255,0.05); border-radius: 50%; }
.banner-deco-3 { position: absolute; top: 60rpx; right: 40rpx; width: 80rpx; height: 80rpx; background: rgba(255,255,255,0.06); border-radius: 50%; }
.banner-content { position: relative; z-index: 2; }
.banner-sub { font-size: 22rpx; color: rgba(255,255,255,0.8); display: block; margin-bottom: 8rpx; letter-spacing: 2rpx; }
.banner-title { font-size: 52rpx; font-weight: 900; color: #fff; display: block; line-height: 1.1; text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2); }
.banner-title-2 { font-size: 52rpx; font-weight: 900; color: #ffd54f; display: block; line-height: 1.1; margin-bottom: 12rpx; text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2); }
.banner-desc { font-size: 22rpx; color: rgba(255,255,255,0.85); display: block; margin-bottom: 20rpx; }
.banner-tags { display: flex; gap: 12rpx; flex-wrap: wrap; }
.banner-tag { display: flex; align-items: center; gap: 6rpx; background: rgba(255,255,255,0.2); border-radius: 20rpx; padding: 8rpx 16rpx; }
.tag-icon { font-size: 24rpx; }
.tag-text { font-size: 20rpx; color: #fff; }
.banner-bottom { position: absolute; bottom: 24rpx; left: 28rpx; right: 28rpx; z-index: 2; display: flex; justify-content: space-between; align-items: center; }
.banner-slogan { font-size: 24rpx; font-weight: 600; color: #fff; }
.banner-slogan-sub { font-size: 20rpx; color: rgba(255,255,255,0.7); }
