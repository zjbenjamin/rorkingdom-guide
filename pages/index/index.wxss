/* 首页样式 */
.page { min-height: 100vh; background-color: #010314; background-image: radial-gradient(ellipse 80% 50% at 20% 15%, rgba(0,180,255,0.1) 0%, transparent 60%), radial-gradient(ellipse 60% 40% at 80% 35%, rgba(100,60,255,0.06) 0%, transparent 50%), linear-gradient(185deg, #020410 0%, #040c24 100%); animation: pageExpand 0.5s cubic-bezier(0.22, 0.61, 0.36, 1); padding-bottom: calc(180rpx + constant(safe-area-inset-bottom)); padding-bottom: calc(180rpx + env(safe-area-inset-bottom)); }
@keyframes pageExpand { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
.stitle-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.announce-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.06); margin-top: 16rpx; }
.sub-counter-btn { width: 48rpx; height: 48rpx; background: rgba(0,200,255,0.1); border: 1rpx solid rgba(0,200,255,0.2); border-radius: 14rpx; display: flex; align-items: center; justify-content: center; transition: all 0.25s cubic-bezier(0.16,1,0.3,1); box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); }
.sub-counter-btn:active { transform: scale(0.88); background: rgba(0,200,255,0.18); }
.sub-counter-badge { min-width: 32rpx; height: 32rpx; background: rgba(0,180,255,0.15); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; padding: 0 8rpx; border: 1rpx solid rgba(0,200,255,0.2); }
.sub-counter-num { font-size: 20rpx; color: #fff; font-weight: 700; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,2,12,0.8); backdrop-filter: blur(24rpx); -webkit-backdrop-filter: blur(24rpx); z-index: 10000; display: flex; align-items: flex-end; animation: modalFadeIn 0.4s cubic-bezier(0.16,1,0.3,1); }
@keyframes modalFadeIn { from { opacity: 0; transform: translateY(100rpx); } to { opacity: 1; transform: translateY(0); } }
.modal-box { width: 100%; background: rgba(16, 20, 48, 0.95); border-top: 1rpx solid rgba(255, 255, 255, 0.12); border-radius: 40rpx 40rpx 0 0; padding: 40rpx 32rpx; max-height: 90vh; display: flex; flex-direction: column; box-shadow: 0 -12rpx 60rpx rgba(0,0,0,0.6), inset 0 1rpx 0 rgba(255,255,255,0.06); box-sizing: border-box; }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40rpx; flex-shrink: 0; }
.modal-title-box { display: flex; align-items: center; gap: 16rpx; }
.modal-title-line { width: 6rpx; height: 32rpx; background: linear-gradient(to bottom, #00d4ff, #9945ff); border-radius: 3rpx; }
.modal-title { font-size: 34rpx; font-weight: 700; color: #fff; letter-spacing: 1rpx; }
.modal-close { font-size: 40rpx; color: rgba(255,255,255,0.3); padding: 10rpx; transition: color 0.2s; }
.modal-close:active { color: #ff4757; }
.modal-body { overflow-y: auto; -webkit-overflow-scrolling: touch; padding-right: 4rpx; }

/* Banner 编辑特有样式 */
.banner-preview-label { font-size: 22rpx; color: rgba(255,255,255,0.4); margin-bottom: 16rpx; display: block; text-transform: uppercase; letter-spacing: 2rpx; }
.banner-preview { width: 100%; height: 280rpx; border-radius: 20rpx; overflow: hidden; margin-bottom: 40rpx; border: 1rpx solid rgba(0,212,255,0.2); position: relative; background: rgba(0,0,0,0.4); }
.banner-preview.empty { display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: rgba(255,255,255,0.2); border: 1rpx dashed rgba(255,255,255,0.15); }
.preview-img { width: 100%; height: 100%; }
.preview-mask { position: absolute; bottom: 0; left: 0; right: 0; height: 60rpx; background: linear-gradient(to top, rgba(0,0,0,0.6), transparent); display: flex; align-items: center; padding: 0 20rpx; }
.preview-text { font-size: 18rpx; color: rgba(0,212,255,0.8); font-weight: 700; letter-spacing: 4rpx; }

.banner-form { background: rgba(255,255,255,0.03); border-radius: 24rpx; padding: 24rpx; border: 1rpx solid rgba(255,255,255,0.05); }
.form-label { font-size: 24rpx; color: rgba(255,255,255,0.6); margin-bottom: 24rpx; font-weight: 600; display: block; }
.banner-actions { display: flex; flex-direction: column; gap: 24rpx; }

.image-action-btn { background: rgba(0,212,255,0.08); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 16rpx; padding: 32rpx; display: flex; flex-direction: column; align-items: center; transition: all 0.2s cubic-bezier(0.16,1,0.3,1); }
.image-action-btn:active { background: rgba(0,212,255,0.15); transform: scale(0.98); border-color: rgba(0,212,255,0.4); }
.action-icon { font-size: 48rpx; margin-bottom: 12rpx; }
.action-text { font-size: 28rpx; color: #fff; font-weight: 600; }
.action-hint { font-size: 20rpx; color: rgba(0,212,255,0.5); margin-top: 6rpx; }

.form-divider { display: flex; align-items: center; gap: 20rpx; padding: 8rpx 0; }
.divider-line { flex: 1; height: 1rpx; background: rgba(255,255,255,0.08); }
.divider-text { font-size: 20rpx; color: rgba(255,255,255,0.2); text-transform: uppercase; letter-spacing: 2rpx; }

.input-group { position: relative; display: flex; align-items: center; }
.input-icon { position: absolute; left: 24rpx; font-size: 32rpx; z-index: 2; color: rgba(255,255,255,0.4); }
.banner-input { width: 100%; height: 96rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(255,255,255,0.12); border-radius: 16rpx; padding: 0 24rpx 0 72rpx; font-size: 26rpx; color: #fff; transition: all 0.3s; box-sizing: border-box; }
.banner-input:focus { border-color: rgba(0,212,255,0.5); background: rgba(0,0,0,0.5); }

.modal-footer { display: flex; gap: 24rpx; flex-shrink: 0; padding-top: 40rpx; padding-bottom: calc(20rpx + constant(safe-area-inset-bottom)); padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); }
.modal-cancel { flex: 1; background: rgba(255, 255, 255, 0.08) !important; color: rgba(255,255,255,0.5) !important; border-radius: 20rpx !important; height: 100rpx !important; font-size: 28rpx !important; border: 1rpx solid rgba(255,255,255,0.1) !important; transition: all 0.2s !important; display: flex !important; align-items: center !important; justify-content: center !important; }
.modal-cancel:active { background: rgba(255, 255, 255, 0.15) !important; opacity: 0.8; }
.modal-save { flex: 1.5; background: linear-gradient(135deg, #00b4ff, #0081ff) !important; color: #fff !important; border-radius: 20rpx !important; height: 100rpx !important; font-size: 28rpx !important; font-weight: 700 !important; border: none !important; box-shadow: 0 8rpx 24rpx rgba(0,180,255,0.3) !important; display: flex !important; align-items: center !important; justify-content: center !important; }
.modal-save:active { transform: translateY(2rpx); box-shadow: 0 4rpx 12rpx rgba(0,180,255,0.2) !important; opacity: 0.9; }
.modal-save[disabled] { opacity: 0.5; background: #333 !important; box-shadow: none !important; }


/* 热门榜单 */
.hot-list { display: flex; flex-direction: column; gap: 8rpx; max-height: 280rpx; overflow: hidden; }
.hot-item { display: flex; align-items: center; gap: 16rpx; padding: 14rpx 16rpx; background: rgba(255,255,255,0.03); border-radius: 12rpx; border: 1rpx solid rgba(255,255,255,0.06); transition: all 0.3s cubic-bezier(0.16,1,0.3,1); opacity: 0; animation: hotEnter 0.4s cubic-bezier(0.22,0.61,0.36,1) forwards; }
.hot-item:nth-child(1) { animation-delay: 0s; }
.hot-item:nth-child(2) { animation-delay: 0.04s; }
.hot-item:nth-child(3) { animation-delay: 0.08s; }
.hot-item:nth-child(4) { animation-delay: 0.12s; }
.hot-item:nth-child(5) { animation-delay: 0.16s; }
@keyframes hotEnter { from { opacity: 0; transform: translateY(10rpx); } to { opacity: 1; transform: translateY(0); } }
.hot-item:active { background: rgba(0,200,255,0.06); }
.hot-rank { width: 40rpx; height: 40rpx; border-radius: 10rpx; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 700; color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.05); flex-shrink: 0; }
.rank-1 { background: linear-gradient(135deg, #ff4757, #cc3a48); color: #fff; }
.rank-2 { background: linear-gradient(135deg, #ffab40, #ff9100); color: #fff; }
.rank-3 { background: linear-gradient(135deg, #9945ff, #7c3aed); color: #fff; }
.hot-info { flex: 1; overflow: hidden; }
.hot-name { font-size: 24rpx; color: rgba(255,255,255,0.7); display: block; font-weight: 600; }
.hot-content { font-size: 22rpx; color: rgba(255,255,255,0.4); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2rpx; }
.hot-likes { display: flex; align-items: center; gap: 4rpx; flex-shrink: 0; }
.hot-heart { font-size: 22rpx; color: #ff4757; }
.hot-count { font-size: 22rpx; color: rgba(255,255,255,0.4); }
