/* 首页样式 */
.page { min-height: 100vh; background-color: #010314; background-image: radial-gradient(ellipse 80% 50% at 20% 15%, rgba(0,180,255,0.1) 0%, transparent 60%), radial-gradient(ellipse 60% 40% at 80% 35%, rgba(100,60,255,0.06) 0%, transparent 50%), linear-gradient(185deg, #020410 0%, #040c24 100%); animation: pageExpand 0.5s cubic-bezier(0.22, 0.61, 0.36, 1); padding-bottom: 180rpx; }
@keyframes pageExpand { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
.stitle-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.announce-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 16rpx; border-top: 1rpx solid rgba(255,255,255,0.06); margin-top: 16rpx; }
.sub-counter-btn { width: 48rpx; height: 48rpx; background: rgba(0,200,255,0.1); border: 1rpx solid rgba(0,200,255,0.2); border-radius: 14rpx; display: flex; align-items: center; justify-content: center; transition: all 0.25s cubic-bezier(0.16,1,0.3,1); box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); }
.sub-counter-btn:active { transform: scale(0.88); background: rgba(0,200,255,0.18); }
.sub-counter-badge { min-width: 32rpx; height: 32rpx; background: rgba(0,180,255,0.15); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; padding: 0 8rpx; border: 1rpx solid rgba(0,200,255,0.2); }
.sub-counter-num { font-size: 20rpx; color: #fff; font-weight: 700; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,2,12,0.75); backdrop-filter: blur(16rpx); z-index: 1000; display: flex; align-items: flex-end; animation: modalFadeIn 0.35s cubic-bezier(0.32,0.72,0,1); }
@keyframes modalFadeIn { from { opacity: 0; transform: translateY(20rpx); } to { opacity: 1; transform: translateY(0); } }
.modal-box { width: 100%; background: rgba(16, 20, 48, 0.9); border: 1rpx solid rgba(255, 255, 255, 0.1); border-radius: 32rpx 32rpx 0 0; padding: 32rpx; max-height: 80vh; display: flex; flex-direction: column; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 -8rpx 40rpx rgba(0,0,0,0.3); }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; flex-shrink: 0; }
.modal-title { font-size: 32rpx; font-weight: 700; color: #00d4ff; }
.modal-close { font-size: 36rpx; color: rgba(255,255,255,0.4); padding: 8rpx; }
.modal-body { overflow-y: auto; -webkit-overflow-scrolling: touch; }
.banner-preview { width: 100%; height: 200rpx; border-radius: 12rpx; overflow: hidden; margin-bottom: 20rpx; border: 1rpx solid rgba(0,212,255,0.2); }
.preview-img { width: 100%; height: 100%; }
.banner-actions { display: flex; flex-direction: column; gap: 16rpx; }
.banner-input { width: 100%; min-height: 80rpx; background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 12rpx; padding: 20rpx; font-size: 26rpx; color: #fff; box-sizing: border-box; }
.modal-footer { display: flex; gap: 16rpx; flex-shrink: 0; padding-top: 20rpx; }
.modal-cancel { flex: 1; background: rgba(255, 255, 255, 0.1) !important; color: rgba(255,255,255,0.7) !important; border-radius: 16rpx !important; height: 80rpx !important; font-size: 26rpx !important; border: 1rpx solid rgba(255,255,255,0.08) !important; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.modal-cancel::after { border: none; }
.modal-save { flex: 1; background: rgba(0, 200, 255, 0.12) !important; color: #00d4ff !important; border-radius: 16rpx !important; height: 80rpx !important; font-size: 26rpx !important; border: 1rpx solid rgba(0, 200, 255, 0.2) !important; box-shadow: 0 0 0 1rpx rgba(0,200,255,0.05) inset, 0 1rpx 0 rgba(150,220,255,0.05) inset; display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.modal-save::after { border: none; }
.modal-save[disabled] { opacity: 0.5; }

/* 热门榜单 */
.hot-list { display: flex; flex-direction: column; gap: 8rpx; max-height: 280rpx; overflow: hidden; }
.hot-item { display: flex; align-items: center; gap: 16rpx; padding: 14rpx 16rpx; background: rgba(255,255,255,0.03); border-radius: 12rpx; border: 1rpx solid rgba(255,255,255,0.06); transition: all 0.3s cubic-bezier(0.16,1,0.3,1); opacity: 0; animation: hotEnter 0.4s cubic-bezier(0.22,0.61,0.36,1) forwards; }
.hot-item:nth-child(1) { animation-delay: 0s; }
.hot-item:nth-child(2) { animation-delay: 0.04s; }
.hot-item:nth-child(3) { animation-delay: 0.08s; }
.hot-item:nth-child(4) { animation-delay: 0.12s; }
.hot-item:nth-child(5) { animation-delay: 0.16s; }
@keyframes hotEnter { from { opacity: 0; transform: translateY(10rpx); } to { opacity: 1; transform: translateY(0); } }
.hot-item:active { background: rgba(0,200,255,0.06); }
.hot-rank { width: 40rpx; height: 40rpx; border-radius: 10rpx; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 700; color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.05); flex-shrink: 0; }
.rank-1 { background: linear-gradient(135deg, #ff4757, #cc3a48); color: #fff; }
.rank-2 { background: linear-gradient(135deg, #ffab40, #ff9100); color: #fff; }
.rank-3 { background: linear-gradient(135deg, #9945ff, #7c3aed); color: #fff; }
.hot-info { flex: 1; overflow: hidden; }
.hot-name { font-size: 24rpx; color: rgba(255,255,255,0.7); display: block; font-weight: 600; }
.hot-content { font-size: 22rpx; color: rgba(255,255,255,0.4); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2rpx; }
.hot-likes { display: flex; align-items: center; gap: 4rpx; flex-shrink: 0; }
.hot-heart { font-size: 22rpx; color: #ff4757; }
.hot-count { font-size: 22rpx; color: rgba(255,255,255,0.4); }
