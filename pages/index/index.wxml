<view class="page">
  <view class="container">
    <!-- 首页大图 -->
    <view class="banner-card" bindtap="{{isAdmin ? 'toggleBannerModal' : ''}}">
      <image class="banner-image" src="{{bannerUrl || '/images/banner1.png'}}" mode="widthFix"></image>
      <view class="banner-edit" wx:if="{{isAdmin}}">
        <text class="banner-edit-icon">✏️</text>
        <text class="banner-edit-text">编辑头图</text>
      </view>
    </view>

    <!-- 头图编辑弹窗 -->
    <view class="modal-mask" wx:if="{{showBannerModal}}" bindtap="toggleBannerModal">
      <view class="modal-box" catchtap="preventClose">
        <view class="modal-header">
          <text class="modal-title">编辑首页头图</text>
          <text class="modal-close" catchtap="toggleBannerModal">✕</text>
        </view>
        <view class="modal-body">
          <view class="banner-preview" wx:if="{{bannerInput}}">
            <image class="preview-img" src="{{bannerInput}}" mode="aspectFill" />
          </view>
          <view class="banner-actions">
            <view class="image-action-btn" catchtap="chooseBannerImage">
              <text class="action-icon">📷</text>
              <text class="action-text">相册选择</text>
            </view>
            <input class="banner-input" placeholder="或粘贴图片URL链接" placeholder-style="color:rgba(255,255,255,0.35)" value="{{bannerInput}}" bindinput="onBannerInput" cursor-spacing="120" />
          </view>
        </view>
        <view class="modal-footer">
          <button class="modal-cancel" catchtap="toggleBannerModal">取消</button>
          <button class="modal-save" catchtap="saveBanner" disabled="{{bannerSaving}}">{{bannerSaving ? '保存中...' : '保存'}}</button>
        </view>
      </view>
    </view>

    <!-- 快捷入口 -->
    <view class="card">
      <view class="stitle">快捷入口</view>
      <view class="actions">
        <view class="act" bindtap="go" data-url="/pages/egg/egg"><view class="act-icon">🥚</view><text>孵蛋查询</text></view>
        <view class="act" bindtap="go" data-url="/pages/merchant/merchant"><view class="act-icon">🛒</view><text>远行商人</text></view>
        <view class="act" bindtap="go" data-url="/pages/catch/catch"><view class="act-icon">🎯</view><text>捕捉统计</text></view>
        <view class="act" bindtap="go" data-url="/pages/about/about"><view class="act-icon">ℹ️</view><text>关于我们</text></view>
      </view>
    </view>

    <!-- 公告栏：有公告时全员可见，无公告时仅管理员可见 -->
    <view class="card announcement-card" wx:if="{{announcements.length > 0 || isAdmin}}">
      <view class="stitle-row">
        <text class="stitle">📢 公告通知</text>
      </view>
      <!-- 有公告 -->
      <view wx:if="{{announcements.length > 0}}">
        <view class="news-item" wx:for="{{announcements}}" wx:key="_id">
          <view class="news" bindtap="showAnnouncement" data-i="{{index}}">
            <view class="news-tag {{item.pinned?'pinned':''}}">{{item.pinned?'置顶':item.type === 'notice' ? '公告' : item.type === 'update' ? '更新' : item.type === 'event' ? '活动' : '提示'}}</view>
            <view class="news-body">
              <text class="news-t">{{item.title}}</text>
              <text class="news-d">{{item.timeStr}}</text>
            </view>
            <view class="news-arrow {{expandedIndex === index ? 'expanded' : ''}}">›</view>
          </view>
          <view class="news-detail" wx:if="{{expandedIndex === index}}">
            <block wx:if="{{item.richContent && item.richContent.length > 0}}">
              <view class="news-detail-rich" style="padding: 12rpx 16rpx; background: rgba(0,0,0,0.2); border-radius: 12rpx; border-left: 4rpx solid rgba(0,212,255,0.3); margin-bottom: 16rpx;">
                <block wx:for="{{item.richContent}}" wx:for-item="block" wx:key="index">
                  <view wx:if="{{block.type === 'music'}}" class="rich-music-block {{currentPlayUrl === block.url && isPlaying ? 'playing' : ''}}" catchtap="playSong" data-url="{{block.url}}" data-name="{{block.name || '推荐单曲'}}">
                    <text class="music-icon {{currentPlayUrl === block.url && isPlaying ? 'rotating' : ''}}">🎵</text>
                    <view class="music-info">
                      <text class="music-name">{{block.name || '推荐单曲'}}</text>
                      <text class="music-url">{{block.url}}</text>
                    </view>
                    <text class="music-play-btn">{{currentPlayUrl === block.url && isPlaying ? '暂停' : '点我听歌'}}</text>
                  </view>
                  <view wx:elif="{{block.type === 'iframe'}}" class="rich-iframe-block">
                    <text class="iframe-icon">🌐</text>
                    <view class="iframe-info">
                      <text class="iframe-name">{{block.name || '外部网页'}}</text>
                      <text class="iframe-url">{{block.url}}</text>
                    </view>
                    <view class="iframe-actions">
                      <view class="iframe-btn open" catchtap="openIframe" data-url="{{block.url}}">打开</view>
                      <view class="iframe-btn copy" catchtap="copyIframe" data-url="{{block.url}}">复制</view>
                    </view>
                  </view>
                  <view wx:elif="{{block.type === 'quote'}}" class="rich-quote-block">
                    <text class="quote-text">{{block.content}}</text>
                  </view>
                  <view wx:elif="{{block.type === 'video'}}" class="rich-music-block" catchtap="openVideo" data-url="{{block.url}}" data-name="{{block.name || '视频'}}">
                    <text class="music-icon">{{block.platform === 'bilibili' ? '📺' : '🎬'}}</text>
                    <view class="music-info">
                      <text class="music-name">{{block.name || block.platformName + '视频'}}</text>
                      <text class="music-url">{{block.url}}</text>
                    </view>
                    <text class="music-play-btn">▶ 观看</text>
                  </view>
                  <view wx:elif="{{block.type === 'table'}}" class="rich-table-block">
                    <view class="rich-table">
                      <view class="rich-table-row rich-table-header">
                        <view class="rich-table-cell" wx:for="{{block.headers}}" wx:key="index">{{item}}</view>
                      </view>
                      <view class="rich-table-row" wx:for="{{block.rows}}" wx:for-item="row" wx:key="index">
                        <view class="rich-table-cell" wx:for="{{row}}" wx:for-item="cell" wx:key="index">{{cell}}</view>
                      </view>
                    </view>
                  </view>
                  <view wx:elif="{{block.type === 'image'}}" class="rich-image-block" catchtap="previewRichImage" data-src="{{block.url}}">
                    <image class="rich-image" src="{{block.url}}" mode="widthFix" />
                  </view>
                  <view wx:else class="rich-text-block" style="font-size:{{block.size}}rpx;color:{{block.color}};font-weight:{{block.weight || 'normal'}};font-style:{{block.style || 'normal'}};{{block.fontFamily && block.fontFamily !== 'sans-serif' ? 'font-family:' + block.fontFamily + ';' : ''}}">
                    {{block.content}}
                  </view>
                </block>
              </view>
            </block>
            <text wx:else class="news-detail-content">{{item.content}}</text>
            <view class="news-source" wx:if="{{item.source}}">
              <text class="source-label">来源：</text>
              <text class="source-text">{{item.source}}</text>
            </view>
            <image 
              wx:if="{{item.image}}" 
              class="news-detail-image" 
              src="{{item.image}}" 
              mode="widthFix" 
              catchtap="previewAnnouncementImage" 
              data-src="{{item.image}}"
              binderror="onAnnouncementImageError"
              data-index="{{index}}"
            />
          </view>
        </view>
      </view>
      <!-- 无公告，管理员可见提示 -->
      <view class="empty-notice" wx:if="{{announcements.length === 0 && isAdmin}}">
        <text class="empty-notice-text">暂无公告，请前往管理后台发布</text>
        <view class="empty-notice-btn" bindtap="goAdmin">去发布</view>
      </view>
    </view>

    <view class="foot">
      <text wx:if="{{icp}}">{{icp}}</text>
    </view>
  </view>

  <!-- 视频播放器 -->
  <view class="modal-mask" wx:if="{{showVideoPlayer}}" catchtap="closeVideoPlayer" style="z-index:10000;">
    <view class="modal-box video-player-box" catchtap="preventClose" style="width:100%;background:rgba(10,14,39,0.96);border-radius:24rpx 24rpx 0 0;padding:0;max-height:85vh;">
      <view class="modal-header" style="padding:20rpx 24rpx 0;margin-bottom:8rpx;">
        <text class="modal-title" style="color:#fff;font-size:26rpx;">{{videoPlayerName}}</text>
        <text class="modal-close" catchtap="closeVideoPlayer">✕</text>
      </view>
      <view style="padding:0 24rpx 8rpx;display:flex;align-items:center;gap:8rpx;" wx:if="{{videoPlayerOwner}}">
        <text style="font-size:22rpx;color:rgba(255,255,255,0.4);">UP主: {{videoPlayerOwner}}</text>
      </view>
      <image wx:if="{{videoPlayerCover}}" src="{{videoPlayerCover}}" mode="aspectFill" style="width:100%;height:220rpx;" />
      <video style="width:100%;height:360rpx;" src="{{videoPlayerUrl}}" controls autoplay show-center-play-btn object-fit="contain" />
      <view style="padding:12rpx 24rpx 24rpx;" wx:if="{{videoPlayerDesc}}">
        <text style="font-size:22rpx;color:rgba(255,255,255,0.5);line-height:1.5;">{{videoPlayerDesc}}</text>
      </view>
    </view>
  </view>

  <dock current="index" />
</view>