<view class="page">
  <view class="container">
    <!-- 社区公告 -->
    <view class="community-notice" wx:if="{{showCommunityNotice && userInfo}}">
      <view class="notice-content">
        <text class="notice-icon">📢</text>
        <text class="notice-text">社区内发布内容需遵守法律法规</text>
      </view>
      <view class="notice-close" catchtap="closeCommunityNotice">✕</view>
    </view>

    <view class="post-bar" bindtap="openPostModal">
      <image class="post-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" binderror="onAvatarError" data-type="post" />
      <text class="post-placeholder">分享你的想法...</text>
      <view class="post-btn">发布</view>
    </view>

    <!-- 位置授权提示 -->
    <view class="location-tip" wx:if="{{showLocationTip && userInfo}}">
      <view class="location-tip-content">
        <text class="location-tip-icon">📍</text>
        <view class="location-tip-text">
          <text class="location-tip-title">显示帖子归属地</text>
          <text class="location-tip-desc">授权后发帖将显示所在地</text>
        </view>
      </view>
      <view class="location-tip-btns">
        <view class="location-btn deny" bindtap="onLocationDeny">暂不</view>
        <view class="location-btn allow" bindtap="onLocationAllow">允许</view>
      </view>
    </view>

    <!-- 头衔选择 -->
    <view class="title-bar" wx:if="{{userInfo}}">
      <view class="title-bar-left" bindtap="toggleTitlePicker">
        <text class="title-bar-label">我的头衔</text>
        <text class="title-bar-value">选择/更换头衔 ›</text>
      </view>
      <view class="location-toggle" bindtap="toggleLocationSetting">
        <text class="location-toggle-icon">📍</text>
        <text class="location-toggle-text">{{province ? '已开启' : '归属地'}}</text>
      </view>
    </view>

    <view class="tabs">
      <view class="tab {{activeTab === 'all' ? 'on' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
      <view class="tab {{activeTab === 'hot' ? 'on' : ''}}" bindtap="switchTab" data-tab="hot">最热</view>
      <view class="tab {{activeTab === 'mine' ? 'on' : ''}}" bindtap="switchTab" data-tab="mine">我的</view>
    </view>

    <view class="feed-list">
      <view class="feed-card" wx:for="{{comments}}" wx:key="_id">
        <view class="feed-header">
          <view class="feed-avatar-wrap {{item.userRole === 'developer' ? 'avatar-dev' : item.userRole === 'editor' ? 'avatar-editor' : ''}}">
            <image class="feed-avatar" src="{{item.userAvatar || '/images/default-avatar.png'}}" mode="aspectFill" binderror="onAvatarError" data-idx="{{index}}" data-type="comments" />
            <view class="verified-badge dev-badge" wx:if="{{item.userRole === 'developer'}}">✓</view>
            <view class="verified-badge editor-badge" wx:elif="{{item.userRole === 'editor'}}">✓</view>
          </view>
          <view class="feed-user">
            <view class="feed-name-row">
              <text class="feed-name">{{item.userName}}</text>
              <text class="feed-uid" wx:if="{{item.gameUid}}">UID:{{item.gameUid}}</text>
              <view class="role-tag developer" wx:if="{{item.userRole === 'developer'}}">开发者</view>
              <view class="role-tag editor" wx:elif="{{item.userRole === 'editor'}}">小编</view>
              <view class="sofa-tag" wx:if="{{item.isFirstToday}}">🛋️ 沙发</view>
              <view class="title-tag" wx:if="{{item.userTitle && item.userTitle !== '不显示头衔'}}" style="color: {{item.titleColor || '#00d4ff'}}">{{item.userTitle}}</view>
            </view>
            <text class="feed-time">{{item.timeStr}}</text>
            <text class="feed-meta" wx:if="{{item.device || item.location}}">{{item.device}}{{item.device && item.location ? ' · ' : ''}}{{item.location}}</text>
          </view>
          <view class="feed-tag" wx:if="{{item.pageType && item.pageType !== 'community'}}" bindtap="goToPage" data-item="{{item}}">
            {{item.pageType === 'pet' ? '精灵' : item.pageType}}
          </view>
          <view class="feed-more" wx:if="{{userInfo.nickName === item.userName}}" catchtap="deletePost" data-item="{{item}}">
            <text class="more-icon">···</text>
          </view>
        </view>
        <view class="feed-content" bindtap="openDetail" data-item="{{item}}">
          <text class="feed-text" wx:if="{{item.content}}">{{item.content}}</text>
          <view class="feed-images" wx:if="{{item.images && item.images.length > 0}}">
            <image class="feed-image" wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="widthFix" catchtap="previewImage" data-src="{{img}}" data-urls="{{item.images}}" />
          </view>
          <view class="feed-stars" wx:if="{{item.rating > 0}}">
            <text class="star-on" wx:for="{{5}}" wx:for-item="s" wx:for-index="si" wx:key="si" wx:if="{{si < item.rating}}">★</text>
            <text class="star-off" wx:for="{{5}}" wx:for-item="s" wx:for-index="si" wx:key="si" wx:if="{{si >= item.rating}}">★</text>
          </view>
        </view>
        <view class="feed-actions">
          <view class="feed-action {{item.liked ? 'liked' : ''}}" bindtap="toggleLike" data-item="{{item}}">
            <text class="action-icon">{{item.liked ? '❤' : '♡'}}</text>
            <text class="action-text" wx:if="{{item.likes.length > 0}}">{{item.likes.length}}</text>
          </view>
          <view class="feed-action" bindtap="openDetail" data-item="{{item}}">
            <text class="action-icon">💬</text>
            <text class="action-text" wx:if="{{item.replyCount > 0}}">{{item.replyCount}}</text>
          </view>
          <view class="feed-admin-btns" wx:if="{{isManager && item.replyTo === null}}">
            <view class="admin-btn {{item.pinned ? 'active' : ''}}" catchtap="togglePin" data-item="{{item}}">📌</view>
            <view class="admin-btn {{item.featured ? 'active' : ''}}" catchtap="toggleFeatured" data-item="{{item}}">⭐</view>
            <view class="admin-btn danger" catchtap="deletePost" data-item="{{item}}">🗑</view>
          </view>
        </view>
        <!-- 内联回复预览 -->
        <view class="inline-replies" wx:if="{{item.inlineReplies && item.inlineReplies.length > 0}}">
          <view class="inline-reply" wx:for="{{item.inlineReplies}}" wx:for-item="rp" wx:key="_id">
            <image class="inline-reply-avatar" src="{{rp.userAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
            <view class="inline-reply-body">
              <text class="inline-reply-name">{{rp.userName}}</text>
              <text class="inline-reply-text">{{rp.content}}</text>
            </view>
            <text class="inline-reply-time">{{rp.timeStr}}</text>
          </view>
          <view class="inline-reply-more" wx:if="{{item.replyCount > 3}}" bindtap="openDetail" data-item="{{item}}">
            查看全部 {{item.replyCount}} 条回复 ›
          </view>
        </view>
        <!-- 置顶/精选标签 -->
        <view class="feed-badges" wx:if="{{item.pinned || item.featured}}">
          <view class="badge-pin" wx:if="{{item.pinned}}">📌 置顶</view>
          <view class="badge-feat" wx:if="{{item.featured}}">⭐ 精选</view>
        </view>
        <!-- 管理员用户操作（仅管理员可见） -->
        <view class="user-manage-bar" wx:if="{{isManager && userRoles[item.userName] !== 'developer' && userInfo.nickName !== item.userName}}">
          <text class="manage-label">用户管理：</text>
          <view class="manage-btn" catchtap="banUser" data-item="{{item}}" wx:if="{{!item.userBanned}}">封禁</view>
          <view class="manage-btn" catchtap="unbanUser" data-item="{{item}}" wx:if="{{item.userBanned}}">解封</view>
          <view class="manage-btn" catchtap="setEditor" data-item="{{item}}" wx:if="{{userRoles[item.userName] !== 'editor'}}">设为小编</view>
          <view class="manage-btn" catchtap="removeEditor" data-item="{{item}}" wx:if="{{userRoles[item.userName] === 'editor'}}">取消小编</view>
        </view>
      </view>
    </view>

    <view class="empty-wrap" wx:if="{{!loading && comments.length === 0}}">
      <view class="empty-particles">
        <view class="ep ep1"></view>
        <view class="ep ep2"></view>
        <view class="ep ep3"></view>
        <view class="ep ep4"></view>
        <view class="ep ep5"></view>
        <view class="ep ep6"></view>
      </view>
      <text class="empty-title">洛手助手社区</text>
      <text class="empty-desc">{{activeTab === 'mine' ? '你还没有发布过内容' : '暂无动态，快来发表第一条吧'}}</text>
    </view>

    <view class="loading-wrap" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>

    <view class="load-more" wx:if="{{!loading && hasMore && comments.length > 0}}" bindtap="loadMore">
      <text class="more-text">加载更多</text>
    </view>

    <view class="no-more" wx:if="{{!loading && !hasMore && comments.length > 0}}">
      <text class="no-more-text">— 没有更多了 —</text>
    </view>
  </view>

  <!-- 发帖弹窗 -->
  <view class="modal-mask" wx:if="{{showPostModal}}" bindtap="closePostModal">
    <view class="modal-box" catchtap="preventClose">
      <view class="modal-header">
        <text class="modal-title">发布动态</text>
        <text class="modal-close" catchtap="closePostModal">✕</text>
      </view>
      <view class="modal-body">
        <textarea class="modal-textarea" placeholder="分享你的想法..." placeholder-style="color:rgba(255,255,255,0.5)" value="{{postContent}}" bindinput="onPostInput" maxlength="500" cursor-spacing="120" />
        <view class="image-list" wx:if="{{postImages.length > 0}}">
          <view class="image-item" wx:for="{{postImages}}" wx:key="*this">
            <image class="image-thumb" src="{{item}}" mode="aspectFill" />
            <view class="image-remove" catchtap="removePostImage" data-idx="{{index}}">✕</view>
          </view>
        </view>
        <view class="image-url-row" wx:if="{{postImages.length < 9}}">
          <input class="image-url-input" placeholder="粘贴图片链接添加" placeholder-style="color:rgba(255,255,255,0.35)" value="{{imageUrlInput}}" bindinput="onImageUrlInput" />
          <view class="image-url-btn" catchtap="addImageByUrl">添加</view>
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-tools">
          <view class="tool-btn" catchtap="choosePostImage">
            <text class="tool-icon">🖼</text>
          </view>
          <text class="char-count">{{postContent.length}}/500</text>
        </view>
        <button class="modal-submit" catchtap="submitPost" disabled="{{posting}}">{{posting ? '发布中...' : '发布'}}</button>
      </view>
    </view>
  </view>

  <!-- 帖子详情弹窗 -->
  <view class="modal-mask detail-mask" wx:if="{{showDetailModal}}" bindtap="closeDetail">
    <view class="detail-modal" catchtap="preventClose">
      <view class="modal-header">
        <text class="modal-title">帖子详情</text>
        <text class="modal-close" bindtap="closeDetail">✕</text>
      </view>
      <scroll-view class="detail-scroll" scroll-y>
        <view class="detail-post">
          <view class="detail-post-header">
            <image class="detail-avatar" src="{{detailItem.userAvatar || '/images/default-avatar.png'}}" mode="aspectFill" binderror="onAvatarError" data-type="detail-post" />
            <view class="detail-user">
              <text class="detail-name">{{detailItem.userName}}</text>
              <text class="detail-time">{{detailItem.timeStr}}</text>
            </view>
          </view>
          <text class="detail-content">{{detailItem.content}}</text>
          <view class="detail-images" wx:if="{{detailItem.images && detailItem.images.length > 0}}">
            <image class="detail-img" wx:for="{{detailItem.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="widthFix" catchtap="previewDetailImage" data-src="{{img}}" data-urls="{{detailItem.images}}" />
          </view>
        </view>
        <view class="reply-section">
          <text class="reply-title">回复 ({{detailReplies.length}})</text>
          <view class="reply-item" wx:for="{{detailReplies}}" wx:key="_id" catchtap="setReplyTarget" data-item="{{item}}">
            <view class="reply-avatar-wrap {{item.userRole === 'developer' ? 'avatar-dev' : item.userRole === 'editor' ? 'avatar-editor' : ''}}">
              <image class="reply-avatar" src="{{item.userAvatar || '/images/default-avatar.png'}}" mode="aspectFill" binderror="onAvatarError" data-idx="{{index}}" data-type="detail" />
              <view class="verified-badge small dev-badge" wx:if="{{item.userRole === 'developer'}}">✓</view>
              <view class="verified-badge small editor-badge" wx:elif="{{item.userRole === 'editor'}}">✓</view>
            </view>
            <view class="reply-body">
              <view class="reply-name-row">
                <text class="reply-name">{{item.userName}}</text>
                <view class="role-tag developer small" wx:if="{{item.userRole === 'developer'}}">开发者</view>
                <view class="role-tag editor small" wx:elif="{{item.userRole === 'editor'}}">小编</view>
              </view>
              <text class="reply-text">{{item.content}}</text>
              <view class="reply-bottom-row">
                <text class="reply-meta" wx:if="{{item.device || item.location}}">{{item.device}}{{item.device && item.location ? ' · ' : ''}}{{item.location}}</text>
                <text class="reply-time">{{item.timeStr}}</text>
                <view class="reply-count" wx:if="{{item.replyCount > 0}}">
                  <text class="reply-count-icon">💬</text>
                  <text class="reply-count-num">{{item.replyCount}}</text>
                </view>
              </view>
            </view>
          </view>
          <view class="reply-empty" wx:if="{{detailReplies.length === 0}}">
            <text class="reply-empty-text">暂无回复</text>
          </view>
        </view>
      </scroll-view>
      <view class="reply-input-bar">
        <view class="reply-target-hint" wx:if="{{replyTarget}}" catchtap="clearReplyTarget">
          <text class="reply-target-text">回复 {{replyTarget.userName}}：</text>
          <text class="reply-target-clear">✕</text>
        </view>
        <input class="reply-input" placeholder="{{replyTarget ? '回复 ' + replyTarget.userName + '...' : '写回复...'}}" placeholder-style="color:rgba(255,255,255,0.5)" value="{{replyContent}}" bindinput="onReplyInput" />
        <button class="reply-submit" bindtap="submitReply" disabled="{{replying}}">{{replying ? '发送中' : '发送'}}</button>
      </view>
    </view>
  </view>

  <!-- 头衔选择弹窗 -->
  <view class="title-picker-mask" wx:if="{{showTitlePicker}}" bindtap="toggleTitlePicker">
    <view class="title-picker" catchtap="preventClose">
      <view class="title-picker-header">
        <text class="title-picker-title">选择头衔</text>
        <text class="title-picker-close" bindtap="toggleTitlePicker">✕</text>
      </view>
      <view class="title-option" wx:for="{{titleOptions}}" wx:key="name" bindtap="selectTitle" data-title="{{item.name}}" data-color="{{item.color}}">
        <text class="title-option-name" style="color: {{item.color}}">{{item.name}}</text>
      </view>
      <text class="title-tip">头衔根据捕捉数据自动计算，也可手动选择</text>
    </view>
  </view>

  <view class="navbar">
    <view class="nav-item" bindtap="go" data-url="/pages/index/index"><text class="nav-icon">🏠</text><text class="nav-text">首页</text></view>
    <view class="nav-item on"><text class="nav-icon">👥</text><text class="nav-text">社区</text></view>
    <view class="nav-item" bindtap="go" data-url="/pages/activity/activity"><text class="nav-icon">📅</text><text class="nav-text">活动</text></view>
    <view class="nav-item" bindtap="go" data-url="/pages/login/login"><text class="nav-icon">👤</text><text class="nav-text">我的</text></view>
  </view>
</view>