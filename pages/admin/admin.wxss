.no-access { text-align: center; padding: 160rpx 0; }
.no-icon { font-size: 120rpx; display: block; margin-bottom: 24rpx; }
.no-title { font-size: 36rpx; font-weight: 700; color: rgba(255,255,255,0.6); display: block; margin-bottom: 12rpx; }
.no-desc { font-size: 26rpx; color: rgba(255,255,255,0.5); display: block; }
.loading { text-align: center; padding: 160rpx 0; }
.loading-text { font-size: 28rpx; color: rgba(0,212,255,0.5); }

.admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.admin-title { font-size: 36rpx; font-weight: 700; color: #00d4ff; }
.refresh-btn { background: rgba(0,212,255,0.1); border: 1rpx solid rgba(0,212,255,0.2); padding: 10rpx 24rpx; border-radius: 20rpx; font-size: 24rpx; color: #00d4ff; }

.admin-tabs { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.admin-tab { flex: 1; text-align: center; padding: 16rpx 0; font-size: 26rpx; color: rgba(255,255,255,0.4); background: rgba(0,0,0,0.2); border: 1rpx solid rgba(0,212,255,0.08); border-radius: 10rpx; }
.admin-tab.on { background: linear-gradient(135deg, rgba(0,212,255,0.2), rgba(153,69,255,0.2)); color: #00d4ff; border-color: rgba(0,212,255,0.3); font-weight: 600; }

.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: rgba(255,255,255,0.7); }
.add-btn { background: linear-gradient(135deg, #00d4ff, #9945ff); color: #fff; font-size: 24rpx; padding: 10rpx 24rpx; border-radius: 20rpx; position: relative; overflow: hidden; }
.add-btn::after { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent); animation: btn-shine 2s ease-in-out infinite; }
@keyframes btn-shine { 0% { left: -100%; } 50%, 100% { left: 100%; } }

.card-item { background: linear-gradient(145deg, rgba(20,25,60,0.9), rgba(15,18,45,0.95)); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.card-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.card-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; border: 1rpx solid rgba(0,212,255,0.2); flex-shrink: 0; background: rgba(0,212,255,0.1); }
.card-user-info { flex: 1; }
.card-author { font-size: 26rpx; color: rgba(255,255,255,0.8); font-weight: 600; }
.card-meta { font-size: 20rpx; color: rgba(255,255,255,0.4); display: block; margin-top: 4rpx; }
.card-title { font-size: 30rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 8rpx; }
.card-desc { font-size: 26rpx; color: rgba(255,255,255,0.6); line-height: 1.6; display: block; margin-bottom: 12rpx; word-break: break-all; }
.card-images { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 12rpx; }
.card-img { width: 160rpx; height: 160rpx; border-radius: 8rpx; border: 1rpx solid rgba(0,212,255,0.1); }
.card-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 12rpx; border-top: 1rpx solid rgba(0,212,255,0.06); }
.card-time { font-size: 20rpx; color: rgba(255,255,255,0.5); }
.card-actions { display: flex; gap: 12rpx; }
.btn-edit { padding: 8rpx 20rpx; background: rgba(0,212,255,0.1); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 8rpx; font-size: 22rpx; color: #00d4ff; }
.btn-delete { padding: 8rpx 20rpx; background: rgba(255,71,87,0.1); border: 1rpx solid rgba(255,71,87,0.2); border-radius: 8rpx; font-size: 22rpx; color: #ff4757; }

.tag { padding: 4rpx 14rpx; border-radius: 6rpx; font-size: 20rpx; font-weight: 600; }
.tag-notice { background: rgba(0,212,255,0.15); color: #00d4ff; border: 1rpx solid rgba(0,212,255,0.3); }
.tag-update { background: rgba(52,199,89,0.15); color: #34c759; border: 1rpx solid rgba(52,199,89,0.3); }
.tag-event { background: rgba(255,171,64,0.15); color: #ffab40; border: 1rpx solid rgba(255,171,64,0.3); }
.tag-tip { background: rgba(153,69,255,0.15); color: #9945ff; border: 1rpx solid rgba(153,69,255,0.3); }
.tag-system { background: rgba(0,212,255,0.15); color: #00d4ff; border: 1rpx solid rgba(0,212,255,0.3); }
.card-version { font-size: 20rpx; color: #ffab40; background: rgba(255,171,64,0.1); border: 1rpx solid rgba(255,171,64,0.2); padding: 2rpx 12rpx; border-radius: 6rpx; margin-left: 8rpx; }
.pin-tag { padding: 4rpx 12rpx; border-radius: 6rpx; font-size: 20rpx; color: rgba(255,255,255,0.5); border: 1rpx solid rgba(255,255,255,0.1); margin-left: auto; }
.pin-tag.on { color: #ffab40; border-color: rgba(255,171,64,0.3); background: rgba(255,171,64,0.1); }
.ban-tag { padding: 4rpx 12rpx; border-radius: 6rpx; font-size: 20rpx; margin-left: auto; }
.ban-tag { color: #34c759; border: 1rpx solid rgba(52,199,89,0.3); background: rgba(52,199,89,0.1); }
.ban-tag.banned { color: #ff4757; border-color: rgba(255,71,87,0.3); background: rgba(255,71,87,0.1); }

.page-icon { font-size: 40rpx; margin-right: 16rpx; }
.page-actions { display: flex; gap: 12rpx; margin-top: 12rpx; padding-top: 12rpx; border-top: 1rpx solid rgba(0,212,255,0.06); }

.stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.stat-card { background: linear-gradient(145deg, rgba(20,25,60,0.9), rgba(15,18,45,0.95)); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 16rpx; padding: 32rpx; text-align: center; }
.stat-num { font-size: 48rpx; font-weight: 700; color: #00d4ff; display: block; text-shadow: 0 0 8px rgba(0,212,255,0.5); }
.stat-label { font-size: 24rpx; color: rgba(255,255,255,0.4); display: block; margin-top: 8rpx; }

.empty { text-align: center; padding: 80rpx 0; }
.empty-text { font-size: 26rpx; color: rgba(255,255,255,0.5); }

.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 1000; display: flex; align-items: flex-end; }
.modal-box { width: 100%; background: linear-gradient(180deg, #1a1040, #0a0e27); border-radius: 24rpx 24rpx 0 0; padding: 32rpx; max-height: 85vh; display: flex; flex-direction: column; }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; flex-shrink: 0; }
.modal-title { font-size: 32rpx; font-weight: 700; color: #00d4ff; }
.modal-close { font-size: 36rpx; color: rgba(255,255,255,0.4); padding: 8rpx; }
.modal-body { overflow-y: auto; -webkit-overflow-scrolling: touch; }
.form-group { margin-bottom: 24rpx; }
.form-group.row { display: flex; justify-content: space-between; align-items: center; }
.form-label { font-size: 26rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 12rpx; }
.form-group.row .form-label { margin-bottom: 0; }
.form-input { width: 100%; min-height: 72rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 10rpx; padding: 18rpx 20rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; }
.form-textarea { width: 100%; height: 200rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 10rpx; padding: 18rpx 20rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; }
.form-label-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.editor-mode-btn { display: flex; align-items: center; gap: 6rpx; padding: 6rpx 14rpx; background: rgba(0,212,255,0.1); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 8rpx; }
.mode-icon { font-size: 24rpx; }
.mode-text { font-size: 20rpx; color: #00d4ff; }

/* 富文本编辑器 */
.rich-toolbar { background: rgba(0,0,0,0.2); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 10rpx; padding: 12rpx; margin-bottom: 12rpx; }
.toolbar-row { display: flex; gap: 8rpx; flex-wrap: wrap; }
.tool-btn { display: flex; align-items: center; justify-content: center; gap: 4rpx; min-width: 64rpx; height: 56rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 8rpx; padding: 0 12rpx; }
.tool-btn.active { background: rgba(0,212,255,0.2); border-color: rgba(0,212,255,0.4); }
.tool-btn:active { background: rgba(0,212,255,0.3); }
.tool-icon { font-size: 28rpx; color: #fff; }
.tool-text { font-size: 20rpx; color: rgba(255,255,255,0.7); }
.color-preview { width: 28rpx; height: 28rpx; border-radius: 6rpx; border: 2rpx solid rgba(255,255,255,0.3); }

/* 字号选择器 */
.size-picker { display: flex; flex-wrap: wrap; gap: 8rpx; padding: 12rpx 0; margin-top: 12rpx; border-top: 1rpx solid rgba(0,212,255,0.1); }
.size-option { display: flex; align-items: center; justify-content: center; min-width: 72rpx; height: 56rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 8rpx; color: rgba(255,255,255,0.7); }
.size-option.active { background: rgba(0,212,255,0.2); border-color: rgba(0,212,255,0.4); color: #00d4ff; }

/* 颜色选择器 */
.color-picker { display: flex; flex-wrap: wrap; gap: 8rpx; padding: 12rpx 0; margin-top: 12rpx; border-top: 1rpx solid rgba(0,212,255,0.1); }
.color-option { display: flex; align-items: center; gap: 8rpx; padding: 8rpx 14rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 8rpx; }
.color-option.active { background: rgba(0,212,255,0.2); border-color: rgba(0,212,255,0.4); }
.color-dot { width: 24rpx; height: 24rpx; border-radius: 50%; border: 2rpx solid rgba(255,255,255,0.2); }
.color-name { font-size: 22rpx; color: rgba(255,255,255,0.7); }

/* 富文本块列表 */
.rich-blocks { margin-bottom: 12rpx; }
.rich-block { display: flex; align-items: flex-start; justify-content: space-between; padding: 12rpx; background: rgba(0,0,0,0.2); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 8rpx; margin-bottom: 8rpx; }
.rich-block.quote-block { border-left: 4rpx solid rgba(0,212,255,0.3); }
.block-content { flex: 1; display: flex; align-items: flex-start; gap: 8rpx; }
.block-quote-icon { font-size: 24rpx; color: #00d4ff; flex-shrink: 0; }
.block-text { word-break: break-all; }
.block-actions { display: flex; gap: 8rpx; flex-shrink: 0; margin-left: 12rpx; }
.block-btn { padding: 4rpx 12rpx; font-size: 20rpx; background: rgba(0,212,255,0.1); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 6rpx; color: #00d4ff; }
.block-btn.delete { background: rgba(255,71,87,0.1); border-color: rgba(255,71,87,0.2); color: #ff4757; }
.form-picker { min-height: 72rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 10rpx; padding: 18rpx 20rpx; display: flex; align-items: center; }
.picker-text { font-size: 28rpx; color: #fff; }
.toggle { width: 88rpx; height: 48rpx; background: rgba(255,255,255,0.15); border-radius: 24rpx; padding: 4rpx; transition: background 0.3s; }
.toggle.on { background: linear-gradient(135deg, #00d4ff, #9945ff); }
.toggle-dot { width: 40rpx; height: 40rpx; background: #fff; border-radius: 50%; transition: transform 0.3s; }
.toggle.on .toggle-dot { transform: translateX(40rpx); }
.image-section { margin-top: 8rpx; }
.image-preview { position: relative; width: 200rpx; height: 200rpx; border-radius: 12rpx; overflow: hidden; border: 1rpx solid rgba(0,212,255,0.2); }
.preview-img { width: 100%; height: 100%; }
.image-remove { position: absolute; top: 8rpx; right: 8rpx; width: 40rpx; height: 40rpx; background: rgba(255,71,87,0.9); color: #fff; font-size: 24rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.image-actions { display: flex; gap: 16rpx; }
.image-action-btn { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 160rpx; height: 120rpx; background: rgba(0,0,0,0.3); border: 1rpx dashed rgba(0,212,255,0.3); border-radius: 12rpx; }
.action-icon { font-size: 36rpx; margin-bottom: 8rpx; }
.action-text { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.file-import { display: flex; align-items: center; gap: 8rpx; margin-top: 12rpx; padding: 12rpx 16rpx; background: rgba(0,212,255,0.08); border: 1rpx dashed rgba(0,212,255,0.3); border-radius: 8rpx; }
.file-import-icon { font-size: 28rpx; }
.file-import-text { font-size: 22rpx; color: rgba(0,212,255,0.7); }
.modal-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 28rpx; flex-shrink: 0; padding-bottom: env(safe-area-inset-bottom); }
.char-count { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.modal-submit { background: linear-gradient(135deg, #00d4ff, #9945ff) !important; color: #fff !important; border-radius: 32rpx !important; padding: 0 40rpx !important; height: 72rpx !important; line-height: 72rpx !important; font-size: 28rpx !important; position: relative; overflow: hidden; }
.modal-submit::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent); animation: btn-shine 2s ease-in-out infinite; }
.modal-submit::after { border: none; }
.modal-submit[disabled] { opacity: 0.5; }
.notify-hint { font-size: 22rpx; color: rgba(255,171,64,0.6); }

/* 订阅管理样式 */
.sub-section { background: linear-gradient(145deg, rgba(20,25,60,0.9), rgba(15,18,45,0.95)); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; }
.sub-section-title { display: flex; align-items: center; gap: 10rpx; font-size: 30rpx; font-weight: 700; color: #fff; margin-bottom: 16rpx; }
.sub-section-icon { font-size: 32rpx; }
.sub-section-hint { font-size: 22rpx; color: rgba(255,255,255,0.4); display: block; margin-bottom: 20rpx; }
.sub-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.sub-toggle-card { display: flex; flex-direction: column; align-items: center; gap: 10rpx; padding: 24rpx 12rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 14rpx; transition: all 0.3s; }
.sub-toggle-card.active { border-color: rgba(0,212,255,0.3); background: rgba(0,212,255,0.08); }
.sub-toggle-icon { font-size: 40rpx; }
.sub-toggle-name { font-size: 24rpx; color: rgba(255,255,255,0.7); font-weight: 500; }
.sub-test-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16rpx; }
.sub-test-btn { display: flex; flex-direction: column; align-items: center; gap: 10rpx; padding: 28rpx 8rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 14rpx; position: relative; overflow: hidden; }
.sub-test-btn::after { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(0,212,255,0.1), transparent); animation: btn-shine 3s ease-in-out infinite; }
.sub-test-btn:active { background: rgba(0,212,255,0.15); transform: scale(0.96); }
.sub-test-icon { font-size: 40rpx; }
.sub-test-text { font-size: 22rpx; color: rgba(255,255,255,0.6); font-weight: 500; }
.sub-refresh-btn { margin-left: auto; font-size: 22rpx; color: #00d4ff; padding: 6rpx 16rpx; background: rgba(0,212,255,0.1); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 16rpx; }
.sub-user-list { display: flex; flex-direction: column; gap: 12rpx; }
.sub-user-item { display: flex; align-items: center; justify-content: space-between; padding: 20rpx; background: rgba(0,0,0,0.2); border: 1rpx solid rgba(0,212,255,0.08); border-radius: 12rpx; }
.sub-user-left { display: flex; align-items: center; gap: 16rpx; }
.sub-user-type-tag { padding: 6rpx 16rpx; border-radius: 8rpx; font-size: 20rpx; font-weight: 600; }
.sub-user-type-tag.announcement { background: rgba(0,212,255,0.15); color: #00d4ff; }
.sub-user-type-tag.activity { background: rgba(255,171,64,0.15); color: #ffab40; }
.sub-user-type-tag.system { background: rgba(153,69,255,0.15); color: #9945ff; }
.sub-user-type-tag.merchant { background: rgba(52,199,89,0.15); color: #34c759; }
.sub-user-type-tag.interaction { background: rgba(224,64,251,0.15); color: #e040fb; }
.sub-user-info { display: flex; flex-direction: column; gap: 4rpx; }
.sub-user-count { font-size: 26rpx; color: rgba(255,255,255,0.8); font-weight: 500; }
.sub-user-time { font-size: 20rpx; color: rgba(255,255,255,0.4); }
.sub-user-right { display: flex; align-items: center; gap: 12rpx; }
.sub-user-status { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 6rpx; }
.sub-user-status.active { color: #34c759; background: rgba(52,199,89,0.1); border: 1rpx solid rgba(52,199,89,0.2); }
.sub-user-status.expired { color: rgba(255,255,255,0.4); background: rgba(255,255,255,0.05); border: 1rpx solid rgba(255,255,255,0.1); }
.sub-user-del { font-size: 22rpx; color: #ff4757; padding: 6rpx 14rpx; background: rgba(255,71,87,0.1); border: 1rpx solid rgba(255,71,87,0.2); border-radius: 8rpx; }
.sub-empty { text-align: center; padding: 40rpx 0; }
.sub-empty-text { font-size: 26rpx; color: rgba(255,255,255,0.4); }