.detail-header { background: linear-gradient(135deg, #ff6900, #ff8533); border-radius: 20rpx; padding: 40rpx; text-align: center; margin-bottom: 16rpx; }
.detail-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 48rpx; font-weight: 600; margin: 0 auto 12rpx; }
.detail-name { font-size: 40rpx; font-weight: 700; color: #fff; display: block; }
.detail-meta { font-size: 22rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }
.tabs { display: flex; background: #f0f0f0; border-radius: 12rpx; margin-bottom: 16rpx; overflow: hidden; }
.tab { flex: 1; text-align: center; padding: 18rpx 0; font-size: 26rpx; color: #666; }
.tab.on { background: #ff6900; color: #fff; font-weight: 600; }
.card { background: #ffffff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 1px 8px rgba(0,0,0,0.04); }
.info-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1px solid #f0f0f0; }
.info-row:last-child { border: none; }
.info-lb { font-size: 26rpx; color: #999; }
.info-vl { font-size: 26rpx; color: #1a1a1a; font-weight: 600; }
.info-desc { font-size: 24rpx; color: #666; line-height: 1.7; margin-top: 12rpx; display: block; }
.stat-row { display: flex; align-items: center; margin-bottom: 14rpx; }
.stat-name { width: 64rpx; font-size: 22rpx; color: #999; }
.stat-bar-bg { flex: 1; height: 18rpx; background: #f0f0f0; border-radius: 9rpx; margin: 0 10rpx; overflow: hidden; }
.stat-bar { height: 100%; border-radius: 9rpx; }
.stat-val { width: 52rpx; text-align: right; font-size: 22rpx; color: #1a1a1a; font-weight: 600; }
.stat-total { display: flex; justify-content: space-between; padding-top: 10rpx; border-top: 1px solid #f0f0f0; }
.stat-total-val { font-size: 28rpx; color: #ff6900; font-weight: 700; }
.skill-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10rpx; }
.skill-item { display: flex; align-items: center; gap: 8rpx; padding: 12rpx; background: #f8f9fa; border-radius: 10rpx; }
.skill-dot { width: 10rpx; height: 10rpx; background: #ff6900; border-radius: 50%; }
.skill-name { font-size: 24rpx; color: #333; }
.detail-btns { display: flex; gap: 12rpx; }
.detail-btns button { flex: 1; border-radius: 40rpx; height: 80rpx; line-height: 80rpx; font-size: 28rpx; border: none; }
.btn-share { background: #ff6900; color: #fff; }
.btn-share::after { border: none; }
.btn-copy { background: #f5f7fa; color: #333; }
.btn-copy::after { border: none; }
