/* 精灵详情科技感样式 */
.detail-header { background: linear-gradient(135deg, #1a1040, #2d1b69, #0a0e27); border-radius: 20rpx; padding: 48rpx 40rpx; text-align: center; margin-bottom: 24rpx; border: 1rpx solid rgba(0,212,255,0.2); }
.detail-avatar { width: 128rpx; height: 128rpx; border-radius: 50%; background: linear-gradient(135deg, rgba(0,212,255,0.2), rgba(153,69,255,0.2)); border: 2rpx solid rgba(0,212,255,0.3); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 52rpx; font-weight: 600; margin: 0 auto 16rpx; box-shadow: 0 0 24px rgba(0,212,255,0.2); }
.detail-name { font-size: 44rpx; font-weight: 700; color: #fff; display: block; text-shadow: 0 0 16px rgba(0,212,255,0.4); }
.detail-meta { font-size: 22rpx; color: rgba(0,212,255,0.7); margin-top: 10rpx; }
.tabs { display: flex; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 12rpx; margin-bottom: 20rpx; overflow: hidden; }
.tab { flex: 1; text-align: center; padding: 18rpx 0; font-size: 26rpx; color: rgba(255,255,255,0.5); }
.tab.on { background: linear-gradient(135deg, rgba(0,212,255,0.3), rgba(153,69,255,0.3)); color: #00d4ff; font-weight: 600; box-shadow: 0 0 12px rgba(0,212,255,0.2); }
.info-row { display: flex; justify-content: space-between; padding: 14rpx 0; border-bottom: 1rpx solid rgba(0,212,255,0.08); }
.info-row:last-child { border: none; }
.info-lb { font-size: 26rpx; color: rgba(255,255,255,0.4); }
.info-vl { font-size: 26rpx; color: #fff; font-weight: 600; }
.info-desc { font-size: 24rpx; color: rgba(255,255,255,0.6); line-height: 1.8; margin-top: 16rpx; display: block; }
.stat-row { display: flex; align-items: center; margin-bottom: 16rpx; }
.stat-name { width: 68rpx; font-size: 22rpx; color: rgba(255,255,255,0.4); }
.stat-bar-bg { flex: 1; height: 18rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 9rpx; margin: 0 12rpx; overflow: hidden; }
.stat-bar { height: 100%; border-radius: 9rpx; background: linear-gradient(90deg, #00d4ff, #9945ff); box-shadow: 0 0 8px rgba(0,212,255,0.4); }
.stat-val { width: 56rpx; text-align: right; font-size: 22rpx; color: #00d4ff; font-weight: 600; }
.stat-total { display: flex; justify-content: space-between; padding-top: 12rpx; border-top: 1rpx solid rgba(0,212,255,0.1); }
.stat-total-val { font-size: 28rpx; color: #00d4ff; font-weight: 700; text-shadow: 0 0 8px rgba(0,212,255,0.5); }
.skill-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12rpx; }
.skill-item { display: flex; align-items: center; gap: 10rpx; padding: 14rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 10rpx; }
.skill-dot { width: 12rpx; height: 12rpx; background: #00d4ff; border-radius: 50%; box-shadow: 0 0 8px rgba(0,212,255,0.5); }
.skill-name { font-size: 24rpx; color: #fff; }
.detail-btns { display: flex; gap: 16rpx; }
.detail-btns button { flex: 1; border-radius: 40rpx; height: 88rpx; line-height: 88rpx; font-size: 28rpx; border: none; }
.btn-share { background: linear-gradient(135deg, #00d4ff, #9945ff); color: #fff; box-shadow: 0 4px 16px rgba(0,212,255,0.3); }
.btn-share::after { border: none; }
.btn-copy { background: rgba(0,212,255,0.1); color: #00d4ff; border: 1rpx solid rgba(0,212,255,0.2); }
.btn-copy::after { border: none; }
