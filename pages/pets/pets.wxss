/* 精灵图鉴科技感样式 */
.search-box { display: flex; align-items: center; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 40rpx; padding: 16rpx 24rpx; margin-bottom: 16rpx; }
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; color: #00d4ff; }
.search-input::placeholder { color: rgba(0,212,255,0.3); }
.filter-bar { white-space: nowrap; margin-bottom: 16rpx; }
.filter-tag { display: inline-block; padding: 10rpx 24rpx; background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 28rpx; font-size: 22rpx; color: rgba(255,255,255,0.5); margin-right: 12rpx; }
.filter-tag.active { background: linear-gradient(135deg, rgba(0,212,255,0.3), rgba(153,69,255,0.3)); border-color: #00d4ff; color: #00d4ff; font-weight: 600; box-shadow: 0 0 12px rgba(0,212,255,0.2); }
.pet-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10rpx; margin: 0 6rpx; }
.pet-card { background: linear-gradient(145deg, rgba(20,25,60,0.9), rgba(15,18,45,0.95)); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 12rpx; overflow: hidden; }
.pet-img { width: 100%; height: 180rpx; display: block; background: rgba(0,212,255,0.05); }
.pet-card .pet-name { font-size: 20rpx; font-weight: 600; color: #fff; text-align: center; margin-top: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; padding: 0 4rpx; }
.pet-types { display: flex; gap: 3rpx; margin-top: 4rpx; margin-bottom: 8rpx; justify-content: center; flex-wrap: wrap; }
.pet-type-badge { font-size: 16rpx; padding: 1rpx 6rpx; border-radius: 4rpx; background: rgba(0,212,255,0.15); color: rgba(0,212,255,0.7); }
.no-more { text-align: center; color: rgba(255,255,255,0.3); font-size: 20rpx; padding: 20rpx 0; }
.empty { text-align: center; color: rgba(255,255,255,0.5); font-size: 24rpx; padding: 32rpx 0; }
.source { text-align: center; font-size: 18rpx; color: rgba(0,212,255,0.3); padding: 20rpx 0; }
