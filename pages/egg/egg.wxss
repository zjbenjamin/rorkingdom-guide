.dev-card { background: #ffffff; border-radius: 20rpx; padding: 24rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 600rpx; box-shadow: 0 1px 8px rgba(0,0,0,0.04); }
.dev-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.dev-title { font-size: 36rpx; font-weight: 600; color: #1a1a1a; margin-bottom: 16rpx; }
.dev-desc { font-size: 26rpx; color: #666; margin-bottom: 12rpx; }
.dev-tip { font-size: 22rpx; color: #999; }
