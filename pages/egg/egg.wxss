/* 尺寸反查工具专用样式 */
.lookup-card {
  background: radial-gradient(circle at top right, rgba(255, 200, 57, 0.12), transparent 45%),
              linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.01)) !important;
  border: 1px solid rgba(255, 200, 57, 0.15) !important;
  box-shadow: 0 8px 32px rgba(31, 36, 48, 0.2);
}

