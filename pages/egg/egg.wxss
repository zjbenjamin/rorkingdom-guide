/* 顶部功能区 */
.page { min-height: 100vh; background-color: #010314; background-image: radial-gradient(ellipse 70% 40% at 40% 20%, rgba(100,200,100,0.06) 0%, transparent 50%), linear-gradient(185deg, #020410 0%, #040c24 100%); animation: pageExpand 0.5s cubic-bezier(0.22, 0.61, 0.36, 1); padding-bottom: 180rpx; }
@keyframes pageExpand { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
.egg-header-actions { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.egg-calc-entry-mini { display: flex; align-items: center; gap: 10rpx; background: rgba(0,212,255,0.1); border: 1rpx solid rgba(0,212,255,0.2); padding: 12rpx 20rpx; border-radius: 40rpx; }
.entry-mini-icon { font-size: 28rpx; }
.entry-mini-text { font-size: 24rpx; color: #00d4ff; font-weight: 500; }

.egg-tabs { display: flex; flex: 1; background: rgba(255,255,255,0.05); border-radius: 40rpx; padding: 6rpx; border: 1rpx solid rgba(255,255,255,0.1); }
.egg-tab { flex: 1; text-align: center; font-size: 24rpx; color: rgba(255,255,255,0.5); padding: 12rpx 0; border-radius: 34rpx; transition: all 0.3s; }
.egg-tab.active { background: linear-gradient(135deg, #00d4ff, #9945ff); color: #fff; font-weight: 600; }

/* 搜索栏 */
.search-bar-wrap { margin-bottom: 24rpx; }
.search-bar { display: flex; align-items: center; gap: 16rpx; background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(255,255,255,0.1); border-radius: 16rpx; padding: 0 24rpx; height: 80rpx; }
.search-icon { font-size: 28rpx; color: rgba(255,255,255,0.3); }
.search-input { flex: 1; font-size: 26rpx; color: #fff; height: 100%; }

/* 精灵蛋池新列表 */
.pet-pool-list { display: flex; flex-direction: column; }
.pet-pool-item { display: flex; align-items: center; justify-content: space-between; padding: 24rpx; border-bottom: 1rpx solid rgba(255,255,255,0.05); }
.pet-pool-item:last-child { border-bottom: none; }
.pet-pool-info { flex: 1; display: flex; flex-direction: column; gap: 8rpx; }
.pet-pool-name-row { display: flex; align-items: center; gap: 16rpx; }
.pet-pool-name { font-size: 30rpx; font-weight: 700; color: #fff; }
.pet-pool-types { display: flex; gap: 8rpx; }
.pet-pool-type { font-size: 20rpx; color: #fff; padding: 2rpx 10rpx; border-radius: 6rpx; background: rgba(255,255,255,0.1); }

/* 属性颜色 */
.type-grass { background: #2e7d32; }
.type-fire { background: #d32f2f; }
.type-water { background: #1565c0; }
.type-electric { background: #f57f17; }
.type-light { background: #ffeb3b; color: #000; }
.type-normal { background: #9e9e9e; }
.type-machinery { background: #607d8b; }
.type-ice { background: #00bcd4; }
.type-dragon { background: #673ab7; }
.type-dark { background: #424242; }
.type-flying { background: #4fc3f7; }
.type-magic { background: #ec407a; }
.type-fight { background: #e53935; }
.type-rock { background: #8d6e63; }
.type-steel { background: #90a4ae; }
.type-fairy { background: #f48fb1; }
.type-psychic { background: #f06292; }
.type-ghost { background: #7e57c2; }
.type-poison { background: #9c27b0; }
.type-ground { background: #a1887f; }
.type-bug { background: #8bc34a; }
.type-martial { background: #bf360c; }
.type-shadow { background: #512da8; }
.type-cute { background: #ff80ab; }
.type-wing { background: #90caf9; }
.type-darkness { background: #212121; }
.type-stone { background: #795548; }

.pet-pool-meta { display: flex; flex-direction: column; gap: 4rpx; }
.pet-pool-egg { font-size: 22rpx; color: rgba(255,255,255,0.4); }
.pet-pool-loc { font-size: 22rpx; color: rgba(0,212,255,0.5); }

.pet-pool-shiny { flex-shrink: 0; }
.shiny-tag { font-size: 20rpx; color: #ffca28; border: 1rpx solid #ffca28; padding: 2rpx 8rpx; border-radius: 4rpx; background: rgba(255,202,40,0.1); }

.empty-results { text-align: center; padding: 60rpx 0; }
.empty-results-text { font-size: 26rpx; color: rgba(255,255,255,0.3); }

/* 骑乘效果优化 */
.mount-main { display: flex; align-items: baseline; gap: 12rpx; margin-bottom: 4rpx; }
.mount-pet { font-size: 28rpx; font-weight: 700; color: #fff; }
.mount-name { font-size: 24rpx; color: #00d4ff; }
.mount-bonus { font-size: 24rpx; color: #34c759; display: block; margin-bottom: 4rpx; }
.mount-req { font-size: 22rpx; color: rgba(255,255,255,0.3); display: block; }

.no-padding { padding: 0 !important; }

/* 蛋类型网格 */
.admin-bar { padding: 20rpx 24rpx; margin-bottom: 16rpx; }
.admin-bar-row { display: flex; align-items: center; gap: 16rpx; }
.admin-bar-label { font-size: 26rpx; color: rgba(255,255,255,0.6); }
.admin-bar-text { font-size: 24rpx; color: #00d4ff; }
.toggle { width: 88rpx; height: 48rpx; background: rgba(255,255,255,0.15); border-radius: 24rpx; padding: 4rpx; transition: background 0.3s; margin-left: auto; }
.toggle.on { background: linear-gradient(135deg, #00d4ff, #9945ff); }
.toggle-dot { width: 40rpx; height: 40rpx; background: #fff; border-radius: 50%; transition: transform 0.3s; }
.toggle.on .toggle-dot { transform: translateX(40rpx); }

/* 编辑提示 */
.admin-edit-hint { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 16rpx; background: rgba(0,212,255,0.08); border: 1rpx dashed rgba(0,212,255,0.3); border-radius: 8rpx; margin-bottom: 16rpx; }
.edit-hint-icon { font-size: 28rpx; }
.edit-hint-text { font-size: 22rpx; color: rgba(0,212,255,0.7); }

/* 自定义内容 */
.custom-content { background: rgba(255, 255, 255, 0.04); border-radius: 12rpx; padding: 20rpx; }
.custom-text { font-size: 26rpx; color: rgba(255,255,255,0.7); line-height: 1.8; white-space: pre-wrap; }
.empty-hint { text-align: center; padding: 40rpx 0; }
.empty-text { font-size: 26rpx; color: rgba(255,255,255,0.5); }

/* 蛋类型网格 */
.egg-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12rpx; }
.egg-card { background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 14rpx; padding: 20rpx; text-align: center; }
.egg-icon { font-size: 48rpx; display: block; margin-bottom: 8rpx; }
.egg-name { font-size: 26rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 6rpx; }
.egg-prob { font-size: 22rpx; color: #00d4ff; display: block; margin-bottom: 6rpx; }
.egg-desc { font-size: 20rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 4rpx; }
.egg-bonus { font-size: 20rpx; color: #34c759; display: block; }

/* 精灵蛋池 */
.pet-list { display: flex; flex-direction: column; gap: 8rpx; }
.pet-item { display: flex; align-items: center; gap: 12rpx; padding: 16rpx; background: rgba(255, 255, 255, 0.04); border-radius: 10rpx; }
.pet-name { font-size: 26rpx; font-weight: 600; color: #fff; min-width: 120rpx; }
.pet-type { font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 6rpx; color: #fff; }
.type-grass { background: #2e7d32; }
.type-fire { background: #d32f2f; }
.type-water { background: #1565c0; }
.type-light { background: #f57f17; }
.type-normal { background: #666; }
.type-mech { background: #546e7a; }
.type-fantasy { background: #9c27b0; }
.pet-egg { font-size: 22rpx; color: rgba(255,255,255,0.5); flex: 1; }
.pet-loc { font-size: 20rpx; color: rgba(0,212,255,0.5); }

/* 骑乘效果 */
.mount-list { display: flex; flex-direction: column; gap: 8rpx; }
.mount-item { display: flex; flex-direction: column; gap: 4rpx; padding: 16rpx; background: rgba(255, 255, 255, 0.04); border-radius: 10rpx; }
.mount-pet { font-size: 24rpx; font-weight: 600; color: #fff; }
.mount-name { font-size: 22rpx; color: #00d4ff; }
.mount-bonus { font-size: 22rpx; color: #34c759; }
.mount-req { font-size: 20rpx; color: rgba(255,255,255,0.4); }

/* 数据来源 */
.source { font-size: 22rpx; color: rgba(0,212,255,0.5); display: block; margin-top: 8rpx; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.7); z-index: 1000; display: flex; align-items: flex-end; }
.modal-box { width: 100%; background: rgba(16, 20, 48, 0.9); border: 1rpx solid rgba(255, 255, 255, 0.1); border-radius: 32rpx 32rpx 0 0; padding: 32rpx; max-height: 80vh; display: flex; flex-direction: column; box-shadow: 0 0 0 1rpx rgba(255,255,255,0.04) inset, 0 1rpx 0 rgba(255,255,255,0.04) inset, 0 -8rpx 40rpx rgba(0,0,0,0.3); }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; flex-shrink: 0; }
.modal-title { font-size: 32rpx; font-weight: 700; color: #00d4ff; }
.modal-close { font-size: 36rpx; color: rgba(255,255,255,0.4); padding: 8rpx; }
.modal-body { overflow-y: auto; -webkit-overflow-scrolling: touch; }
.modal-textarea { width: 100%; height: 400rpx; background: rgba(255, 255, 255, 0.04); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 12rpx; padding: 20rpx; font-size: 26rpx; color: #fff; box-sizing: border-box; margin-bottom: 24rpx; }
.modal-footer { display: flex; gap: 16rpx; flex-shrink: 0; padding-top: 20rpx; }
.modal-cancel { flex: 1; background: rgba(255, 255, 255, 0.1) !important; color: rgba(255,255,255,0.7) !important; border-radius: 16rpx !important; height: 80rpx !important; line-height: 80rpx !important; font-size: 26rpx !important; border: 1rpx solid rgba(255,255,255,0.08) !important; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.04); display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.modal-cancel::after { border: none; }
.modal-save { flex: 1; background: rgba(0, 200, 255, 0.12) !important; color: #00d4ff !important; border-radius: 16rpx !important; height: 80rpx !important; line-height: 80rpx !important; font-size: 26rpx !important; border: 1rpx solid rgba(0, 200, 255, 0.2) !important; box-shadow: 0 0 0 1rpx rgba(0,200,255,0.05) inset, 0 1rpx 0 rgba(150,220,255,0.05) inset; display: flex !important; align-items: center !important; justify-content: center !important; text-align: center !important; }
.modal-save::after { border: none; }
.modal-save[disabled] { opacity: 0.5; }

/* 维护模式 */
.maintain-card { text-align: center; padding: 80rpx 40rpx; }
.maintain-icon { font-size: 96rpx; display: block; margin-bottom: 24rpx; }
.maintain-title { font-size: 36rpx; font-weight: 700; color: rgba(255,255,255,0.7); display: block; margin-bottom: 16rpx; }
.maintain-desc { font-size: 26rpx; color: rgba(255,255,255,0.4); display: block; }

/* 蛋组计算器入口 */
.egg-calc-entry { margin-bottom: 20rpx; }
.egg-calc-entry-content { display: flex; align-items: center; gap: 20rpx; padding: 8rpx 0; }
.egg-calc-entry-icon { font-size: 48rpx; }
.egg-calc-entry-info { flex: 1; }
.egg-calc-entry-title { font-size: 30rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 6rpx; }
.egg-calc-entry-desc { font-size: 22rpx; color: rgba(255,255,255,0.4); display: block; margin-bottom: 6rpx; }
.egg-calc-entry-arrow { font-size: 40rpx; color: rgba(0,212,255,0.4); }

/* 孵蛋规则页特定样式 */
.rule-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 8rpx 0;
}
.rule-item-box {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(0, 212, 255, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
}
.rule-item-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.rule-item-badge {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}
.rule-item-badge.female {
  background: linear-gradient(135deg, #ff80ab, #ff4081);
  box-shadow: 0 4rpx 10rpx rgba(255, 64, 129, 0.3);
}
.rule-item-badge.male {
  background: linear-gradient(135deg, #00b0ff, #00e5ff);
  box-shadow: 0 4rpx 10rpx rgba(0, 229, 255, 0.3);
}
.rule-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}
.rule-item-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.6;
}

/* 道具规则 */
.item-rules-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}
.item-rule-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(0, 212, 255, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.item-rule-top {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.item-rule-emoji {
  font-size: 36rpx;
}
.item-rule-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}
.item-rule-effect {
  font-size: 22rpx;
  color: #00d4ff;
  font-weight: 500;
}
.item-rule-detail {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.5;
}

/* 闪光传递 */
.shiny-trans-box {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 24rpx;
}
.shiny-formula {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}
.shiny-pet {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.shiny-pet.parent {
  border-color: rgba(255, 215, 0, 0.3);
}
.shiny-pet.child {
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.2), rgba(255, 64, 129, 0.2));
  border-color: #ffd700;
  box-shadow: 0 0 12rpx rgba(255, 215, 0, 0.3);
}
.shiny-emoji {
  font-size: 24rpx;
}
.shiny-plus, .shiny-arrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.4);
  font-weight: 700;
}
.shiny-rules-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.shiny-rule-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.5;
}

