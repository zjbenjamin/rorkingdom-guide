  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  margin-bottom: 24rpx;
  line-height: 1.4;
}

.lookup-form {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.lookup-form-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 90rpx;
}

.lookup-label {
  width: 160rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.lookup-input {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
  height: 100%;
}

.lookup-picker {
  flex: 1;
  height: 100%;
  display: flex;
  align-items: center;
}

.picker-value-wrap {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 28rpx;
  color: #fff;
}

.picker-arrow {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

.lookup-actions {
  display: flex;
  gap: 16rpx;
}

.lookup-btn {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 40rpx;
  padding: 0;
  transition: all 0.2s ease;
}

.lookup-btn::after {
  display: none;
}

.btn-clear {
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.65);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.btn-clear:active {
  background: rgba(255, 255, 255, 0.1);
  transform: translateY(1px);
}

.btn-submit {
  background: linear-gradient(135deg, #FFC839, #ffe082);
  color: #4f3700;
  box-shadow: 0 8px 20px rgba(255, 200, 57, 0.15);
}

.btn-submit:active {
  opacity: 0.9;
  transform: translateY(1px);
}

