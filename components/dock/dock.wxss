.dock {
  position: fixed;
  bottom: 28rpx;
  bottom: calc(28rpx + constant(safe-area-inset-bottom));
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  left: 50%;
  transform: translateX(-50%);
  z-index: 9999;
}
.dock-inner {
  display: flex;
  gap: 24rpx;
  align-items: center;
  padding: 16rpx 36rpx;
  border-radius: 60rpx;
  background: rgba(16, 20, 48, 0.72);
  backdrop-filter: blur(32rpx);
  -webkit-backdrop-filter: blur(32rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 
    0 0 0 1rpx rgba(255, 255, 255, 0.04) inset,
    0 1rpx 0 rgba(255, 255, 255, 0.06) inset,
    0 12rpx 48rpx rgba(0, 0, 0, 0.35),
    0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}
.dock-item {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  background: transparent;
  box-sizing: border-box;
}
navigator.dock-item {
  margin: 0;
  padding: 0;
  line-height: 1;
}
.dock-item:active {
  transform: scale(0.82);
  background: rgba(0, 200, 255, 0.12);
  transition: transform 0.1s ease, background 0.08s ease;
}
.dock-item.active {
  background: rgba(255, 255, 255, 0.1);
  box-shadow: 0 0 16rpx rgba(0, 212, 255, 0.12);
}
.dock-icon {
  font-size: 36rpx;
  line-height: 1;
}
