.comments-wrap { margin-top: 24rpx; }
.comments-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.comments-title { font-size: 30rpx; font-weight: 700; color: #00d4ff; }
.comments-rating { display: flex; align-items: center; gap: 8rpx; }
.rating-star { font-size: 28rpx; color: #ffab40; }
.rating-val { font-size: 28rpx; color: #ffab40; font-weight: 700; }

.comment-input-bar { background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 12rpx; padding: 20rpx 24rpx; margin-bottom: 20rpx; }
.input-placeholder { font-size: 26rpx; color: rgba(255,255,255,0.5); }

.comment-form { background: rgba(0,0,0,0.3); border: 1rpx solid rgba(0,212,255,0.2); border-radius: 12rpx; padding: 24rpx; margin-bottom: 20rpx; }
.rating-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 16rpx; }
.rating-label { font-size: 24rpx; color: rgba(255,255,255,0.5); }
.star { font-size: 40rpx; color: rgba(255,255,255,0.2); }
.star.on { color: #ffab40; text-shadow: 0 0 8px rgba(255,171,64,0.5); }
.reply-hint { font-size: 22rpx; color: #00d4ff; margin-bottom: 12rpx; }
.comment-textarea { width: 100%; min-height: 120rpx; background: rgba(0,0,0,0.2); border: 1rpx solid rgba(0,212,255,0.1); border-radius: 8rpx; padding: 16rpx 20rpx; font-size: 26rpx; color: #fff; box-sizing: border-box; }
.form-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 16rpx; }
.form-tools { display: flex; align-items: center; gap: 20rpx; }
.tool-btn { display: flex; align-items: center; gap: 6rpx; padding: 8rpx 16rpx; background: rgba(0,212,255,0.1); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 8rpx; }
.tool-icon { font-size: 28rpx; }
.tool-text { font-size: 22rpx; color: rgba(255,255,255,0.6); }
.char-count { font-size: 22rpx; color: rgba(255,255,255,0.5); }
.submit-btn { background: linear-gradient(135deg, #00d4ff, #9945ff); color: #fff; font-size: 24rpx; border-radius: 8rpx; padding: 0 28rpx; height: 68rpx; line-height: 68rpx; min-width: 120rpx; }
.submit-btn::after { border: none; }
.submit-btn[disabled] { opacity: 0.5; }

.image-list { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.image-item { position: relative; width: 160rpx; height: 160rpx; }
.image-thumb { width: 100%; height: 100%; border-radius: 8rpx; border: 1rpx solid rgba(0,212,255,0.15); }
.image-remove { position: absolute; top: -8rpx; right: -8rpx; width: 36rpx; height: 36rpx; background: rgba(255,71,87,0.9); color: #fff; font-size: 20rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }

/* 图片链接输入 */
.image-url-row { display: flex; gap: 12rpx; margin-top: 12rpx; }
.image-url-input { flex: 1; min-height: 60rpx; background: rgba(0,0,0,0.2); border: 1rpx solid rgba(0,212,255,0.15); border-radius: 8rpx; padding: 0 16rpx; font-size: 24rpx; color: #fff; }
.image-url-btn { padding: 0 20rpx; height: 60rpx; line-height: 60rpx; background: rgba(0,212,255,0.15); border: 1rpx solid rgba(0,212,255,0.3); border-radius: 8rpx; font-size: 24rpx; color: #00d4ff; flex-shrink: 0; }

.comment-list { }
.comment-item { display: flex; gap: 16rpx; padding: 24rpx 0; border-bottom: 1rpx solid rgba(0,212,255,0.08); }
.comment-item:last-child { border: none; }
.comment-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; border: 1rpx solid rgba(0,212,255,0.2); flex-shrink: 0; background: rgba(0,212,255,0.1); }
.comment-body { flex: 1; min-width: 0; }
.comment-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.comment-name { font-size: 24rpx; color: rgba(255,255,255,0.8); font-weight: 600; }
.comment-stars { display: flex; gap: 2rpx; }
.star-sm { font-size: 20rpx; color: #ffab40; }
.comment-text { font-size: 26rpx; color: rgba(255,255,255,0.7); line-height: 1.6; word-break: break-all; display: block; margin-bottom: 12rpx; }
.comment-images { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 12rpx; }
.comment-image { width: 160rpx; height: 160rpx; border-radius: 8rpx; border: 1rpx solid rgba(0,212,255,0.1); }
.comment-bottom { display: flex; justify-content: space-between; align-items: center; }
.comment-time { font-size: 20rpx; color: rgba(255,255,255,0.5); }
.comment-actions { display: flex; gap: 24rpx; }
.action-btn { display: flex; align-items: center; gap: 4rpx; }
.action-icon { font-size: 24rpx; color: rgba(255,255,255,0.4); }
.action-btn.liked .action-icon { color: #ff4757; }
.action-count { font-size: 20rpx; color: rgba(255,255,255,0.4); }
.action-btn.liked .action-count { color: #ff4757; }

.empty-state { text-align: center; padding: 60rpx 0; }
.empty-icon { font-size: 64rpx; display: block; margin-bottom: 16rpx; }
.empty-text { font-size: 24rpx; color: rgba(255,255,255,0.5); }

.load-more { text-align: center; padding: 24rpx 0; }
.loading-text { font-size: 24rpx; color: rgba(0,212,255,0.5); }
.more-text { font-size: 24rpx; color: #00d4ff; }
.no-more { text-align: center; padding: 24rpx 0; }
.no-more-text { font-size: 22rpx; color: rgba(255,255,255,0.4); }