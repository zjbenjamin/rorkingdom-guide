<view class="comments-wrap">
  <view class="comments-header">
    <text class="comments-title">评论 ({{totalCount}})</text>
    <view class="comments-rating" wx:if="{{avgRating > 0}}">
      <text class="rating-star">★</text>
      <text class="rating-val">{{avgRating}}</text>
    </view>
  </view>

  <view class="comment-input-bar" bindtap="toggleInput">
    <text class="input-placeholder">{{showInput ? '点击收起' : '说点什么...'}}</text>
  </view>

  <view class="comment-form" wx:if="{{showInput}}">
    <view class="rating-row">
      <text class="rating-label">评分：</text>
      <text class="star {{rating >= 1 ? 'on' : ''}}" bindtap="onRating" data-val="1">★</text>
      <text class="star {{rating >= 2 ? 'on' : ''}}" bindtap="onRating" data-val="2">★</text>
      <text class="star {{rating >= 3 ? 'on' : ''}}" bindtap="onRating" data-val="3">★</text>
      <text class="star {{rating >= 4 ? 'on' : ''}}" bindtap="onRating" data-val="4">★</text>
      <text class="star {{rating >= 5 ? 'on' : ''}}" bindtap="onRating" data-val="5">★</text>
    </view>
    <view class="reply-hint" wx:if="{{replyTo}}">回复中...</view>
    <textarea class="comment-textarea" placeholder="写下你的评论..." value="{{inputValue}}" bindinput="onInput" maxlength="500" auto-height />
    <view class="image-list" wx:if="{{images.length > 0}}">
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image class="image-thumb" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-src="{{item}}" />
        <view class="image-remove" catchtap="removeImage" data-idx="{{index}}">✕</view>
      </view>
    </view>
    <view class="image-url-row" wx:if="{{images.length < 9}}">
      <input class="image-url-input" placeholder="粘贴图片链接添加" placeholder-style="color:rgba(255,255,255,0.35)" value="{{imageUrlInput}}" bindinput="onImageUrlInput" />
      <view class="image-url-btn" catchtap="addImageByUrl">添加</view>
    </view>
    <view class="form-footer">
      <view class="form-tools">
        <view class="tool-btn" bindtap="chooseImage">
          <text class="tool-icon">🖼</text>
          <text class="tool-text">图片</text>
        </view>
        <text class="char-count">{{inputValue.length}}/500</text>
      </view>
      <button class="submit-btn" bindtap="submitComment" disabled="{{submitting || uploading}}">{{submitting || uploading ? '发送中' : '发送'}}</button>
    </view>
  </view>

  <view class="comment-list">
    <view class="comment-item" wx:for="{{comments}}" wx:key="_id">
      <image class="comment-avatar" src="{{item.userAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="comment-body">
        <view class="comment-top">
          <text class="comment-name">{{item.userName}}</text>
          <view class="comment-stars" wx:if="{{item.rating > 0}}">
            <text class="star-sm" wx:for="{{5}}" wx:for-item="s" wx:for-index="si" wx:key="si" wx:if="{{si < item.rating}}">★</text>
          </view>
        </view>
        <text class="comment-text" wx:if="{{item.content}}">{{item.content}}</text>
        <view class="comment-images" wx:if="{{item.images && item.images.length > 0}}">
          <image class="comment-image" wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" src="{{img}}" mode="aspectFill" bindtap="previewImage" data-src="{{img}}" />
        </view>
        <view class="comment-bottom">
          <text class="comment-time">{{item.timeStr}}</text>
          <view class="comment-actions">
            <view class="action-btn {{item.liked ? 'liked' : ''}}" bindtap="toggleLike" data-item="{{item}}">
              <text class="action-icon">{{item.liked ? '❤' : '♡'}}</text>
              <text class="action-count" wx:if="{{item.likes.length > 0}}">{{item.likes.length}}</text>
            </view>
            <view class="action-btn" bindtap="replyToComment" data-item="{{item}}">
              <text class="action-icon">💬</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{!loading && comments.length === 0}}">
      <text class="empty-icon">💬</text>
      <text class="empty-text">暂无评论，快来发表第一条评论吧</text>
    </view>

    <view class="load-more" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>

    <view class="load-more" wx:if="{{!loading && hasMore && comments.length > 0}}" bindtap="loadMore">
      <text class="more-text">加载更多</text>
    </view>

    <view class="no-more" wx:if="{{!loading && !hasMore && comments.length > 0}}">
      <text class="no-more-text">— 没有更多了 —</text>
    </view>
  </view>
</view>